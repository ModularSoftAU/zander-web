<%- include("modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Support the Crafting For Christ Network and help us reach more players with a safe, Christ-centred community."
}) %>

<%- include("modules/navigationBar.ejs") %>

<%
  const formattedCurrency = (value) => Number(value || 0).toLocaleString("en-US", {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });

  const fundedPercent = Math.min(100, Number(supportProgress?.percentageFunded || 0)).toFixed(2);
  const raised = Number(supportProgress?.currentMonthRevenue || 0);
  const goal = Number(supportProgress?.monthlyOperationsBudget || 0);
%>

<section class="banner hero-overlay" style="background: linear-gradient(180deg, rgba(3, 25, 44, 0.8) 0%, rgba(3, 25, 44, 0.85) 100%), url(<%= globalImage %>) no-repeat 50% 50%; background-size:cover">
  <div class="container">
    <% if (req.cookies.alertType) { %>
      <br>
      <%- include("partials/alert.ejs", {
        alertType: req.cookies.alertType,
        content: req.cookies.alertContent
      }) %>
    <% } %>

    <div class="row align-items-center">
      <div class="col-lg-7">
        <div class="block">
          <div class="divider mb-3"></div>
          <p class="text-uppercase text-sm letter-spacing mb-2">Support the Mission</p>
          <h1 class="mb-3 mt-2">🙏 Support the Crafting For Christ Network</h1>
          <p class="mb-4 pe-lg-5">Crafting For Christ exists to provide a safe, encouraging, Christ-centred community for players around the world. Your generosity helps keep the network running, growing, and reaching more people every day.</p>
          <div class="btn-container d-flex flex-wrap gap-3">
            <a href="/ranks" class="btn btn-main-2 btn-icon btn-round-full">View Ranks & Perks <i class="fa-solid fa-arrow-right"></i></a>
            <a href="/webstore" class="btn btn-outline-light btn-round-full">Give a Gift or Rank</a>
          </div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="p-4 bg-white rounded shadow text-dark">
          <p class="text-uppercase text-sm letter-spacing text-muted mb-1">This Month</p>
          <h3 class="mb-2">Monthly Operations Goal</h3>
          <p class="text-muted mb-4">Each month, we trust God to provide what’s needed to keep the network running. Below is our current month’s support progress:</p>
          <div class="progress" style="height: 12px;">
            <div class="progress-bar" role="progressbar" style="width: <%= fundedPercent %>%" aria-valuenow="<%= fundedPercent %>" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <div class="d-flex justify-content-between align-items-center mt-3">
            <p class="mb-0 fw-bold"><%= fundedPercent %>% Funded</p>
            <p class="mb-0">$<%= formattedCurrency(raised) %> raised of $<%= formattedCurrency(goal) %> goal</p>
          </div>
          <p class="text-muted mt-3 mb-0">Every purchase or donation made through our store contributes directly to this goal.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section bg-light">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <div class="section-title">
          <span class="text-color">Why We Give</span>
          <h2 class="mt-3">✨ Why Support the Network?</h2>
          <p class="lead">Crafting For Christ is fully community-funded. Your support directly helps us continue providing:</p>
          <ul class="list-unstyled mt-4">
            <li class="mb-2"><i class="fa-solid fa-circle-check text-color me-2"></i>Reliable and high-performance Minecraft servers</li>
            <li class="mb-2"><i class="fa-solid fa-circle-check text-color me-2"></i>A safe, wholesome place to play and grow</li>
            <li class="mb-2"><i class="fa-solid fa-circle-check text-color me-2"></i>Resources for events, ministry projects, and outreach</li>
            <li class="mb-3"><i class="fa-solid fa-circle-check text-color me-2"></i>An environment where friendships and faith flourish</li>
          </ul>
          <p class="mb-0">Whether it’s through prayer, encouragement, or financial support, you’re helping build something impactful.</p>
        </div>
      </div>
      <div class="col-lg-5 offset-lg-1">
        <div class="p-4 bg-white rounded shadow">
          <h5 class="mb-3">Monthly Operations Budget</h5>
          <p class="text-muted">We set a monthly operations goal to cover hosting, software, and ministry project expenses.</p>
          <div class="d-flex flex-column gap-2">
            <div class="d-flex justify-content-between">
              <span class="fw-bold">Goal</span>
              <span>$<%= formattedCurrency(goal) %></span>
            </div>
            <div class="d-flex justify-content-between">
              <span class="fw-bold">Current Month</span>
              <span>$<%= formattedCurrency(raised) %></span>
            </div>
            <div class="d-flex justify-content-between">
              <span class="fw-bold">Progress</span>
              <span><%= fundedPercent %>% funded</span>
            </div>
          </div>
          <div class="progress mt-3" style="height: 10px;">
            <div class="progress-bar bg-color" role="progressbar" style="width: <%= fundedPercent %>%" aria-valuenow="<%= fundedPercent %>" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <p class="text-muted mt-3 mb-0">Thank you for helping us keep the lights on and the community thriving.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="row justify-content-center text-center">
      <div class="col-lg-8">
        <span class="text-color">How You Can Support</span>
        <h2 class="mt-3">💬 Two Ways to Help Sustain the Ministry</h2>
        <p class="lead">Every bit of support helps us meet our monthly goal and reach more players with a safe, Christ-centred community.</p>
      </div>
    </div>

    <div class="row mt-5">
      <div class="col-lg-6 mb-4">
        <div class="service-item bg-white rounded shadow-sm h-100">
          <div class="p-4">
            <h4 class="mb-3">1. Purchasing a Rank</h4>
            <p class="mb-3">Rank purchases help fund operations and come with fun perks and cosmetics.</p>
            <p class="text-muted mb-4">👉 Explore ranks and perks at: <a href="/ranks">craftingforchrist.net/ranks</a></p>
            <a href="/ranks" class="btn btn-main-2 btn-round-full">View Ranks</a>
          </div>
        </div>
      </div>
      <div class="col-lg-6 mb-4">
        <div class="service-item bg-white rounded shadow-sm h-100">
          <div class="p-4">
            <h4 class="mb-3">2. Monthly Support Tiers</h4>
            <p class="mb-3">Recurring support is the most impactful way to help us meet our monthly operations budget.</p>
            <p class="text-muted mb-4">👉 Visit the webstore to subscribe or give: <a href="/webstore" target="_blank" rel="noopener">craftingforchrist.net/webstore</a></p>
            <a href="/webstore" class="btn btn-outline-primary btn-round-full">Visit Webstore</a>
          </div>
        </div>
      </div>
    </div>

    <div class="row justify-content-center mt-3">
      <div class="col-lg-8 text-center">
        <p class="mb-0">You can also gift a rank to bless another player!</p>
      </div>
    </div>
  </div>
</section>

<section class="section bg-light">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-5 mb-4 mb-lg-0">
        <div class="p-4 bg-white rounded shadow-sm">
          <h4 class="mb-3">❤️ Why Your Support Matters</h4>
          <p>Your contributions make a real difference. Because of your support, players from all over the world are finding a community where they can:</p>
          <ul class="list-unstyled mt-3">
            <li class="mb-2"><i class="fa-solid fa-heart text-color me-2"></i>Meet positive, Christ-following friends</li>
            <li class="mb-2"><i class="fa-solid fa-heart text-color me-2"></i>Find prayer, encouragement, and support</li>
            <li class="mb-2"><i class="fa-solid fa-heart text-color me-2"></i>Participate in events, worship nights, and community projects</li>
            <li class="mb-0"><i class="fa-solid fa-heart text-color me-2"></i>Play in a safe environment free from toxicity</li>
          </ul>
        </div>
      </div>
      <div class="col-lg-7">
        <div class="section-title">
          <h3 class="mt-2">Crafting For Christ is more than a server — it’s a ministry.</h3>
          <p class="lead">You’re helping keep that ministry alive.</p>
          <p class="mb-0">Thank you for praying for our team, supporting the network, and being part of our community. Your generosity helps us continue doing what God has called us to do.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="row justify-content-center text-center">
      <div class="col-lg-8">
        <h2 class="mb-4">🙏 Thank You</h2>
        <p class="lead mb-4">Thank you for praying for our team, supporting the network, and being part of our community. Your generosity helps us continue doing what God has called us to do.</p>
        <blockquote class="blockquote">
          <p class="mb-3">“And whatever you do, whether in word or deed, do it all in the name of the Lord Jesus…”</p>
          <footer class="blockquote-footer">Colossians 3:17</footer>
        </blockquote>
        <div class="btn-container mt-4 d-flex flex-wrap justify-content-center gap-3">
          <a href="/webstore" class="btn btn-main-2 btn-round-full">Give Through the Webstore</a>
          <a href="/ranks" class="btn btn-outline-primary btn-round-full">Browse Ranks & Perks</a>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("modules/footer.ejs") %>
