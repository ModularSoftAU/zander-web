<%- include("modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Vote daily for our network and climb the leaderboard to earn exciting perks, with the top voter at the end of each month receiving exclusive rewards!"
}) %>

<%- include("modules/navigationBar.ejs") %>

<%- include("partials/miniHeader.ejs", {
  headerTitle: "Vote",
  backgroundImage: globalImage
}) %>

<section class="section">
    <div class="container">
        <div class="row">
            <div class="col-md-8">
                <div class="p-4">
                    <p>
                        Voting for our server helps us grow by increasing our visibility on server listing websites. 
                        The more votes we receive, the higher we rank, attracting new players to our community. 
                        As a thank-you, we offer exciting perks and rewards to our top voters each month!
                    </p>
                    
                    <h4>How to Vote:</h4>
                    <ul>
                        <li>Click on the vote buttons below.</li>
                        <li>Follow the instructions on each site.</li>
                        <li>Vote daily to maximize your rewards!</li>
                    </ul>

                    <p class="fw-bold text-center">Every vote makes a difference—thank you for supporting our server! 🚀</p>

                    <div class="alert alert-info" role="alert">
                        If you're a Bedrock player, make sure you add . before your username or it won't count!
                    </div>
                </div>
                <hr>

                <% if (voteSiteApiData.success == false) { %>
                    <%- include("partials/alert.ejs", {
                        alertType: "danger",
                        content: voteSiteApiData.message
                    }) %>
                <% } else { %>
                    <div class="row">
                        <% voteSiteApiData.data.forEach(function(site) { %>
                            <div class="col-md-4 mb-3">
                                <div class="p-3 text-center">
                                    <h3 style="margin-bottom: 15px;"><%= site.voteSiteDisplayName %></h3>
                                    <a href="<%= site.link %>" target="_blank" class="btn btn-primary w-100">
                                        Vote
                                    </a>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            </div>
            <div class="col-md-4">
                <h3>Voting Leaderboard</h3>
                <p>Climb the Voting Leaderboard by voting daily and compete for the top spot! 🎉 The top voter at the end of the month wins an exclusive prize that lasts the entire month—so keep voting and claim your reward! 🚀</p>
                <hr>

                <% if (!voteApiData.data || voteApiData.data.length === 0) { %>
                    <div class="alert alert-warning" role="alert">
                        There are no votes yet, but you can be the first!
                    </div>
                <% } else { %>
                    <% const topVotes = voteApiData.data.slice(0, 10); %>
                    <% topVotes.forEach(function(voteUser) { %>
                        <p><%= voteUser.username %> (<b><%= voteUser.total_votes %> votes</b>)</p>
                    <% }); %>
                    <small>Only displaying the top 10 voters.</small>
                <% } %>
            </div>
        </div>
    </div>
</section>


<%- include("modules/footer.ejs") %>