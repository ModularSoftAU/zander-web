<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "View form response details"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: form.name + " — Response #" + response.responseId,
  backgroundImage: globalImage
}) %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <div>
                    <h1 class="h2">Response #<%= response.responseId %></h1>
                    <small class="text-muted"><%= form.name %></small>
                </div>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="/dashboard/forms/<%= form.formId %>/responses" class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Back to Responses
                    </a>
                </div>
            </div>

            <% if (req.cookies.alertType) { %>
                <%- include("../../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
            <% } %>

            <!-- Response metadata -->
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0">Details</h5></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <strong>Submitter</strong>
                            <p><%= response.submitterUsername || 'Anonymous' %></p>
                        </div>
                        <div class="col-md-3">
                            <strong>Submitted</strong>
                            <p><%= moment(response.submittedAt).format('YYYY-MM-DD HH:mm:ss') %>
                            <br><small class="text-muted">(<%= moment(response.submittedAt).fromNow() %>)</small></p>
                        </div>
                        <div class="col-md-3">
                            <strong>Status</strong>
                            <p>
                                <span class="badge bg-<%= response.status === 'new' ? 'primary' : response.status === 'reviewed' ? 'info' : response.status === 'converted' ? 'success' : 'secondary' %>">
                                    <%= response.status %>
                                </span>
                            </p>
                        </div>
                        <div class="col-md-3">
                            <strong>Discord</strong>
                            <p>
                                <% if (response.discordWebhookFailed) { %>
                                    <span class="badge bg-warning text-dark">Webhook failed</span>
                                <% } %>
                                <% if (response.discordForumPostFailed) { %>
                                    <span class="badge bg-warning text-dark">Forum post failed</span>
                                <% } %>
                                <% if (response.discordForumThreadId) { %>
                                    <span class="badge bg-success">Thread: <%= response.discordForumThreadId %></span>
                                <% } %>
                                <% if (!response.discordWebhookFailed && !response.discordForumPostFailed && !response.discordForumThreadId) { %>
                                    <span class="text-muted">N/A</span>
                                <% } %>
                            </p>
                        </div>
                    </div>

                    <% if (response.status === 'converted' && response.ticketId) { %>
                        <div class="alert alert-info mb-0 mt-2">
                            <i class="fas fa-ticket-alt me-1"></i>
                            Converted to <a href="/support/ticket/<%= response.ticketId %>">Ticket #<%= response.ticketId %></a>
                            <% if (response.convertedAt) { %>
                                on <%= moment(response.convertedAt).format('YYYY-MM-DD HH:mm:ss') %>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Answers -->
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0">Answers</h5></div>
                <div class="card-body">
                    <% formattedAnswers.forEach(function(answer) { %>
                        <div class="mb-3 pb-3 border-bottom">
                            <label class="form-label fw-bold text-muted"><%= answer.label %></label>
                            <p class="mb-0" style="white-space: pre-wrap;"><%= answer.value %></p>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Actions -->
            <div class="d-flex flex-wrap gap-2">
                <% if (response.status === 'new') { %>
                    <form action="<%= process.env.siteAddress %>/redirect/forms/response/status" method="post" style="display:inline;">
                        <input type="hidden" name="responseId" value="<%= response.responseId %>">
                        <input type="hidden" name="formId" value="<%= form.formId %>">
                        <input type="hidden" name="status" value="reviewed">
                        <button class="btn btn-info" type="submit"><i class="fas fa-check me-1"></i> Mark Reviewed</button>
                    </form>
                <% } %>

                <% if (response.status !== 'converted') { %>
                    <form action="/dashboard/forms/<%= form.formId %>/responses/<%= response.responseId %>/convert-to-ticket" method="post" style="display:inline;">
                        <button class="btn btn-success" type="submit" onclick="return confirm('Convert this response to a support ticket?')">
                            <i class="fas fa-ticket-alt me-1"></i> Convert to Ticket
                        </button>
                    </form>
                <% } %>

                <% if (response.status !== 'archived') { %>
                    <form action="<%= process.env.siteAddress %>/redirect/forms/response/status" method="post" style="display:inline;">
                        <input type="hidden" name="responseId" value="<%= response.responseId %>">
                        <input type="hidden" name="formId" value="<%= form.formId %>">
                        <input type="hidden" name="status" value="archived">
                        <button class="btn btn-outline-secondary" type="submit"><i class="fas fa-archive me-1"></i> Archive</button>
                    </form>
                <% } %>
            </div>
        </main>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>
