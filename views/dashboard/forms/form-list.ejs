<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Manage all forms"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Forms",
  backgroundImage: globalImage
}) %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Forms</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="/dashboard/forms/create" class="btn btn-sm btn-info">Create Form</a>
                </div>
            </div>

            <% if (req.cookies.alertType) { %>
                <%- include("../../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
            <% } %>

            <% if (!forms || forms.length === 0) { %>
                <div class="text-center py-5">
                    <i class="fas fa-file-alt text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3">No forms have been created yet.</p>
                    <a href="/dashboard/forms/create" class="btn btn-primary">Create Your First Form</a>
                </div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table align-middle forms-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Slug</th>
                                <th>Status</th>
                                <th>Responses</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% forms.forEach(function(form) { %>
                                <tr>
                                    <td data-label="Name"><%= form.name %></td>
                                    <td data-label="Slug"><code>/<%= form.slug %></code></td>
                                    <td data-label="Status">
                                        <% if (form.status === 'published') { %>
                                            <span class="badge bg-success">Published</span>
                                        <% } else if (form.status === 'draft') { %>
                                            <span class="badge bg-warning text-dark">Draft</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Archived</span>
                                        <% } %>
                                    </td>
                                    <td data-label="Responses">
                                        <span class="badge bg-primary"><%= form.responseCount ? form.responseCount.total : 0 %></span>
                                        <% if (form.responseCount && form.responseCount.newCount > 0) { %>
                                            <span class="badge bg-info"><%= form.responseCount.newCount %> new</span>
                                        <% } %>
                                    </td>
                                    <td data-label="Action">
                                        <div class="d-flex flex-wrap gap-2">
                                            <a href="/dashboard/forms/edit?formId=<%= form.formId %>" class="btn btn-sm btn-warning">Edit</a>
                                            <a href="/dashboard/forms/<%= form.formId %>/responses" class="btn btn-sm btn-info">Responses</a>
                                            <% if (form.status === 'published') { %>
                                                <a href="/forms/<%= form.slug %>" class="btn btn-sm btn-outline-primary" target="_blank">View</a>
                                            <% } %>
                                            <% if (form.responseCount && form.responseCount.total == 0) { %>
                                                <form action="<%= process.env.siteAddress %>/redirect/forms/delete" method="post" style="display:inline;">
                                                    <input type="hidden" name="formId" value="<%= form.formId %>">
                                                    <button class="btn btn-sm btn-danger" type="submit" onclick="return confirm('Are you sure you want to delete this form?')">Delete</button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </main>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>

<style>
    @media (max-width: 768px) {
        .forms-table thead {
            display: none;
        }

        .forms-table tr {
            display: block;
            border: 1px solid #e6e6e6;
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 12px;
        }

        .forms-table td {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
            border: none;
            padding: 6px 0;
            font-size: 0.9rem;
            word-break: break-word;
        }

        .forms-table td::before {
            content: attr(data-label);
            font-weight: 600;
            color: #5f6b7a;
            min-width: 110px;
        }
    }
</style>
