<%- include("../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Manage web punishments."
}) %>

<%- include("../modules/navigationBar.ejs") %>

<%- include("../partials/miniHeader.ejs", {
  headerTitle: "Web Punishments",
  backgroundImage: globalImage
}) %>

<%- include("../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Web Punishments</h1>
            </div>

            <% if (req.cookies.alertType) { %>
                <%- include("../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
            <% } %>

            <!-- New Punishment Form -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">Issue Punishment</h5>
                </div>
                <div class="card-body">
                    <form method="post" action="/dashboard/web-punishments/create">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label for="username" class="form-label">Username</label>
                                <input type="text" class="form-control" id="username" name="username" placeholder="Player username" required>
                            </div>
                            <div class="col-md-4">
                                <label for="type" class="form-label">Type</label>
                                <select class="form-select" id="type" name="type" required>
                                    <option value="">Select type...</option>
                                    <option value="WARN">Warning</option>
                                    <option value="TEMP_BAN">Temporary Ban</option>
                                    <option value="PERM_BAN">Permanent Ban</option>
                                </select>
                            </div>
                            <div class="col-md-4" id="durationGroup" style="display:none;">
                                <label for="duration" class="form-label">Duration</label>
                                <input type="text" class="form-control" id="duration" name="duration" placeholder="e.g. 7d, 1h, 2w">
                            </div>
                        </div>
                        <div class="row g-3 mt-1">
                            <div class="col-12">
                                <label for="reason" class="form-label">Reason</label>
                                <textarea class="form-control" id="reason" name="reason" rows="2" required></textarea>
                            </div>
                        </div>
                        <div class="mt-3">
                            <button type="submit" class="btn btn-danger">Issue Punishment</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Punishments Table -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Punishment History</h5>
                    <span class="badge bg-secondary"><%= total %> total</span>
                </div>
                <div class="card-body p-0">
                    <% if (punishments.length === 0) { %>
                        <div class="p-4 text-center text-muted">No web punishments have been issued yet.</div>
                    <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>User</th>
                                    <th>Type</th>
                                    <th>Reason</th>
                                    <th>Issued By</th>
                                    <th>Date</th>
                                    <th>Expires</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% punishments.forEach((p) => { %>
                                <tr>
                                    <td><%= p.id %></td>
                                    <td><%= p.target_username || p.target_player_id || '—' %></td>
                                    <td>
                                        <% if (p.type === 'WARN') { %>
                                            <span class="badge bg-warning text-dark">Warning</span>
                                        <% } else if (p.type === 'TEMP_BAN') { %>
                                            <span class="badge bg-danger">Temp Ban</span>
                                        <% } else if (p.type === 'PERM_BAN') { %>
                                            <span class="badge bg-danger">Perm Ban</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary"><%= p.type %></span>
                                        <% } %>
                                    </td>
                                    <td><%= p.reason %></td>
                                    <td><%= p.actor_username || p.actor_name_snapshot || '—' %></td>
                                    <td><%= moment(p.created_at).format('MMM D, YYYY h:mm A') %></td>
                                    <td>
                                        <% if (p.expires_at) { %>
                                            <%= moment(p.expires_at).format('MMM D, YYYY h:mm A') %>
                                        <% } else if (p.type === 'PERM_BAN') { %>
                                            <span class="text-danger">Never</span>
                                        <% } else { %>
                                            —
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (p.status === 'ACTIVE') { %>
                                            <span class="badge bg-success">Active</span>
                                        <% } else if (p.status === 'LIFTED') { %>
                                            <span class="badge bg-secondary">Lifted</span>
                                        <% } else if (p.status === 'EXPIRED') { %>
                                            <span class="badge bg-secondary">Expired</span>
                                        <% } else { %>
                                            <span class="badge bg-info"><%= p.status %></span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (p.status === 'ACTIVE' && (p.type === 'TEMP_BAN' || p.type === 'PERM_BAN')) { %>
                                            <form method="post" action="/dashboard/web-punishments/<%= p.id %>/lift" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-success" onclick="return confirm('Lift this punishment?')">Lift</button>
                                            </form>
                                        <% } else { %>
                                            —
                                        <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
                </div>

                <% if (totalPages > 1) { %>
                <div class="card-footer bg-white">
                    <nav>
                        <ul class="pagination justify-content-center mb-0">
                            <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                                <a class="page-link" href="/dashboard/web-punishments?page=<%= page - 1 %>">Previous</a>
                            </li>
                            <% for (let i = 1; i <= totalPages; i++) { %>
                                <li class="page-item <%= i === page ? 'active' : '' %>">
                                    <a class="page-link" href="/dashboard/web-punishments?page=<%= i %>"><%= i %></a>
                                </li>
                            <% } %>
                            <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
                                <a class="page-link" href="/dashboard/web-punishments?page=<%= page + 1 %>">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
                <% } %>
            </div>
        </main>
    </div>
</div>

<%- include("../modules/footer.ejs") %>

<script>
  document.getElementById('type').addEventListener('change', function () {
    document.getElementById('durationGroup').style.display =
      this.value === 'TEMP_BAN' ? '' : 'none';
  });
</script>
