<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "List of all Network Announcements"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<div class="container-fluid">
    <div class="row">
        <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>

        <main role="main" class="col-md-9 ml-sm-auto col-lg-10 px-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Announcements</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="/dashboard/announcements/create" class="btn btn-sm btn-info">Create Announcement</a>
                    <%- include("../../partials/documentationLink.ejs", {
                        doclink: "https://modularsoft.org/docs/products/zander/features/announcement/"
                    }) %>
                </div>
            </div>

            <% if (req.cookies.alertType) { %>
                <%- include("../../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
            <% } %>

            <table class="table">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Format</th>
                        <th>Schedule</th>
                        <th>Enabled</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (apiData.success == false) { %>
                        <%- include("../../partials/alert.ejs", {
                          alertType: "danger",
                          content: apiData.message
                        }) %>
                    <% } else { %>
                        <% apiData.data.forEach(function (announcement) { %>
                            <tr>
                                <td><span class="badge text-bg-primary"><%= announcement.announcementType %></span></td>
                                <td><%= announcement.colourMessageFormat %></td>
                                <td>
                                    <% if (announcement.startDate || announcement.endDate) { %>
                                        <small>
                                            <span class="js-datetime" data-iso="<%= announcement.startDate || '' %>" data-fallback="Now"></span>
                                            →
                                            <span class="js-datetime" data-iso="<%= announcement.endDate || '' %>" data-fallback="No end"></span>
                                        </small>
                                    <% } else { %>
                                        <small>Always active</small>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (announcement.enabled === 1) { %>
                                        <i class="fas fa-check-circle" style="color:green"></i>
                                    <% } else { %>
                                        <i class="fas fa-times-circle" style="color: red;"></i>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a href="/dashboard/announcements/edit?announcementId=<%= announcement.announcementId %>"><button class="btn btn-sm btn-warning" type="button">Edit</button></a>

                                        <form action="<%= process.env.siteAddress %>/redirect/announcement/delete" method="post">
                                            <input type="hidden" name="announcementId" value="<%= announcement.announcementId %>">
                                            <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </main>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>

<script>
    document.querySelectorAll(".js-datetime").forEach((element) => {
        const isoValue = element.dataset.iso;
        if (!isoValue) {
            element.textContent = element.dataset.fallback || "";
            return;
        }

        const date = new Date(isoValue);
        if (Number.isNaN(date.getTime())) {
            element.textContent = element.dataset.fallback || "";
            return;
        }

        element.textContent = date.toLocaleString();
    });
</script>
