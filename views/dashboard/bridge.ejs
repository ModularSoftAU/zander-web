<%- include("../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Bridge processor configuration and tooling."
}) %>

<%- include("../modules/navigationBar.ejs") %>

<%- include("../partials/miniHeader.ejs", {
  headerTitle: "Bridge",
  backgroundImage: globalImage
}) %>

<%
  const pendingList = pendingTasks && pendingTasks.success ? pendingTasks.data : [];
  const processingList = processingTasks && processingTasks.success ? processingTasks.data : [];
  const routinesList = routines && routines.success ? routines.data : [];
%>

<div class="row dashboardview">
  <div class="col-sm-2">
    <%- include("../modules/dashboard/dashboard-sidebar.ejs") %>
  </div>
  <div class="col" style="padding: 20px;">
    <%- include("../partials/documentationLink.ejs", {
        doclink: "https://modularsoft.org/docs/products/zander/features/bridge/"
    }) %>

    <div class="row g-4 mt-1">
      <div class="col-xl-4 col-lg-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h5 class="card-title">Queue a single command</h5>
            <p class="text-muted small mb-4">
              Send a command to a specific server slug. Optionally include metadata or a custom priority to change queue order.
            </p>
            <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/command/add" class="row g-3">
              <div class="col-12">
                <label for="command" class="form-label">Command</label>
                <input type="text" class="form-control" id="command" name="command" placeholder="/ban Player Reason" required>
              </div>
              <div class="col-6">
                <label for="slug" class="form-label">Target slug</label>
                <input type="text" class="form-control" id="slug" name="slug" placeholder="proxy" required>
              </div>
              <div class="col-6">
                <label for="priority" class="form-label">Priority</label>
                <input type="number" class="form-control" id="priority" name="priority" value="0" step="1">
              </div>
              <div class="col-12">
                <label for="metadataJSON" class="form-label">Metadata (JSON optional)</label>
                <textarea class="form-control" id="metadataJSON" name="metadataJSON" rows="2" placeholder='{"requestedBy":"Dashboard"}'></textarea>
              </div>
              <div class="col-12 text-end">
                <button type="submit" class="btn btn-primary">Queue command</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-xl-4 col-lg-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h5 class="card-title">Trigger a routine</h5>
            <p class="text-muted small mb-4">
              Run all steps associated with an existing routine. Each step will be queued as an executor task.
            </p>
            <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/routine/run" class="row g-3">
              <div class="col-8">
                <label for="routineSlug" class="form-label">Routine slug</label>
                <input type="text" class="form-control" id="routineSlug" name="routineSlug" placeholder="vote-reward" required>
              </div>
              <div class="col-4">
                <label for="routinePriority" class="form-label">Priority</label>
                <input type="number" class="form-control" id="routinePriority" name="priority" value="0" step="1">
              </div>
              <div class="col-12">
                <label for="routineMetadata" class="form-label">Metadata (JSON optional)</label>
                <textarea class="form-control" id="routineMetadata" name="metadataJSON" rows="2" placeholder='{"player":"PlayerName"}'></textarea>
              </div>
              <div class="col-12 text-end">
                <button type="submit" class="btn btn-secondary">Run routine</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-xl-4">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h5 class="card-title">Queue multiple commands</h5>
            <p class="text-muted small mb-4">
              Paste an array of tasks to queue several commands at once. Each task can target a different server and define its own priority.
            </p>
            <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/command/add" class="row g-3">
              <div class="col-12">
                <label for="bulkSlug" class="form-label">Default target slug (optional)</label>
                <input type="text" class="form-control" id="bulkSlug" name="slug" placeholder="proxy">
                <div class="form-text">Used when a task omits its own slug.</div>
              </div>
              <div class="col-12">
                <label for="tasksJSON" class="form-label">Tasks JSON</label>
                <textarea class="form-control" id="tasksJSON" name="tasksJSON" rows="6" placeholder='[
  {"slug":"proxy","command":"/broadcast Restarting soon","priority":5},
  {"slug":"survival","command":"/say Preparing for restart"}
]'></textarea>
                <div class="form-text">Each task supports <code>slug</code>, <code>command</code>, optional <code>priority</code>, and <code>metadata</code>.</div>
              </div>
              <div class="col-6">
                <label for="bulkPriority" class="form-label">Default priority</label>
                <input type="number" class="form-control" id="bulkPriority" name="priority" value="0" step="1">
              </div>
              <div class="col-6">
                <label for="bulkMetadata" class="form-label">Metadata (JSON optional)</label>
                <textarea class="form-control" id="bulkMetadata" name="metadataJSON" rows="2" placeholder='{"requestedBy":"Dashboard"}'></textarea>
              </div>
              <div class="col-12 text-end">
                <button type="submit" class="btn btn-outline-primary">Queue tasks</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4 mt-1">
      <div class="col-xl-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h5 class="card-title">Manage queue</h5>
            <p class="text-muted small mb-4">
              Quickly clear out tasks that are no longer needed by filtering on status, slug, or routine association.
            </p>
            <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/queue/clear" class="row g-3">
              <div class="col-md-4">
                <label for="clearStatus" class="form-label">Status filter</label>
                <select class="form-select" id="clearStatus" name="status">
                  <option value="">Any status</option>
                  <option value="pending">Pending</option>
                  <option value="processing">Processing</option>
                  <option value="completed">Completed</option>
                  <option value="failed">Failed</option>
                </select>
              </div>
              <div class="col-md-4">
                <label for="clearSlug" class="form-label">Target slug</label>
                <input type="text" class="form-control" id="clearSlug" name="slug" placeholder="proxy">
              </div>
              <div class="col-md-4">
                <label for="clearRoutine" class="form-label">Routine slug</label>
                <input type="text" class="form-control" id="clearRoutine" name="routineSlug" placeholder="vote-reward">
              </div>
              <div class="col-12 text-end">
                <button type="submit" class="btn btn-outline-danger">Clear matching tasks</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-xl-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h5 class="card-title">Report task outcome</h5>
            <p class="text-muted small mb-4">
              Manually update a task status if you execute a command outside of the bridge or need to resolve a stuck job.
            </p>
            <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/task/report" class="row g-3">
              <div class="col-md-4">
                <label for="reportTaskId" class="form-label">Task ID</label>
                <input type="number" class="form-control" id="reportTaskId" name="taskId" placeholder="42" required>
              </div>
              <div class="col-md-4">
                <label for="reportStatus" class="form-label">Status</label>
                <select class="form-select" id="reportStatus" name="status" required>
                  <option value="processing">Processing</option>
                  <option value="completed">Completed</option>
                  <option value="failed">Failed</option>
                </select>
              </div>
              <div class="col-md-4">
                <label for="reportExecutedBy" class="form-label">Executed by</label>
                <input type="text" class="form-control" id="reportExecutedBy" name="executedBy" placeholder="AdminUser">
              </div>
              <div class="col-12">
                <label for="reportResult" class="form-label">Result / Notes</label>
                <textarea class="form-control" id="reportResult" name="result" rows="3" placeholder="Command executed manually."></textarea>
              </div>
              <div class="col-12">
                <label for="reportMetadata" class="form-label">Metadata (JSON optional)</label>
                <textarea class="form-control" id="reportMetadata" name="metadataJSON" rows="2" placeholder='{"reason":"manual override"}'></textarea>
              </div>
              <div class="col-12 text-end">
                <button type="submit" class="btn btn-success">Submit report</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm border-0 mt-4">
      <div class="card-body">
        <h5 class="card-title">Define or update a routine</h5>
        <p class="text-muted small">
          Provide a JSON array of steps. Each step requires a <code>slug</code>, <code>command</code>, and optional <code>order</code> or <code>metadata</code> field. Existing steps for the routine will be replaced.
        </p>
        <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/routine/save" class="row g-3">
          <div class="col-md-4">
            <label for="routineSlugSave" class="form-label">Routine slug</label>
            <input type="text" class="form-control" id="routineSlugSave" name="routineSlug" placeholder="vote-reward" required>
          </div>
          <div class="col-md-4">
            <label for="displayName" class="form-label">Display name</label>
            <input type="text" class="form-control" id="displayName" name="displayName" placeholder="Vote reward flow">
          </div>
          <div class="col-md-4">
            <label for="routineDescription" class="form-label">Description</label>
            <input type="text" class="form-control" id="routineDescription" name="description" placeholder="Executed when a player votes">
          </div>
          <div class="col-12">
            <label for="stepsJSON" class="form-label">Steps JSON</label>
            <textarea class="form-control" id="stepsJSON" name="stepsJSON" rows="5" placeholder='[
  {"slug":"proxy","command":"/broadcast Thanks {player}!"},
  {"slug":"survival","command":"/eco give {player} 50"}
]'></textarea>
          </div>
          <div class="col-12 text-end">
            <button type="submit" class="btn btn-outline-primary">Save routine</button>
          </div>
        </form>
      </div>
    </div>

    <div class="mt-4">
      <% if (req.cookies.alertType) { %>
        <%- include("../partials/alert.ejs", {
          alertType: req.cookies.alertType,
          content: req.cookies.alertContent
        }) %>
      <% } %>

      <% if (pendingTasks && pendingTasks.success === false) { %>
        <%- include("../partials/alert.ejs", {
          alertType: "danger",
          content: pendingTasks.message
        }) %>
      <% } %>

      <% if (processingTasks && processingTasks.success === false) { %>
        <%- include("../partials/alert.ejs", {
          alertType: "danger",
          content: processingTasks.message
        }) %>
      <% } %>

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title mb-0">Pending tasks</h5>
            <span class="badge bg-primary rounded-pill"><%= pendingList.length %></span>
          </div>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th scope="col">ID</th>
                  <th scope="col">Slug</th>
                  <th scope="col">Command</th>
                  <th scope="col">Priority</th>
                  <th scope="col">Routine</th>
                  <th scope="col">Created</th>
                  <th scope="col"></th>
                </tr>
              </thead>
              <tbody>
                <% if (!pendingList.length) { %>
                  <tr>
                    <td colspan="7" class="text-center text-muted">No pending tasks</td>
                  </tr>
                <% } else { %>
                  <% pendingList.forEach(function(task) { %>
                    <tr>
                      <td><code>#<%= task.executorTaskId %></code></td>
                      <td><%= task.slug %></td>
                      <td><code><%= task.command %></code></td>
                      <td><%= task.priority %></td>
                      <td><%= task.routineSlug ? task.routineSlug : "-" %></td>
                      <td><%= moment(task.createdAt).fromNow() %></td>
                      <td class="text-end">
                        <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/task/reset" class="d-inline">
                          <input type="hidden" name="taskId" value="<%= task.executorTaskId %>">
                          <button type="submit" class="btn btn-sm btn-outline-secondary">Reset</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title mb-0">Processing tasks</h5>
            <span class="badge bg-warning rounded-pill"><%= processingList.length %></span>
          </div>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th scope="col">ID</th>
                  <th scope="col">Slug</th>
                  <th scope="col">Command</th>
                  <th scope="col">Status</th>
                  <th scope="col">Updated</th>
                  <th scope="col">Executed by</th>
                  <th scope="col"></th>
                </tr>
              </thead>
              <tbody>
                <% if (!processingList.length) { %>
                  <tr>
                    <td colspan="7" class="text-center text-muted">No processing tasks</td>
                  </tr>
                <% } else { %>
                  <% processingList.forEach(function(task) { %>
                    <tr>
                      <td><code>#<%= task.executorTaskId %></code></td>
                      <td><%= task.slug %></td>
                      <td><code><%= task.command %></code></td>
                      <td><span class="badge bg-warning text-dark"><%= task.status %></span></td>
                      <td><%= moment(task.updatedAt).fromNow() %></td>
                      <td><%= task.executedBy ? task.executedBy : "-" %></td>
                      <td class="text-end">
                        <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/task/report" class="d-inline">
                          <input type="hidden" name="taskId" value="<%= task.executorTaskId %>">
                          <input type="hidden" name="status" value="completed">
                          <button type="submit" class="btn btn-sm btn-outline-success">Mark complete</button>
                        </form>
                        <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/task/report" class="d-inline ms-1">
                          <input type="hidden" name="taskId" value="<%= task.executorTaskId %>">
                          <input type="hidden" name="status" value="failed">
                          <button type="submit" class="btn btn-sm btn-outline-danger">Mark failed</button>
                        </form>
                        <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/task/reset" class="d-inline ms-1">
                          <input type="hidden" name="taskId" value="<%= task.executorTaskId %>">
                          <button type="submit" class="btn btn-sm btn-outline-secondary">Reset</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title mb-0">Configured routines</h5>
            <span class="badge bg-info text-dark rounded-pill"><%= routinesList.length %></span>
          </div>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th scope="col">Routine</th>
                  <th scope="col">Display name</th>
                  <th scope="col">Description</th>
                  <th scope="col">Steps</th>
                  <th scope="col">Updated</th>
                </tr>
              </thead>
              <tbody>
                <% if (!routinesList.length) { %>
                  <tr>
                    <td colspan="5" class="text-center text-muted">No routines configured yet</td>
                  </tr>
                <% } else { %>
                  <% routinesList.forEach(function(routine) { %>
                    <tr>
                      <td><code><%= routine.routineSlug %></code></td>
                      <td><%= routine.displayName || '-' %></td>
                      <td><%= routine.description || '-' %></td>
                      <td>
                        <ul class="list-unstyled mb-0 small">
                          <% routine.steps.forEach(function(step) { %>
                            <li>
                              <span class="badge bg-light text-dark">#<%= step.order %></span>
                              <strong><%= step.slug %></strong> &mdash; <code><%= step.command %></code>
                            </li>
                          <% }) %>
                        </ul>
                      </td>
                      <td><%= moment(routine.updatedAt || routine.createdAt).fromNow() %></td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include("../modules/footer.ejs") %>
