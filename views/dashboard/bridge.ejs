<%- include("../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Bridge processor configuration and tooling."
}) %>

<%- include("../modules/navigationBar.ejs") %>

<div class="container-fluid">
    <div class="row">
        <%- include("../modules/dashboard/dashboard-sidebar.ejs") %>

        <main role="main" class="col-md-9 ml-sm-auto col-lg-10 px-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Bridge</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <%- include("../partials/documentationLink.ejs", {
                        doclink: "https://modularsoft.org/docs/products/zander/features/bridge/"
                    }) %>
                </div>
            </div>

            <div class="card bridge-card shadow-sm border-0 mb-4">
                <div class="card-body">
                  <h5 class="card-title">Bridge overview</h5>
                  <p class="text-muted small mb-3">
                    The bridge links the API with your proxy and Paper servers so commands can be queued, executed, and tracked from one place.
                  </p>
                  <ul class="text-muted small ps-3 mb-0">
                    <li>Queue ad-hoc commands or batches without building JSON by hand.</li>
                    <li>Trigger reusable routines that target multiple servers with one submission.</li>
                    <li>Use the management tools to clear stuck work and keep processors healthy.</li>
                  </ul>
                </div>
              </div>

              <% if (req.cookies.alertType) { %>
                <%- include("../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
              <% } %>

              <% if (pendingTasks && pendingTasks.success === false) { %>
                <%- include("../partials/alert.ejs", {
                  alertType: "danger",
                  content: pendingTasks.message
                }) %>
              <% } %>

              <% if (processingTasks && processingTasks.success === false) { %>
                <%- include("../partials/alert.ejs", {
                  alertType: "danger",
                  content: processingTasks.message
                }) %>
              <% } %>

              <div class="card bridge-card shadow-sm border-0">
                <div class="card-body">
                  <ul class="nav nav-pills bridge-tablist mb-4" id="bridgeTabs" role="tablist">
                    <li class="nav-item flex-grow-1" role="presentation">
                      <button type="button" class="nav-link bridge-tab-button active" data-bridge-tab="queue" role="tab" aria-selected="true">
                        Queue commands
                      </button>
                    </li>
                    <li class="nav-item flex-grow-1" role="presentation">
                      <button type="button" class="nav-link bridge-tab-button" data-bridge-tab="routines" role="tab" aria-selected="false">
                        Routines
                      </button>
                    </li>
                    <li class="nav-item flex-grow-1" role="presentation">
                      <button type="button" class="nav-link bridge-tab-button" data-bridge-tab="manage" role="tab" aria-selected="false">
                        Queue management
                      </button>
                    </li>
                    <li class="nav-item flex-grow-1" role="presentation">
                      <button type="button" class="nav-link bridge-tab-button" data-bridge-tab="status" role="tab" aria-selected="false">
                        <span class="d-flex align-items-center justify-content-between">
                          <span>Status</span>
                          <span class="badge bg-light text-dark ms-3"><%= pendingList.length + processingList.length %></span>
                        </span>
                      </button>
                    </li>
                  </ul>

                  <div class="tab-content" id="bridgeTabContent">
                    <div class="tab-pane active" data-bridge-panel="queue" role="tabpanel">
                      <div class="row g-4 row-cols-1 row-cols-xl-2">
                        <div class="col">
                          <div class="card bridge-card shadow-sm border-0 h-100">
                            <div class="card-body d-flex flex-column">
                              <h5 class="card-title">Queue a single command</h5>
                              <p class="text-muted small mb-4">
                                Send one command to a specific server slug. Metadata pairs are optional and help processors know who queued the work or why.
                              </p>
                              <div class="mt-auto d-flex justify-content-end">
                                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#singleCommandModal">
                                  Open form
                                </button>
                              </div>
                            </div>
                          </div>
                        </div>

                        <div class="col">
                          <div class="card bridge-card shadow-sm border-0 h-100">
                            <div class="card-body d-flex flex-column">
                              <h5 class="card-title">Queue multiple commands</h5>
                              <p class="text-muted small mb-4">
                                Build a batch of commands inline. Each row becomes an executor task and can target a different server or priority.
                              </p>
                              <div class="mt-auto d-flex justify-content-end">
                                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#bulkCommandModal">
                                  Build batch
                                </button>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="tab-pane" data-bridge-panel="routines" role="tabpanel">
                      <div class="row g-4">
                        <div class="col-12 col-xl-5">
                          <div class="card bridge-card shadow-sm border-0 h-100">
                            <div class="card-body d-flex flex-column">
                              <h5 class="card-title">Trigger a routine</h5>
                              <p class="text-muted small mb-4">
                                Execute every step saved for a routine. Metadata pairs can supply values for placeholders such as the player name.
                              </p>
                              <div class="mt-auto d-flex justify-content-end">
                                <button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#runRoutineModal">
                                  Run routine
                                </button>
                              </div>
                            </div>
                          </div>
                        </div>
                        <div class="col-12 col-xl-7">
                          <div class="card bridge-card shadow-sm border-0 h-100">
                            <div class="card-body d-flex flex-column">
                              <h5 class="card-title">Define or update a routine</h5>
                              <p class="text-muted small mb-4">
                                Build the steps visually (or load an existing routine to update it) and we will create the JSON payload when you save. Steps execute in ascending order values. Use placeholders like <code>{{player}}</code> to inject metadata into commands automatically.
                              </p>
                              <div class="mt-auto d-flex justify-content-end">
                                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#routineBuilderModal">
                                  Open builder
                                </button>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="tab-pane" data-bridge-panel="manage" role="tabpanel">
                      <div class="row g-4 row-cols-1 row-cols-xl-2">
                        <div class="col">
                          <div class="card bridge-card shadow-sm border-0 h-100">
                            <div class="card-body d-flex flex-column">
                              <h5 class="card-title">Clear tasks from the queue</h5>
                              <p class="text-muted small mb-4">
                                Remove work that is no longer needed. Filters are optional and can be combined to target specific jobs.
                              </p>
                              <div class="mt-auto d-flex justify-content-end">
                                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#queueClearModal">
                                  Clear tasks
                                </button>
                              </div>
                            </div>
                          </div>
                        </div>
                        <div class="col">
                          <div class="card bridge-card shadow-sm border-0 h-100">
                            <div class="card-body d-flex flex-column">
                              <h5 class="card-title">Report a task outcome</h5>
                              <p class="text-muted small mb-4">
                                Update a stuck or manually executed task. Completed and failed reports both finalise processing.
                              </p>
                              <div class="mt-auto d-flex justify-content-end">
                                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#reportTaskModal">
                                  Report task
                                </button>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="tab-pane" data-bridge-panel="status" role="tabpanel">
                      <div class="row g-4">
                        <div class="col-12">
                          <div class="card bridge-card shadow-sm border-0">
                            <div class="card-body">
                              <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2 mb-3">
                                <h5 class="card-title mb-0">Pending tasks</h5>
                                <span class="badge bg-primary rounded-pill"><%= pendingList.length %></span>
                              </div>
                              <div class="table-responsive">
                                <table class="table align-middle">
                                  <thead>
                                    <tr>
                                      <th scope="col">ID</th>
                                      <th scope="col">Slug</th>
                                      <th scope="col">Command</th>
                                      <th scope="col">Priority</th>
                                      <th scope="col">Routine</th>
                                      <th scope="col">Created</th>
                                      <th scope="col"></th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    <% if (!pendingList.length) { %>
                                      <tr>
                                        <td colspan="7" class="text-center text-muted">No pending tasks</td>
                                      </tr>
                                    <% } else { %>
                                      <% pendingList.forEach(function(task) { %>
                                        <tr>
                                          <td><code>#<%= task.executorTaskId %></code></td>
                                          <td><%= task.slug %></td>
                                          <td><code><%= task.command %></code></td>
                                          <td><%= task.priority %></td>
                                          <td><%= task.routineSlug ? task.routineSlug : "-" %></td>
                                          <td><%= moment(task.createdAt).fromNow() %></td>
                                          <td class="text-end">
                                            <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/task/reset" class="d-inline">
                                              <input type="hidden" name="taskId" value="<%= task.executorTaskId %>">
                                              <button type="submit" class="btn btn-sm btn-outline-secondary">Reset</button>
                                            </form>
                                          </td>
                                        </tr>
                                      <% }) %>
                                    <% } %>
                                  </tbody>
                                </table>
                              </div>
                            </div>
                          </div>
                        </div>

                        <div class="col-12">
                          <div class="card bridge-card shadow-sm border-0">
                            <div class="card-body">
                              <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2 mb-3">
                                <h5 class="card-title mb-0">Processing tasks</h5>
                                <span class="badge bg-warning text-dark rounded-pill"><%= processingList.length %></span>
                              </div>
                              <div class="table-responsive">
                                <table class="table align-middle">
                                  <thead>
                                    <tr>
                                      <th scope="col">ID</th>
                                      <th scope="col">Slug</th>
                                      <th scope="col">Command</th>
                                      <th scope="col">Status</th>
                                      <th scope="col">Updated</th>
                                      <th scope="col">Executed by</th>
                                      <th scope="col"></th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    <% if (!processingList.length) { %>
                                      <tr>
                                        <td colspan="7" class="text-center text-muted">No processing tasks</td>
                                      </tr>
                                    <% } else { %>
                                      <% processingList.forEach(function(task) { %>
                                        <tr>
                                          <td><code>#<%= task.executorTaskId %></code></td>
                                          <td><%= task.slug %></td>
                                          <td><code><%= task.command %></code></td>
                                          <td><span class="badge bg-warning text-dark"><%= task.status %></span></td>
                                          <td><%= moment(task.updatedAt).fromNow() %></td>
                                          <td><%= task.executedBy ? task.executedBy : "-" %></td>
                                          <td class="text-end">
                                            <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/task/report" class="d-inline">
                                              <input type="hidden" name="taskId" value="<%= task.executorTaskId %>">
                                              <input type="hidden" name="status" value="completed">
                                              <button type="submit" class="btn btn-sm btn-outline-success">Mark complete</button>
                                            </form>
                                            <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/task/report" class="d-inline ms-1">
                                              <input type="hidden" name="taskId" value="<%= task.executorTaskId %>">
                                              <input type="hidden" name="status" value="failed">
                                              <button type="submit" class="btn btn-sm btn-outline-danger">Mark failed</button>
                                            </form>
                                            <form method="post" action="<%= process.env.siteAddress %>/redirect/bridge/task/reset" class="d-inline ms-1">
                                              <input type="hidden" name="taskId" value="<%= task.executorTaskId %>">
                                              <button type="submit" class="btn btn-sm btn-outline-secondary">Reset</button>
                                            </form>
                                          </td>
                                        </tr>
                                      <% }) %>
                                    <% } %>
                                  </tbody>
                                </table>
                              </div>
                            </div>
                          </div>
                        </div>

                        <div class="col-12">
                          <div class="card shadow-sm border-0">
                            <div class="card-body">
                              <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="card-title mb-0">Configured routines</h5>
                                <span class="badge bg-info text-dark rounded-pill"><%= routinesList.length %></span>
                              </div>
                              <div class="table-responsive">
                                <table class="table align-middle">
                                  <thead>
                                    <tr>
                                      <th scope="col">Routine</th>
                                      <th scope="col">Display name</th>
                                      <th scope="col">Description</th>
                                      <th scope="col">Steps</th>
                                      <th scope="col">Updated</th>
                                      <th scope="col" class="text-end">Actions</th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    <% if (!routinesList.length) { %>
                                      <tr>
                                        <td colspan="6" class="text-center text-muted">No routines configured yet</td>
                                      </tr>
                                    <% } else { %>
                                      <% routinesList.forEach(function(routine) { %>
                                        <tr>
                                          <td><code><%= routine.routineSlug %></code></td>
                                          <td><%= routine.displayName || '-' %></td>
                                          <td><%= routine.description || '-' %></td>
                                          <td>
                                            <ul class="list-unstyled mb-0 small">
                                              <% routine.steps.forEach(function(step) { %>
                                                <li>
                                                  <span class="badge bg-light text-dark">#<%= step.order %></span>
                                                  <strong><%= step.slug %></strong> &mdash; <code><%= step.command %></code>
                                                </li>
                                              <% }) %>
                                            </ul>
                                          </td>
                                          <td><%= moment(routine.updatedAt || routine.createdAt).fromNow() %></td>
                                          <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-primary" data-routine-edit="<%= routine.routineSlug %>" data-bs-toggle="modal" data-bs-target="#routineBuilderModal">
                                              Edit
                                            </button>
                                          </td>
                                        </tr>
                                      <% }) %>
                                    <% } %>
                                  </tbody>
                                </table>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
        </main>
    </div>
</div>

<%- include("../modules/footer.ejs") %>
