<%- include('../../modules/header'); %>
<%- include('../../modules/dashboard/dashboard-sidebar'); %>

<div class="content-wrap">
    <div class="main">
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-8 p-r-0 title-margin-right">
                    <div class="page-header">
                        <div class="page-title">
                            <h1>Forums Management</h1>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 p-l-0 title-margin-left">
                    <div class="page-header">
                        <div class="page-title">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                                <li class="breadcrumb-item active">Forums</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <section id="main-content">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="card">
                            <div class="bootstrap-data-table-panel">
                                <div class="table-responsive">
                                    <div class="card-header">
                                        <h4>All Categories</h4>
                                        <a href="/dashboard/forums/new" class="btn btn-primary btn-sm float-right">Create New Category</a>
                                    </div>
                                    <table id="bootstrap-data-table-export" class="table table-striped table-bordered">
                                        <thead>
                                            <tr>
                                                <th>Position</th>
                                                <th>Title</th>
                                                <th>Description</th>
                                                <th>Required Permission</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% categories.forEach(function(category) { %>
                                                <tr>
                                                    <td><%= category.position %></td>
                                                    <td><%= category.title %></td>
                                                    <td><%= category.description %></td>
                                                    <td><code><%= category.requiredPermission || 'None' %></code></td>
                                                    <td>
                                                        <a href="/dashboard/forums/<%= category.categoryId %>/edit" class="btn btn-info btn-sm">Edit</a>
                                                        <form action="/dashboard/forums/<%= category.categoryId %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this category and all its contents? This action cannot be undone.');">
                                                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

<%- include('../../modules/footer'); %>
