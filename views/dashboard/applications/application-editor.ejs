<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Editor for Network Applications"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: type === 'create' ? 'Create Application' : 'Edit Application',
  backgroundImage: globalImage
}) %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2"><%= type === 'create' ? 'Create' : 'Edit' %> Application</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <%- include("../../partials/documentationLink.ejs", {
                        doclink: "https://modularsoft.org/docs/products/zander/features/application/"
                    }) %>
                </div>
            </div>

            <div class="basic-form">
                <% if (type === 'create') { %>
                    <form method="post" action="<%= process.env.siteAddress %>/redirect/applications/create">
                <% } %>
                <% if (type === 'edit') { %>
                    <form method="post" action="<%= process.env.siteAddress %>/redirect/applications/edit">
                        <%- include("../../partials/form/inputHidden.ejs", {
                            elementName: "applicationId",
                            elementValue: applicationApiData.applicationId
                        }) %>
                <% } %>

                  <div class="row">
                      <!-- Display Name -->
                      <div class="mb-3 col">
                          <label for="displayName">Display Name</label>

                          <% if (type === 'create') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "displayName",
                                  elementValue: null,
                                  required: true
                              }) %>
                          <% } %>
                          <% if (type === 'edit') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "displayName",
                                  elementValue: applicationApiData.displayName,
                                  required: true
                              }) %>
                          <% } %>
                      </div>

                      <!-- Application Icon -->
                      <div class="mb-3 col">
                          <label for="displayIcon">Application Icon</label>

                          <% if (type === 'create') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "displayIcon",
                                  elementValue: null,
                                  required: true
                              }) %>
                          <% } %>
                          <% if (type === 'edit') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "displayIcon",
                                  elementValue: applicationApiData.displayIcon,
                                  required: true
                              }) %>
                          <% } %>
                      </div>
                  </div>

                  <!-- Application Description -->
                  <div class="mb-3">
                      <label for="description">Application Description</label>

                      <% if (type === 'create') { %>
                          <%- include("../../partials/form/inputTextArea.ejs", {
                              elementName: "description",
                              elementValue: null,
                              required: false
                          }) %>
                      <% } %>
                      <% if (type === 'edit') { %>
                          <%- include("../../partials/form/inputTextArea.ejs", {
                              elementName: "description",
                              elementValue: applicationApiData.description,
                              required: false
                          }) %>
                      <% } %>
                  </div>

                  <!-- Application Type -->
                  <div class="mb-3">
                      <label for="applicationType">Application Type</label>
                      <%- include("../../partials/form/inputSelect.ejs", {
                          elementName: "applicationType",
                          elementValue: type === 'edit' ? (applicationApiData.applicationType || 'external') : 'external',
                          required: true,
                          optionElements: [
                              {
                                  optionName: "External URL",
                                  optionValue: "external",
                                  selected: false,
                                  disabled: false
                              },
                              {
                                  optionName: "Linked Form",
                                  optionValue: "linked_form",
                                  selected: false,
                                  disabled: false
                              }
                          ]
                      }) %>
                      <small class="form-text text-muted">External: redirects to a URL. Linked Form: opens a built-in form.</small>
                  </div>

                  <div class="row">
                      <!-- Application Requirements Markdown Link -->
                      <div class="mb-3 col">
                          <label for="requirementsMarkdown">Application Requirements Markdown Link</label>

                          <% if (type === 'create') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "requirementsMarkdown",
                                  elementValue: null,
                                  required: true
                              }) %>
                          <% } %>
                          <% if (type === 'edit') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "requirementsMarkdown",
                                  elementValue: applicationApiData.requirementsMarkdown,
                                  required: true
                              }) %>
                          <% } %>
                      </div>

                      <!-- Application URL Redirect (for external type) -->
                      <div class="mb-3 col" id="redirectUrlField">
                          <label for="redirectUrl">Application URL Redirect</label>

                          <% if (type === 'create') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "redirectUrl",
                                  elementValue: null,
                                  required: false
                              }) %>
                          <% } %>
                          <% if (type === 'edit') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "redirectUrl",
                                  elementValue: applicationApiData.redirectUrl,
                                  required: false
                              }) %>
                          <% } %>
                      </div>

                      <!-- Linked Form ID (for linked_form type) -->
                      <div class="mb-3 col" id="linkedFormField">
                          <label for="linkedFormId">Linked Form ID</label>

                          <% if (type === 'create') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "linkedFormId",
                                  elementValue: null,
                                  required: false
                              }) %>
                          <% } %>
                          <% if (type === 'edit') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "linkedFormId",
                                  elementValue: applicationApiData.linkedFormId,
                                  required: false
                              }) %>
                          <% } %>
                          <small class="form-text text-muted">Enter the Form ID from Dashboard > Forms.</small>
                      </div>
                  </div>

                  <div class="row">
                      <!-- Application Position -->
                      <div class="mb-3 col">
                          <label for="position">Application Position</label>

                          <% if (type === 'create') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "position",
                                  elementValue: null,
                                  required: true
                              }) %>
                          <% } %>
                          <% if (type === 'edit') { %>
                              <%- include("../../partials/form/inputText.ejs", {
                                  elementName: "position",
                                  elementValue: applicationApiData.position,
                                  required: true
                              }) %>
                          <% } %>
                      </div>

                      <!-- Application Status -->
                      <div class="mb-3 col">
                          <label for="applicationStatus">Application Status</label>

                          <% if (type === 'create') { %>
                              <%- include("../../partials/form/inputSelect.ejs", {
                                  elementName: "applicationStatus",
                                  elementValue: "null",
                                  required: true,
                                  optionElements: [
                                      {
                                          optionName: "Select a Status",
                                          optionValue: "null",
                                          selected: true,
                                          disabled: true
                                      },
                                      {
                                          optionName: "Open",
                                          optionValue: "1",
                                          selected: false,
                                          disabled: false
                                      },
                                      {
                                          optionName: "Closed",
                                          optionValue: "0",
                                          selected: false,
                                          disabled: false
                                      }
                                  ]
                              }) %>
                          <% } %>
                          <% if (type === 'edit') { %>
                              <%- include("../../partials/form/inputSelect.ejs", {
                                  elementName: "applicationStatus",
                                  elementValue: applicationApiData.applicationStatus,
                                  required: true,
                                  optionElements: [
                                      {
                                          optionName: "Select a Status",
                                          optionValue: "null",
                                          selected: true,
                                          disabled: true
                                      },
                                      {
                                          optionName: "Open",
                                          optionValue: "1",
                                          selected: false,
                                          disabled: false
                                      },
                                      {
                                          optionName: "Closed",
                                          optionValue: "0",
                                          selected: false,
                                          disabled: false
                                      }
                                  ]
                              }) %>
                          <% } %>
                      </div>
                  </div>

                  <% if (type === 'create') { %>
                      <button type="submit" class="btn btn-primary"><i class="fal fa-copy"></i> Create Application</button>
                  <% } %>

                  <% if (type === 'edit') { %>
                      <button type="submit" class="btn btn-warning"><i class="fa-solid fa-pen-to-square"></i> Edit Application</button>
                  <% } %>
                </form>
            </div>
        </main>
    </div>
</div>

<script>
(function() {
    var typeSelect = document.getElementById('applicationTypeSel');
    var redirectField = document.getElementById('redirectUrlField');
    var linkedFormField = document.getElementById('linkedFormField');

    function toggleFields() {
        if (!typeSelect || !redirectField || !linkedFormField) return;
        if (typeSelect.value === 'linked_form') {
            redirectField.style.display = 'none';
            linkedFormField.style.display = 'block';
        } else {
            redirectField.style.display = 'block';
            linkedFormField.style.display = 'none';
        }
    }

    if (typeSelect) {
        typeSelect.addEventListener('change', toggleFields);
        toggleFields();
    }
})();
</script>

<%- include("../../modules/footer.ejs") %>
