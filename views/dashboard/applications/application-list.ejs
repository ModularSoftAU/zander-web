<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "List of all Network Applications"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Applications",
  backgroundImage: globalImage
}) %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Applications</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="/dashboard/applications/create" class="btn btn-sm btn-info">Create Application</a>
                    <%- include("../../partials/documentationLink.ejs", {
                        doclink: "https://modularsoft.org/docs/products/zander/features/application/"
                    }) %>
                </div>
            </div>

            <% if (req.cookies.alertType) { %>
                <%- include("../../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
            <% } %>

            <div class="table-responsive">
                <table class="table align-middle applications-table">
                <thead>
                    <tr>
                        <th></th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (apiData.success == false) { %>
                        <%- include("../../partials/alert.ejs", {
                          alertType: "danger",
                          content: apiData.message
                        }) %>
                    <% } else { %>
                        <% apiData.data.forEach(function (application) { %>
                            <tr>
                                <td data-label="Icon"><i class="<%= application.displayIcon %>"></i></td>
                                <td data-label="Name"><%= application.displayName %></td>
                                <td data-label="Description"><%= application.description %></td>
                                <td data-label="Status">
                                    <% if (application.applicationStatus === 1) { %>
                                        <i class="fas fa-check-circle" style="color:green"></i>
                                    <% } else { %>
                                        <i class="fas fa-times-circle" style="color: red;"></i>
                                    <% } %>
                                </td>
                                <td data-label="Action">
                                    <div class="d-flex flex-wrap gap-2">
                                        <a href="/dashboard/applications/edit?applicationId=<%= application.applicationId %>" class="btn btn-sm btn-warning">Edit</a>
                                        <form action="<%= process.env.siteAddress %>/redirect/applications/delete" method="post">
                                            <input type="hidden" name="applicationId" value="<%= application.applicationId %>">
                                            <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
                </table>
            </div>
        </main>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>

<style>
    @media (max-width: 768px) {
        .applications-table thead {
            display: none;
        }

        .applications-table tr {
            display: block;
            border: 1px solid #e6e6e6;
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 12px;
        }

        .applications-table td {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
            border: none;
            padding: 6px 0;
            font-size: 0.9rem;
            word-break: break-word;
        }

        .applications-table td::before {
            content: attr(data-label);
            font-weight: 600;
            color: #5f6b7a;
            min-width: 110px;
        }
    }
</style>
