<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "List of all Network Applications"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Applications",
  backgroundImage: globalImage
}) %>

<section class="section section-dashboard">
  <div class="container-fluid">
    <div class="row dashboardview g-4">
      <div class="col-12 d-lg-none">
        <button class="btn btn-outline-primary w-100 dashboard-menu-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#dashboardSidebar" aria-controls="dashboardSidebar" aria-expanded="false">
          <i class="fas fa-bars me-2"></i>Dashboard menu
        </button>
      </div>
      <div class="col-12 col-lg-3 col-xl-2">
        <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
      </div>
      <div class="col-12 col-lg-9 col-xl-10">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-3 mb-4">
          <a href="/dashboard/applications/create" class="btn btn-info btn-sm text-nowrap"><i class="fa-solid fa-plus me-1"></i> Create application</a>
          <%- include("../../partials/documentationLink.ejs", {
              doclink: "https://modularsoft.org/docs/products/zander/features/application/"
          }) %>
        </div>

        <% if (req.cookies.alertType) { %>
          <div class="mb-3">
            <%- include("../../partials/alert.ejs", {
              alertType: req.cookies.alertType,
              content: req.cookies.alertContent
            }) %>
          </div>
        <% } %>

        <div class="card shadow-sm border-0">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th scope="col" class="text-center">Icon</th>
                    <th scope="col">Name</th>
                    <th scope="col">Description</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="text-end">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (apiData.success == false) { %>
                    <tr>
                      <td colspan="5">
                        <%- include("../../partials/alert.ejs", {
                          alertType: "danger",
                          content: apiData.message
                        }) %>
                      </td>
                    </tr>
                  <% } else { %>
                    <% apiData.data.forEach(function (application) { %>
                      <tr>
                        <td class="text-center"><i class="<%= application.displayIcon %>"></i></td>
                        <td class="fw-semibold"><%= application.displayName %></td>
                        <td class="text-break"><%= application.description %></td>
                        <td>
                          <% if (application.applicationStatus === 1) { %>
                            <i class="fas fa-check-circle text-success"></i>
                          <% } else { %>
                            <i class="fas fa-times-circle text-danger"></i>
                          <% } %>
                        </td>
                        <td class="text-end">
                          <div class="btn-group flex-wrap">
                            <a href="/dashboard/applications/edit?applicationId=<%= application.applicationId %>" class="btn btn-sm btn-warning">Edit</a>
                            <form action="<%= process.env.siteAddress %>/redirect/application/delete" method="post">
                              <input type="hidden" name="applicationId" value="<%= application.applicationId %>">
                              <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../../modules/footer.ejs") %>
