<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "List of all of the Vault entries"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Vault",
  backgroundImage: globalImage
}) %>

<div class="dashboardview">
    <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
    <div class="main-content">
        <a href="/dashboard/vault/create"><button type="button" class="btn btn-sm btn-info">Create Vault Entry</button></a>
        <%- include("../../partials/documentationLink.ejs", {
            doclink: "https://modularsoft.org/docs/products/zander/features/vault/"
        }) %>
        <br><br>

        <% if (req.cookies.alertType) { %>
            <%- include("../../partials/alert.ejs", {
              alertType: req.cookies.alertType,
              content: req.cookies.alertContent
            }) %>
        <% } %>
        <ul class="item-list">
            <% if (apiData.success == false) { %>
                <li class="item-list-item">
                    <%- include("../../partials/alert.ejs", {
                      alertType: "danger",
                      content: apiData.message
                    }) %>
                </li>
            <% } else { %>
                <% apiData.data.forEach(function (vault) { %>
                    <li class="item-list-item">
                        <div class="item-details">
                            <h5><%= vault.displayName %></h5>
                            <p><%= vault.description %></p>
                            <p><strong>Position:</strong> <%= vault.position %></p>
                            <a href="<%= vault.redirectUrl %>" class="btn btn-info btn-sm" target="_blank">View Vault Item</a>
                        </div>
                        <div class="item-actions">
                            <div class="btn-group">
                                <a href="/dashboard/vault/edit?vaultId=<%= vault.vaultId %>" class="btn btn-sm btn-warning">Edit</a>
                                <form action="<%= process.env.siteAddress %>/redirect/vault/delete" method="post" class="d-inline">
                                    <input type="hidden" name="vaultId" value="<%= vault.vaultId %>">
                                    <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </div>
                    </li>
                <% }) %>
            <% } %>
        </ul>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>