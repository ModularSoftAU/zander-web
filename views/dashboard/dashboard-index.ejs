<%- include("../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "The dashboard for the Network Administration Panel"
}) %>

<%- include("../modules/navigationBar.ejs") %>

<%- include("../partials/miniHeader.ejs", {
  headerTitle: "Dashboard",
  backgroundImage: globalImage
}) %>

<%- include("../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <% if (req.cookies.alertType) { %>
                <%- include("../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
            <% } %>

            <div class="row g-3 mb-4">
                <div class="col-sm-6 col-md-4">
                    <div class="card shadow-sm border-0 dashboard-stat-card">
                        <div class="card-body d-flex align-items-center gap-3 p-3">
                            <div class="dashboard-stat-icon text-success"><i class="fas fa-bullhorn"></i></div>
                            <div>
                                <div class="text-muted small">Announcements</div>
                                <div class="fw-bold fs-4"><%= announcementsCount %></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-md-4">
                    <div class="card shadow-sm border-0 dashboard-stat-card">
                        <div class="card-body d-flex align-items-center gap-3 p-3">
                            <div class="dashboard-stat-icon text-primary"><i class="fas fa-file-alt"></i></div>
                            <div>
                                <div class="text-muted small">Applications</div>
                                <div class="fw-bold fs-4"><%= applicationsCount %></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-md-4">
                    <div class="card shadow-sm border-0 dashboard-stat-card">
                        <div class="card-body d-flex align-items-center gap-3 p-3">
                            <div class="dashboard-stat-icon text-warning"><i class="fas fa-server"></i></div>
                            <div>
                                <div class="text-muted small">Servers</div>
                                <div class="fw-bold fs-4"><%= serversCount %></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<%- include("../modules/footer.ejs") %>
