<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Logs of all Network Administration events."
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container-fluid">
    <div class="row">
        <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>

        <main role="main" class="col-md-9 ml-sm-auto col-lg-10 px-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Logs</h1>
            </div>

            <% if (req.cookies.alertType) { %>
                <%- include("../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
            <% } %>

            <% const availableUsers = apiData.success ? Array.from(new Set(apiData.data.map((log) => log.actionedUsername).filter(Boolean))) : []; %>
            <% const availableFeatures = apiData.success ? Array.from(new Set(apiData.data.map((log) => log.logFeature).filter(Boolean))) : []; %>
            <form class="row g-3 align-items-end mb-3" method="get" action="/dashboard/logs">
                <div class="col-12 col-md-4">
                    <label class="form-label" for="userFilter">User</label>
                    <select class="form-select" id="userFilter" name="user">
                        <option value="">All users</option>
                        <% availableUsers.forEach((user) => { %>
                            <option value="<%= user %>" <%= req.query.user === user ? 'selected' : '' %>><%= user %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label" for="featureFilter">Event</label>
                    <select class="form-select" id="featureFilter" name="feature">
                        <option value="">All events</option>
                        <% availableFeatures.forEach((feature) => { %>
                            <option value="<%= feature %>" <%= req.query.feature === feature ? 'selected' : '' %>><%= feature %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">Filter</button>
                    <a class="btn btn-outline-secondary flex-grow-1" href="/dashboard/logs">Reset</a>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table align-middle logs-table">
                    <thead>
                        <tr>
                            <th>Actioned User</th>
                            <th>Type</th>
                            <th>Feature</th>
                            <th>Description</th>
                            <th>DateTime</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (apiData.success == false) { %>
                            <%- include("../../partials/alert.ejs", {
                              alertType: "danger",
                              content: apiData.message
                            }) %>
                        <% } else { %>
                            <% apiData.data.forEach(function (log) { %>
                                <tr>
                                    <td data-label="Actioned User"><%= log.actionedUsername %></td>
                                    <td data-label="Type">
                                        <%- include("../../partials/logPriorityBadge.ejs", {
                                            type: log.logType
                                        }) %>
                                    </td>
                                    <td data-label="Feature"><span class="badge text-bg-primary"><%= log.logFeature %></span></td>
                                    <td data-label="Description"><%= log.description %></td>
                                    <td data-label="DateTime">
                                        <span class="js-log-datetime" data-iso="<%= log.actionedDateTime %>"></span>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>

<style>
    @media (max-width: 768px) {
        .logs-table thead {
            display: none;
        }

        .logs-table tr {
            display: block;
            border: 1px solid #e6e6e6;
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 12px;
        }

        .logs-table td {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
            border: none;
            padding: 6px 0;
            font-size: 0.9rem;
        }

        .logs-table td::before {
            content: attr(data-label);
            font-weight: 600;
            color: #5f6b7a;
            min-width: 120px;
        }
    }
</style>

<script>
    const parseDateValue = (value) => {
        if (!value) return null;
        const normalized = value.includes(" ") ? value.replace(" ", "T") : value;
        const date = new Date(normalized);
        if (Number.isNaN(date.getTime())) {
            return null;
        }
        return date;
    };

    document.querySelectorAll(".js-log-datetime").forEach((element) => {
        const isoValue = element.dataset.iso;
        const date = parseDateValue(isoValue);
        if (!date) {
            element.textContent = "";
            return;
        }

        element.textContent = date.toLocaleString();
    });
</script>
