<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Monthly vote leaderboard and reward results"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Vote Leaderboard",
  backgroundImage: globalImage
}) %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Vote Leaderboard</h1>
                <div class="btn-toolbar mb-2 mb-md-0 gap-2">
                    <a href="/dashboard/voting" class="btn btn-sm btn-outline-secondary">← Vote Sites</a>
                    <button class="btn btn-sm btn-success" id="processMonthBtn">Process Monthly Rewards</button>
                </div>
            </div>

            <!-- Month picker -->
            <form method="get" action="/dashboard/voting/leaderboard" class="row g-2 mb-4 align-items-end">
                <div class="col-auto">
                    <label class="form-label mb-1">Month</label>
                    <input type="month" name="month" class="form-control form-control-sm" value="<%= activeMonth %>">
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-sm btn-primary">View</button>
                </div>
            </form>

            <div id="processResult" class="alert d-none mb-3"></div>

            <div class="row g-4">
                <div class="col-lg-7">
                    <h5>Rankings — <%= activeMonth %></h5>
                    <% if (boardData.success && boardData.data && boardData.data.length) { %>
                        <ol class="list-group list-group-numbered">
                            <% boardData.data.forEach(function(entry) { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>
                                        <strong><%= entry.player_name %></strong>
                                        <br><small class="text-muted"><%= entry.player_uuid %></small>
                                    </span>
                                    <span class="badge bg-primary rounded-pill"><%= entry.vote_count %> votes</span>
                                </li>
                            <% }) %>
                        </ol>
                    <% } else { %>
                        <p class="text-muted">No votes recorded for <%= activeMonth %>.</p>
                    <% } %>
                </div>
                <div class="col-lg-5">
                    <h5>Reward Results — <%= activeMonth %></h5>
                    <% if (resultsData.success && resultsData.data && resultsData.data.length) { %>
                        <ul class="list-group">
                            <% resultsData.data.forEach(function(result) { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>
                                        <strong>#<%= result.tie_position %> <%= result.player_name %></strong>
                                        <br><small class="text-muted"><%= result.vote_count %> votes</small>
                                    </span>
                                    <span class="badge bg-success">Rewarded</span>
                                </li>
                            <% }) %>
                        </ul>
                        <p class="text-muted small mt-2">Rewards already generated for this month.</p>
                    <% } else { %>
                        <p class="text-muted">No rewards generated yet for <%= activeMonth %>.</p>
                        <p class="text-muted small">Use the "Process Monthly Rewards" button to generate them.</p>
                    <% } %>
                </div>
            </div>
        </main>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>

<script>
const API_KEY = <%- JSON.stringify(process.env.apiKey || '') %>;
const activeMonth = "<%= activeMonth %>";

document.getElementById('processMonthBtn').addEventListener('click', async () => {
    const btn = document.getElementById('processMonthBtn');
    const resultEl = document.getElementById('processResult');
    btn.disabled = true;
    btn.textContent = 'Processing…';
    resultEl.classList.add('d-none');

    try {
        const res = await fetch('/admin/vote/monthly/process', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'x-access-token': API_KEY },
            body: JSON.stringify({ month: activeMonth }),
        });
        const data = await res.json();
        resultEl.className = `alert alert-${data.success ? 'success' : 'warning'}`;
        resultEl.textContent = data.message;
        resultEl.classList.remove('d-none');
        if (data.success) setTimeout(() => location.reload(), 1500);
    } catch (err) {
        resultEl.className = 'alert alert-danger';
        resultEl.textContent = 'Request failed: ' + err.message;
        resultEl.classList.remove('d-none');
    } finally {
        btn.disabled = false;
        btn.textContent = 'Process Monthly Rewards';
    }
});
</script>
