<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Reward command queue viewer"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Reward Queue",
  backgroundImage: globalImage
}) %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Reward Queue</h1>
                <div class="btn-toolbar mb-2 mb-md-0 gap-2">
                    <a href="/dashboard/voting" class="btn btn-sm btn-outline-secondary">← Vote Sites</a>
                </div>
            </div>

            <!-- Filters -->
            <form method="get" action="/dashboard/voting/queue" class="row g-2 mb-4 align-items-end">
                <div class="col-auto">
                    <label class="form-label mb-1">Status</label>
                    <select name="status" class="form-select form-select-sm">
                        <option value="" <%= activeStatus === '' ? 'selected' : '' %>>All</option>
                        <option value="pending" <%= activeStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                        <option value="claimed" <%= activeStatus === 'claimed' ? 'selected' : '' %>>Claimed</option>
                        <option value="completed" <%= activeStatus === 'completed' ? 'selected' : '' %>>Completed</option>
                        <option value="failed" <%= activeStatus === 'failed' ? 'selected' : '' %>>Failed</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-1">Player UUID</label>
                    <input type="text" name="playerUuid" class="form-control form-control-sm" placeholder="uuid" value="<%= activePlayerUuid %>">
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-sm btn-primary">Filter</button>
                    <a href="/dashboard/voting/queue" class="btn btn-sm btn-outline-secondary ms-1">Reset</a>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-sm align-middle queue-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Player</th>
                            <th>Source</th>
                            <th>Command</th>
                            <th>Scope</th>
                            <th>Status</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!queueData.success || !queueData.data || !queueData.data.length) { %>
                            <tr><td colspan="7" class="text-center text-muted">No queue entries found.</td></tr>
                        <% } else { %>
                            <% queueData.data.forEach(function(entry) { %>
                                <tr>
                                    <td data-label="ID"><small><%= entry.id %></small></td>
                                    <td data-label="Player">
                                        <strong><%= entry.player_name %></strong>
                                        <br><small class="text-muted"><%= entry.player_uuid %></small>
                                    </td>
                                    <td data-label="Source">
                                        <span class="badge text-bg-secondary"><%= entry.source %></span>
                                    </td>
                                    <td data-label="Command">
                                        <code class="small"><%= entry.command_text %></code>
                                        <% if (entry.failure_reason) { %>
                                            <br><small class="text-danger"><%= entry.failure_reason %></small>
                                        <% } %>
                                    </td>
                                    <td data-label="Scope"><small><%= entry.server_scope %></small></td>
                                    <td data-label="Status">
                                        <% const statusClasses = { pending: 'warning', claimed: 'info', completed: 'success', failed: 'danger' }; %>
                                        <span class="badge text-bg-<%= statusClasses[entry.status] || 'secondary' %>"><%= entry.status %></span>
                                    </td>
                                    <td data-label="Created">
                                        <small class="js-datetime" data-iso="<%= entry.created_at %>"><%= entry.created_at %></small>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>

<script>
document.querySelectorAll(".js-datetime").forEach(el => {
    const iso = el.dataset.iso;
    if (!iso) return;
    const d = new Date(iso.includes(" ") ? iso.replace(" ", "T") + "Z" : iso);
    if (!isNaN(d.getTime())) el.textContent = d.toLocaleString();
});
</script>
