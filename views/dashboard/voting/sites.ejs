<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Manage voting sites and view the current leaderboard"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Voting",
  backgroundImage: globalImage
}) %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Vote Sites</h1>
                <div class="btn-toolbar mb-2 mb-md-0 gap-2">
                    <a href="/dashboard/voting/rewards" class="btn btn-sm btn-outline-secondary">Reward Templates</a>
                    <a href="/dashboard/voting/leaderboard" class="btn btn-sm btn-outline-secondary">Leaderboard</a>
                    <a href="/dashboard/voting/queue" class="btn btn-sm btn-outline-secondary">Reward Queue</a>
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createSiteModal">
                        Add Vote Site
                    </button>
                </div>
            </div>

            <% if (req.cookies.alertType) { %>
                <%- include("../../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
            <% } %>

            <div class="table-responsive">
                <table class="table align-middle vote-sites-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Site Name</th>
                            <th>Service Name</th>
                            <th>Vote URL</th>
                            <th>Order</th>
                            <th>Active</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!sitesData.success || !sitesData.data || !sitesData.data.length) { %>
                            <tr><td colspan="7" class="text-center text-muted">No vote sites configured.</td></tr>
                        <% } else { %>
                            <% sitesData.data.forEach(function (site) { %>
                                <tr>
                                    <td data-label="#"><%= site.id %></td>
                                    <td data-label="Site Name"><strong><%= site.site_name %></strong></td>
                                    <td data-label="Service Name"><code><%= site.service_name %></code></td>
                                    <td data-label="Vote URL">
                                        <a href="<%= site.vote_url %>" target="_blank" rel="noopener" class="text-truncate d-inline-block" style="max-width:180px"><%= site.vote_url %></a>
                                    </td>
                                    <td data-label="Order"><%= site.display_order %></td>
                                    <td data-label="Active">
                                        <% if (site.is_active) { %>
                                            <i class="fas fa-check-circle text-success"></i>
                                        <% } else { %>
                                            <i class="fas fa-times-circle text-danger"></i>
                                        <% } %>
                                    </td>
                                    <td data-label="Actions">
                                        <div class="d-flex flex-wrap gap-2">
                                            <button class="btn btn-sm btn-warning"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editSiteModal"
                                                data-id="<%= site.id %>"
                                                data-site-name="<%= site.site_name %>"
                                                data-service-name="<%= site.service_name %>"
                                                data-vote-url="<%= site.vote_url %>"
                                                data-display-order="<%= site.display_order %>"
                                                data-is-active="<%= site.is_active %>">
                                                Edit
                                            </button>
                                            <button class="btn btn-sm btn-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteSiteModal"
                                                data-id="<%= site.id %>"
                                                data-site-name="<%= site.site_name %>">
                                                Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Current month leaderboard preview -->
            <div class="mt-4">
                <h5 class="border-bottom pb-2">Current Month Leaderboard Preview</h5>
                <% if (leaderboardData.success && leaderboardData.data && leaderboardData.data.length) { %>
                    <ol class="list-group list-group-numbered">
                        <% leaderboardData.data.slice(0, 10).forEach(function(entry) { %>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span><%= entry.player_name %></span>
                                <span class="badge bg-primary rounded-pill"><%= entry.vote_count %> votes</span>
                            </li>
                        <% }) %>
                    </ol>
                    <a href="/dashboard/voting/leaderboard" class="btn btn-sm btn-link mt-2">View full leaderboard →</a>
                <% } else { %>
                    <p class="text-muted">No votes recorded this month yet.</p>
                <% } %>
            </div>
        </main>
    </div>
</div>

<!-- Create Site Modal -->
<div class="modal fade" id="createSiteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Vote Site</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="createSiteForm">
                    <div class="mb-3">
                        <label class="form-label">Site Name</label>
                        <input type="text" class="form-control" name="siteName" required placeholder="Planet Minecraft">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Service Name <small class="text-muted">(lowercase, used to match incoming votes)</small></label>
                        <input type="text" class="form-control" name="serviceName" required placeholder="planetminecraft">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vote URL</label>
                        <input type="url" class="form-control" name="voteUrl" required placeholder="https://www.planetminecraft.com/server/...">
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label">Display Order</label>
                            <input type="number" class="form-control" name="displayOrder" value="0">
                        </div>
                        <div class="col mb-3">
                            <label class="form-label">Active</label>
                            <select class="form-select" name="isActive">
                                <option value="true" selected>Yes</option>
                                <option value="false">No</option>
                            </select>
                        </div>
                    </div>
                    <div id="createSiteError" class="alert alert-danger d-none"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="createSiteSubmit">Add Site</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Site Modal -->
<div class="modal fade" id="editSiteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Vote Site</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editSiteForm">
                    <input type="hidden" name="siteId" id="editSiteId">
                    <div class="mb-3">
                        <label class="form-label">Site Name</label>
                        <input type="text" class="form-control" name="siteName" id="editSiteName" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Service Name</label>
                        <input type="text" class="form-control" name="serviceName" id="editServiceName" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vote URL</label>
                        <input type="url" class="form-control" name="voteUrl" id="editVoteUrl" required>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label">Display Order</label>
                            <input type="number" class="form-control" name="displayOrder" id="editDisplayOrder">
                        </div>
                        <div class="col mb-3">
                            <label class="form-label">Active</label>
                            <select class="form-select" name="isActive" id="editIsActive">
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </select>
                        </div>
                    </div>
                    <div id="editSiteError" class="alert alert-danger d-none"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" id="editSiteSubmit">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Site Modal -->
<div class="modal fade" id="deleteSiteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Vote Site</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteSiteName"></strong>?</p>
                <p class="text-muted small">Existing vote records referencing this site will be retained.</p>
                <div id="deleteSiteError" class="alert alert-danger d-none"></div>
            </div>
            <div class="modal-footer">
                <input type="hidden" id="deleteSiteId">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="deleteSiteSubmit">Delete</button>
            </div>
        </div>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>

<script>
const API_KEY = <%- JSON.stringify(process.env.apiKey || '') %>;

// Populate edit modal
document.querySelectorAll('[data-bs-target="#editSiteModal"]').forEach(btn => {
    btn.addEventListener('click', () => {
        document.getElementById('editSiteId').value = btn.dataset.id;
        document.getElementById('editSiteName').value = btn.dataset.siteName;
        document.getElementById('editServiceName').value = btn.dataset.serviceName;
        document.getElementById('editVoteUrl').value = btn.dataset.voteUrl;
        document.getElementById('editDisplayOrder').value = btn.dataset.displayOrder;
        document.getElementById('editIsActive').value = btn.dataset.isActive === '1' ? 'true' : 'false';
        document.getElementById('editSiteError').classList.add('d-none');
    });
});

// Populate delete modal
document.querySelectorAll('[data-bs-target="#deleteSiteModal"]').forEach(btn => {
    btn.addEventListener('click', () => {
        document.getElementById('deleteSiteId').value = btn.dataset.id;
        document.getElementById('deleteSiteName').textContent = btn.dataset.siteName;
        document.getElementById('deleteSiteError').classList.add('d-none');
    });
});

async function apiRequest(method, url, body) {
    const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json', 'x-access-token': API_KEY },
        body: body ? JSON.stringify(body) : undefined,
    });
    return res.json();
}

document.getElementById('createSiteSubmit').addEventListener('click', async () => {
    const form = document.getElementById('createSiteForm');
    const errEl = document.getElementById('createSiteError');
    errEl.classList.add('d-none');
    const data = {
        siteName: form.siteName.value.trim(),
        serviceName: form.serviceName.value.trim(),
        voteUrl: form.voteUrl.value.trim(),
        displayOrder: parseInt(form.displayOrder.value, 10) || 0,
        isActive: form.isActive.value === 'true',
    };
    const result = await apiRequest('POST', '/admin/vote/sites', data);
    if (result.success) { location.reload(); }
    else { errEl.textContent = result.message; errEl.classList.remove('d-none'); }
});

document.getElementById('editSiteSubmit').addEventListener('click', async () => {
    const form = document.getElementById('editSiteForm');
    const errEl = document.getElementById('editSiteError');
    errEl.classList.add('d-none');
    const id = document.getElementById('editSiteId').value;
    const data = {
        siteName: form.siteName.value.trim(),
        serviceName: form.serviceName.value.trim(),
        voteUrl: form.voteUrl.value.trim(),
        displayOrder: parseInt(form.displayOrder.value, 10) || 0,
        isActive: form.isActive.value === 'true',
    };
    const result = await apiRequest('PUT', `/admin/vote/sites/${id}`, data);
    if (result.success) { location.reload(); }
    else { errEl.textContent = result.message; errEl.classList.remove('d-none'); }
});

document.getElementById('deleteSiteSubmit').addEventListener('click', async () => {
    const errEl = document.getElementById('deleteSiteError');
    errEl.classList.add('d-none');
    const id = document.getElementById('deleteSiteId').value;
    const result = await apiRequest('DELETE', `/admin/vote/sites/${id}`);
    if (result.success) { location.reload(); }
    else { errEl.textContent = result.message; errEl.classList.remove('d-none'); }
});
</script>
