<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Manage reward command templates for votes and monthly top voters"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Reward Templates",
  backgroundImage: globalImage
}) %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Reward Templates</h1>
                <div class="btn-toolbar mb-2 mb-md-0 gap-2">
                    <a href="/dashboard/voting" class="btn btn-sm btn-outline-secondary">← Vote Sites</a>
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createTemplateModal">
                        Add Template
                    </button>
                </div>
            </div>

            <div id="globalAlert" class="alert d-none mb-3"></div>

            <p class="text-muted small mb-4">
                Templates define the commands queued when a vote is received (<strong>Vote reward</strong>) or when a monthly top-voter winner is determined (<strong>Monthly top-voter</strong>).
                Commands fire in display-order. Inactive templates are skipped.<br>
                <strong>Placeholders:</strong>
                <code>{player}</code> — username,
                <code>{uuid}</code> — UUID,
                <code>{month}</code> — YYYY-MM (monthly only),
                <code>{voteCount}</code> — vote total (monthly only).
            </p>

            <%
              const allTemplates = (templatesData.success && templatesData.data) ? templatesData.data : [];
              const voteTemplates = allTemplates.filter(t => t.reward_type === 'vote');
              const monthlyTemplates = allTemplates.filter(t => t.reward_type === 'monthly_top');
            %>

            <!-- Vote reward templates -->
            <h5 class="mb-2"><i class="fas fa-check-to-slot me-2 text-primary"></i>Vote Rewards <span class="badge bg-primary ms-1"><%= voteTemplates.length %></span></h5>
            <p class="text-muted small">Fired every time a player casts a valid vote.</p>
            <%- include("../../partials/voting/template-table.ejs", { templates: voteTemplates }) %>

            <hr class="my-4">

            <!-- Monthly top-voter templates -->
            <h5 class="mb-2"><i class="fas fa-trophy me-2 text-warning"></i>Monthly Top-Voter Rewards <span class="badge bg-warning text-dark ms-1"><%= monthlyTemplates.length %></span></h5>
            <p class="text-muted small">Fired once per winner when monthly rewards are processed.</p>
            <%- include("../../partials/voting/template-table.ejs", { templates: monthlyTemplates }) %>
        </main>
    </div>
</div>

<!-- Create Template Modal -->
<div class="modal fade" id="createTemplateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Reward Template</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="createTemplateForm">
                    <div class="mb-3">
                        <label class="form-label">Reward Type</label>
                        <select class="form-select" name="rewardType" required>
                            <option value="vote">Vote Reward</option>
                            <option value="monthly_top">Monthly Top-Voter</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Command Template</label>
                        <input type="text" class="form-control font-monospace" name="commandTemplate" required placeholder="crate key give {player} vote 1">
                        <div class="form-text">Use <code>{player}</code>, <code>{uuid}</code>, <code>{month}</code>, <code>{voteCount}</code> as placeholders.</div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label">Execute As</label>
                            <select class="form-select" name="executeAs">
                                <option value="console">Console</option>
                                <option value="player">Player</option>
                            </select>
                        </div>
                        <div class="col mb-3">
                            <label class="form-label">Server Scope</label>
                            <input type="text" class="form-control" name="serverScope" value="any" placeholder="any">
                            <div class="form-text">Server name or <code>any</code>.</div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label">Display Order</label>
                            <input type="number" class="form-control" name="displayOrder" value="0" min="0">
                        </div>
                        <div class="col mb-3">
                            <label class="form-label">Active</label>
                            <select class="form-select" name="isActive">
                                <option value="true" selected>Yes</option>
                                <option value="false">No</option>
                            </select>
                        </div>
                    </div>
                    <div id="createTemplateError" class="alert alert-danger d-none"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="createTemplateSubmit">Add Template</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Template Modal -->
<div class="modal fade" id="editTemplateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Reward Template</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editTemplateForm">
                    <input type="hidden" name="templateId" id="editTemplateId">
                    <div class="mb-3">
                        <label class="form-label">Reward Type</label>
                        <select class="form-select" name="rewardType" id="editRewardType" required>
                            <option value="vote">Vote Reward</option>
                            <option value="monthly_top">Monthly Top-Voter</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Command Template</label>
                        <input type="text" class="form-control font-monospace" name="commandTemplate" id="editCommandTemplate" required>
                        <div class="form-text">Use <code>{player}</code>, <code>{uuid}</code>, <code>{month}</code>, <code>{voteCount}</code>.</div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label">Execute As</label>
                            <select class="form-select" name="executeAs" id="editExecuteAs">
                                <option value="console">Console</option>
                                <option value="player">Player</option>
                            </select>
                        </div>
                        <div class="col mb-3">
                            <label class="form-label">Server Scope</label>
                            <input type="text" class="form-control" name="serverScope" id="editServerScope" placeholder="any">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label">Display Order</label>
                            <input type="number" class="form-control" name="displayOrder" id="editDisplayOrder" min="0">
                        </div>
                        <div class="col mb-3">
                            <label class="form-label">Active</label>
                            <select class="form-select" name="isActive" id="editIsActive">
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </select>
                        </div>
                    </div>
                    <div id="editTemplateError" class="alert alert-danger d-none"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" id="editTemplateSubmit">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Template Modal -->
<div class="modal fade" id="deleteTemplateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Reward Template</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Delete this template?</p>
                <code id="deleteTemplateCommand" class="d-block mb-2"></code>
                <p class="text-muted small">This cannot be undone. Existing queued commands generated from this template are not affected.</p>
                <div id="deleteTemplateError" class="alert alert-danger d-none"></div>
            </div>
            <div class="modal-footer">
                <input type="hidden" id="deleteTemplateId">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="deleteTemplateSubmit">Delete</button>
            </div>
        </div>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>

<script>
const API_KEY = "<%= process.env.apiKey %>";

async function apiRequest(method, url, body) {
    const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json', 'x-access-token': API_KEY },
        body: body ? JSON.stringify(body) : undefined,
    });
    return res.json();
}

// Populate edit modal from data attributes on button
document.addEventListener('click', e => {
    const editBtn = e.target.closest('[data-bs-target="#editTemplateModal"]');
    if (editBtn) {
        document.getElementById('editTemplateId').value = editBtn.dataset.id;
        document.getElementById('editRewardType').value = editBtn.dataset.rewardType;
        document.getElementById('editCommandTemplate').value = editBtn.dataset.commandTemplate;
        document.getElementById('editExecuteAs').value = editBtn.dataset.executeAs;
        document.getElementById('editServerScope').value = editBtn.dataset.serverScope;
        document.getElementById('editDisplayOrder').value = editBtn.dataset.displayOrder;
        document.getElementById('editIsActive').value = editBtn.dataset.isActive === '1' ? 'true' : 'false';
        document.getElementById('editTemplateError').classList.add('d-none');
    }

    const delBtn = e.target.closest('[data-bs-target="#deleteTemplateModal"]');
    if (delBtn) {
        document.getElementById('deleteTemplateId').value = delBtn.dataset.id;
        document.getElementById('deleteTemplateCommand').textContent = delBtn.dataset.commandTemplate;
        document.getElementById('deleteTemplateError').classList.add('d-none');
    }
});

function showGlobal(type, msg) {
    const el = document.getElementById('globalAlert');
    el.className = `alert alert-${type}`;
    el.textContent = msg;
    el.classList.remove('d-none');
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

document.getElementById('createTemplateSubmit').addEventListener('click', async () => {
    const form = document.getElementById('createTemplateForm');
    const errEl = document.getElementById('createTemplateError');
    errEl.classList.add('d-none');
    const data = {
        rewardType: form.rewardType.value,
        commandTemplate: form.commandTemplate.value.trim(),
        executeAs: form.executeAs.value,
        serverScope: form.serverScope.value.trim() || 'any',
        displayOrder: parseInt(form.displayOrder.value, 10) || 0,
        isActive: form.isActive.value === 'true',
    };
    const result = await apiRequest('POST', '/admin/vote/reward-templates', data);
    if (result.success) {
        bootstrap.Modal.getInstance(document.getElementById('createTemplateModal')).hide();
        showGlobal('success', 'Template created.');
        setTimeout(() => location.reload(), 800);
    } else {
        errEl.textContent = result.message;
        errEl.classList.remove('d-none');
    }
});

document.getElementById('editTemplateSubmit').addEventListener('click', async () => {
    const form = document.getElementById('editTemplateForm');
    const errEl = document.getElementById('editTemplateError');
    errEl.classList.add('d-none');
    const id = document.getElementById('editTemplateId').value;
    const data = {
        rewardType: form.rewardType.value,
        commandTemplate: form.commandTemplate.value.trim(),
        executeAs: form.executeAs.value,
        serverScope: form.serverScope.value.trim() || 'any',
        displayOrder: parseInt(form.displayOrder.value, 10) || 0,
        isActive: form.isActive.value === 'true',
    };
    const result = await apiRequest('PUT', `/admin/vote/reward-templates/${id}`, data);
    if (result.success) {
        bootstrap.Modal.getInstance(document.getElementById('editTemplateModal')).hide();
        showGlobal('success', 'Template updated.');
        setTimeout(() => location.reload(), 800);
    } else {
        errEl.textContent = result.message;
        errEl.classList.remove('d-none');
    }
});

document.getElementById('deleteTemplateSubmit').addEventListener('click', async () => {
    const errEl = document.getElementById('deleteTemplateError');
    errEl.classList.add('d-none');
    const id = document.getElementById('deleteTemplateId').value;
    const result = await apiRequest('DELETE', `/admin/vote/reward-templates/${id}`);
    if (result.success) {
        bootstrap.Modal.getInstance(document.getElementById('deleteTemplateModal')).hide();
        showGlobal('success', 'Template deleted.');
        setTimeout(() => location.reload(), 800);
    } else {
        errEl.textContent = result.message;
        errEl.classList.remove('d-none');
    }
});
</script>
