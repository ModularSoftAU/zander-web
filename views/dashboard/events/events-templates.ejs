<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Event Templates"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Event Templates",
  backgroundImage: globalImage
}) %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Event Templates</h1>
                <div class="btn-toolbar mb-2 mb-md-0 gap-2">
                    <a href="/dashboard/events" class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-calendar fa-fw me-1"></i>Calendar
                    </a>
                    <a href="/dashboard/events/templates/create" class="btn btn-sm btn-primary">
                        <i class="fas fa-plus fa-fw me-1"></i>New Template
                    </a>
                    <%- include("../../partials/documentationLink.ejs", {
                        doclink: "https://modularsoft.org/docs/products/zander/features/events/"
                    }) %>
                </div>
            </div>

            <% if (req.cookies.alertType) { %>
                <%- include("../../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
            <% } %>

            <p class="text-muted small">Templates define recurring event patterns. When a template is due, a draft event is automatically generated for review.</p>

            <% if (!apiData.success) { %>
                <%- include("../../partials/alert.ejs", { alertType: "danger", content: apiData.message }) %>
            <% } else if (!apiData.data || apiData.data.length === 0) { %>
                <div class="alert alert-info">
                    No templates yet. <a href="/dashboard/events/templates/create">Create your first template</a>.
                </div>
            <% } else { %>
                <div class="row g-3">
                    <% apiData.data.forEach(tmpl => { %>
                    <div class="col-md-6">
                        <div class="card h-100 <%= !tmpl.isActive ? 'border-secondary opacity-75' : '' %>">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span class="fw-semibold"><%= tmpl.title %></span>
                                <div class="d-flex gap-1 align-items-center">
                                    <% if (!tmpl.isActive) { %><span class="badge bg-secondary">Inactive</span><% } %>
                                    <% if (tmpl.autoGenerateDrafts) { %><span class="badge bg-info text-dark" title="Auto-generates drafts"><i class="fas fa-robot fa-fw"></i></span><% } %>
                                </div>
                            </div>
                            <div class="card-body">
                                <dl class="row mb-0 small">
                                    <dt class="col-5">Recurrence</dt>
                                    <dd class="col-7">
                                        <%= tmpl.recurrenceType %>
                                        <% if (tmpl.recurrenceType === 'weekly' && tmpl.recurrenceDays) {
                                            const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
                                            const days = Array.isArray(tmpl.recurrenceDays) ? tmpl.recurrenceDays : JSON.parse(tmpl.recurrenceDays || '[]');
                                        %>
                                        — <%= days.map(d => dayNames[d]).join(', ') %>
                                        <% } %>
                                    </dd>
                                    <dt class="col-5">Default Time</dt>
                                    <dd class="col-7"><%= tmpl.defaultStartTime || '—' %> – <%= tmpl.defaultEndTime || '—' %></dd>
                                    <dt class="col-5">Draft Advance</dt>
                                    <dd class="col-7"><%= tmpl.draftAdvanceDays %> days before</dd>
                                    <dt class="col-5">Next Generate</dt>
                                    <dd class="col-7">
                                        <% if (tmpl.nextGenerateAt) { %>
                                            <span class="js-datetime" data-iso="<%= tmpl.nextGenerateAt %>"></span>
                                        <% } else { %><span class="text-muted">—</span><% } %>
                                    </dd>
                                    <dt class="col-5">Events</dt>
                                    <dd class="col-7"><%= tmpl._count ? tmpl._count.events : 0 %> created</dd>
                                </dl>
                            </div>
                            <div class="card-footer d-flex gap-2">
                                <a href="/dashboard/events/templates/edit?templateId=<%= tmpl.templateId %>" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit me-1"></i>Edit
                                </a>
                                <button class="btn btn-sm btn-outline-primary btn-generate-draft" data-template-id="<%= tmpl.templateId %>" data-title="<%= tmpl.title %>">
                                    <i class="fas fa-plus me-1"></i>Generate Draft
                                </button>
                                <button class="btn btn-sm btn-outline-danger btn-delete-template ms-auto" data-template-id="<%= tmpl.templateId %>" data-title="<%= tmpl.title %>">
                                    <i class="fas fa-trash me-1"></i>Delete
                                </button>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            <% } %>
        </main>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>

<script>
document.querySelectorAll('.js-datetime').forEach(el => {
    const d = el.dataset.iso ? new Date(el.dataset.iso) : null;
    el.textContent = d && !isNaN(d) ? d.toLocaleString() : '—';
});

document.querySelectorAll('.btn-generate-draft').forEach(btn => {
    btn.addEventListener('click', async () => {
        if (!confirm(`Generate a draft event from template "${btn.dataset.title}"?`)) return;
        btn.disabled = true;
        const res = await fetch('/api/events/templates/generate-draft', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'x-access-token': '<%= process.env.apiKey %>' },
            body: JSON.stringify({ templateId: btn.dataset.templateId }),
        });
        const data = await res.json();
        if (data.success) {
            window.location.href = `/dashboard/events/view?eventId=${data.data.eventId}`;
        } else {
            alert('Error: ' + data.message);
            btn.disabled = false;
        }
    });
});

document.querySelectorAll('.btn-delete-template').forEach(btn => {
    btn.addEventListener('click', async () => {
        if (!confirm(`Delete template "${btn.dataset.title}"? This will not delete generated events.`)) return;
        const res = await fetch('/api/events/templates/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'x-access-token': '<%= process.env.apiKey %>' },
            body: JSON.stringify({ templateId: btn.dataset.templateId }),
        });
        const data = await res.json();
        if (data.success) window.location.reload();
        else alert('Error: ' + data.message);
    });
});
</script>
