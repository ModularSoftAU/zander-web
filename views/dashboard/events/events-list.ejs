<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Events List"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Events",
  backgroundImage: globalImage
}) %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Events</h1>
                <div class="btn-toolbar mb-2 mb-md-0 gap-2">
                    <a href="/dashboard/events" class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-calendar fa-fw me-1"></i>Calendar
                    </a>
                    <a href="/dashboard/events/review" class="btn btn-sm btn-outline-warning">
                        <i class="fas fa-clock fa-fw me-1"></i>Review Queue
                    </a>
                    <a href="/dashboard/events/create" class="btn btn-sm btn-primary">
                        <i class="fas fa-plus fa-fw me-1"></i>New Event
                    </a>
                    <%- include("../../partials/documentationLink.ejs", {
                        doclink: "https://modularsoft.org/docs/products/zander/features/events/"
                    }) %>
                </div>
            </div>

            <%- include("../../partials/permissionsInfo.ejs", { permissions: [
                { node: "zander.web.events",        description: "View, create, edit and manage all events" },
                { node: "zander.web.events.review",  description: "Approve or reject events submitted for review" },
            ]}) %>

            <% if (req.cookies.alertType) { %>
                <%- include("../../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
            <% } %>

            <!-- Filters -->
            <form method="GET" action="/dashboard/events/list" class="row g-2 mb-3">
                <div class="col-sm-4">
                    <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All Statuses</option>
                        <% ['draft','pending_review','approved','published','rejected','cancelled','archived'].forEach(s => { %>
                            <option value="<%= s %>" <%= statusFilter === s ? 'selected' : '' %>><%= s.replace('_',' ').replace(/\b\w/g,c=>c.toUpperCase()) %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-sm-6">
                    <div class="input-group input-group-sm">
                        <input type="text" name="search" class="form-control" placeholder="Search events…" value="<%= search %>">
                        <button class="btn btn-outline-secondary" type="submit"><i class="fas fa-search"></i></button>
                    </div>
                </div>
            </form>

            <% if (!apiData.success) { %>
                <%- include("../../partials/alert.ejs", { alertType: "danger", content: apiData.message }) %>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table align-middle events-table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Start</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (!apiData.events || apiData.events.length === 0) { %>
                                <tr><td colspan="5" class="text-center text-muted py-4">No events found.</td></tr>
                            <% } else { %>
                                <% apiData.events.forEach(ev => {
                                    const statusColors = {
                                        draft:'secondary', pending_review:'warning', approved:'info',
                                        published:'success', rejected:'danger', cancelled:'purple', archived:'dark'
                                    };
                                    const badgeClass = statusColors[ev.status] || 'secondary';
                                %>
                                <tr>
                                    <td data-label="Title">
                                        <strong><a href="/dashboard/events/view?eventId=<%= ev.eventId %>"><%= ev.title %></a></strong>
                                        <% if (ev.featured) { %><span class="badge bg-warning text-dark ms-1"><i class="fas fa-star fa-fw"></i></span><% } %>
                                        <% if (ev.templateId) { %><small class="text-muted d-block">From template</small><% } %>
                                    </td>
                                    <td data-label="Type"><span class="badge bg-secondary"><%= ev.eventType %></span></td>
                                    <td data-label="Status">
                                        <span class="badge bg-<%= badgeClass %> <%= badgeClass === 'warning' || badgeClass === 'info' ? 'text-dark' : '' %>">
                                            <%= ev.status.replace(/_/g,' ') %>
                                        </span>
                                    </td>
                                    <td data-label="Start">
                                        <small class="js-datetime" data-iso="<%= ev.startAt %>" data-fallback="—"></small>
                                    </td>
                                    <td data-label="Actions">
                                        <div class="d-flex flex-wrap gap-1">
                                            <a href="/dashboard/events/view?eventId=<%= ev.eventId %>" class="btn btn-xs btn-outline-secondary">View</a>
                                            <% if (['draft','rejected'].includes(ev.status)) { %>
                                                <a href="/dashboard/events/edit?eventId=<%= ev.eventId %>" class="btn btn-xs btn-warning">Edit</a>
                                            <% } %>
                                            <% if (ev.status === 'published') { %>
                                                <a href="/dashboard/events/edit?eventId=<%= ev.eventId %>" class="btn btn-xs btn-warning">Edit Live</a>
                                                <a href="/events/<%= ev.slug %>" target="_blank" class="btn btn-xs btn-outline-success">Public</a>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                <small class="text-muted">Showing <%= apiData.events ? apiData.events.length : 0 %> of <%= apiData.total || 0 %> events</small>
            <% } %>
        </main>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>

<style>
.btn-xs { padding: 0.15rem 0.4rem; font-size: 0.75rem; }
@media (max-width: 768px) {
    .events-table thead { display: none; }
    .events-table tr { display:block; border:1px solid #e6e6e6; border-radius:12px; padding:12px; margin-bottom:12px; }
    .events-table td { display:flex; justify-content:space-between; align-items:flex-start; gap:12px; border:none; padding:6px 0; font-size:0.9rem; }
    .events-table td::before { content: attr(data-label); font-weight:600; color:#5f6b7a; min-width:90px; }
}
</style>
<script>
document.querySelectorAll('.js-datetime').forEach(el => {
    const d = el.dataset.iso ? new Date(el.dataset.iso) : null;
    el.textContent = d && !isNaN(d) ? d.toLocaleString() : (el.dataset.fallback || '');
});
</script>
