<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Schedule announcements and Discord embeds."
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../modules/dashboard/dashboard-header.ejs") %>

<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-3">
            <%- include("../../modules/dashboard/dashboard-sidebar.ejs") %>
        </div>
        <main class="col-lg-9">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Scheduler</h1>
            </div>

            <% if (req.cookies.alertType) { %>
                <%- include("../../partials/alert.ejs", {
                  alertType: req.cookies.alertType,
                  content: req.cookies.alertContent
                }) %>
            <% } %>

            <% const channelMap = Object.fromEntries(discordChannels.map((channel) => [channel.id, channel.name])); %>
            <% const channelOptions = [
                {
                    optionName: "Select a Channel",
                    optionValue: "null",
                    selected: true,
                    disabled: true
                },
                ...discordChannels.map((channel) => ({
                    optionName: `#${channel.name}`,
                    optionValue: channel.id,
                    selected: false,
                    disabled: false
                }))
            ]; %>

            <ul class="nav nav-tabs" id="schedulerTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="announcements-tab" data-bs-toggle="tab" data-bs-target="#announcements-pane" type="button" role="tab" aria-controls="announcements-pane" aria-selected="true">Announcements</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="discord-tab" data-bs-toggle="tab" data-bs-target="#discord-pane" type="button" role="tab" aria-controls="discord-pane" aria-selected="false">Discord Embeds</button>
                </li>
            </ul>

            <div class="tab-content pt-4">
                <div class="tab-pane fade show active" id="announcements-pane" role="tabpanel" aria-labelledby="announcements-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Temporary Announcements</h5>
                        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#announcementWizardModal">
                            <i class="fas fa-calendar-plus"></i> Schedule Announcement
                        </button>
                    </div>

                    <% const scheduledAnnouncements = announcementsData.success ? announcementsData.data.filter((announcement) => announcement.startDate || announcement.endDate) : []; %>
                    <% if (!announcementsData.success || scheduledAnnouncements.length === 0) { %>
                        <p class="text-muted mb-0">No temporary announcements scheduled.</p>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Type</th>
                                        <th>Schedule</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% scheduledAnnouncements.forEach((announcement) => { %>
                                        <tr>
                                            <td><span class="badge text-bg-primary"><%= announcement.announcementType %></span></td>
                                            <td>
                                                <small>
                                                    <span class="js-datetime" data-iso="<%= announcement.startDate || '' %>" data-fallback="Now"></span>
                                                    →
                                                    <span class="js-datetime" data-iso="<%= announcement.endDate || '' %>" data-fallback="No end"></span>
                                                </small>
                                            </td>
                                            <td>
                                                <% if (announcement.enabled === 1) { %>
                                                    <span class="badge text-bg-success">Enabled</span>
                                                <% } else { %>
                                                    <span class="badge text-bg-secondary">Disabled</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>

                <div class="tab-pane fade" id="discord-pane" role="tabpanel" aria-labelledby="discord-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Scheduled Discord Embeds</h5>
                        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#discordWizardModal">
                            <i class="fab fa-discord"></i> Schedule Discord Embed
                        </button>
                    </div>

                    <% if (!scheduledMessages.success) { %>
                        <p class="text-muted mb-0">No scheduled Discord messages found.</p>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Channel</th>
                                        <th>Broadcast</th>
                                        <th>Author</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% scheduledMessages.data.forEach((message) => { %>
                                        <tr>
                                            <td>#<%= channelMap[message.channelId] || message.channelId %></td>
                                            <td>
                                                <small class="js-datetime" data-iso="<%= message.scheduledFor %>" data-fallback=""></small>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <% if (message.profilePictureUrl) { %>
                                                        <img src="<%= message.profilePictureUrl %>" alt="<%= message.username || 'User' %>" class="rounded-circle" width="28" height="28">
                                                    <% } else { %>
                                                        <div class="rounded-circle bg-secondary" style="width: 28px; height: 28px;"></div>
                                                    <% } %>
                                                    <span><%= message.username || "Unknown" %></span>
                                                </div>
                                            </td>
                                            <td><span class="badge text-bg-secondary"><%= message.status %></span></td>
                                            <td>
                                                <form action="<%= process.env.siteAddress %>/redirect/scheduler/discord/delete" method="post">
                                                    <input type="hidden" name="scheduleId" value="<%= message.scheduleId %>">
                                                    <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>
</div>

<div class="modal fade" id="announcementWizardModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Schedule Announcement</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="announcementWizardForm" method="post" action="<%= process.env.siteAddress %>/redirect/announcement/create">
                    <input type="hidden" name="timezoneOffset" value="">
                    <div class="wizard-step" data-step="1">
                        <div class="mb-3">
                            <label for="announcementType">Announcement Type</label>
                            <%- include("../../partials/form/inputSelect.ejs", {
                                elementName: "announcementType",
                                elementValue: "null",
                                required: true,
                                optionElements: [
                                    {
                                        optionName: "Select a Type",
                                        optionValue: "null",
                                        selected: true,
                                        disabled: true
                                    },
                                    {
                                        optionName: "Server Ping MOTD",
                                        optionValue: "motd",
                                        selected: false,
                                        disabled: false
                                    },
                                    {
                                        optionName: "In-Game Tip",
                                        optionValue: "tip",
                                        selected: false,
                                        disabled: false
                                    },
                                    {
                                        optionName: "Website Banner",
                                        optionValue: "web",
                                        selected: false,
                                        disabled: false
                                    },
                                    {
                                        optionName: "Website Popup Announcement",
                                        optionValue: "popup",
                                        selected: false,
                                        disabled: false
                                    }
                                ]
                            }) %>
                        </div>

                        <div class="mb-3" data-announcement-field="body">
                            <label for="body">Announcement Text</label>
                            <%- include("../../partials/form/inputTextArea.ejs", {
                                elementName: "body",
                                elementValue: null,
                                required: false
                            }) %>
                        </div>

                        <div class="mb-3" data-announcement-field="colourMessageFormat">
                            <label for="colourMessageFormat">Colour Message Format</label>
                            <%- include("../../partials/form/inputTextArea.ejs", {
                                elementName: "colourMessageFormat",
                                elementValue: null,
                                required: false
                            }) %>
                        </div>

                        <div class="mb-3" data-announcement-field="link">
                            <label for="link">Announcement Link</label>
                            <%- include("../../partials/form/inputText.ejs", {
                                elementName: "link",
                                elementValue: null,
                                required: false
                            }) %>
                        </div>

                        <div class="mb-3" data-announcement-field="popupButtonText">
                            <label for="popupButtonText">Popup Button Text</label>
                            <%- include("../../partials/form/inputText.ejs", {
                                elementName: "popupButtonText",
                                elementValue: null,
                                required: false
                            }) %>
                            <small class="text-muted">Optional label for popup call-to-action button.</small>
                        </div>

                        <div class="mb-3" data-announcement-field="popupImageUrl">
                            <label for="popupImageUrl">Popup Image URL</label>
                            <%- include("../../partials/form/inputText.ejs", {
                                elementName: "popupImageUrl",
                                elementValue: null,
                                required: false
                            }) %>
                            <small class="text-muted">Optional banner image for popup announcements.</small>
                        </div>
                    </div>

                    <div class="wizard-step d-none" data-step="2">
                        <div class="mb-3">
                            <label for="enabled">Announcement Visibility</label>
                            <%- include("../../partials/form/inputSelect.ejs", {
                                elementName: "enabled",
                                elementValue: "1",
                                required: true,
                                optionElements: [
                                    {
                                        optionName: "Enabled",
                                        optionValue: "1",
                                        selected: true,
                                        disabled: false
                                    },
                                    {
                                        optionName: "Disabled",
                                        optionValue: "0",
                                        selected: false,
                                        disabled: false
                                    }
                                ]
                            }) %>
                        </div>

                        <div class="row">
                            <div class="mb-3 col">
                                <label for="startDate">Start Date</label>
                                <%- include("../../partials/form/inputDateTime.ejs", {
                                    elementName: "startDate",
                                    elementValue: null,
                                    required: false
                                }) %>
                            </div>

                            <div class="mb-3 col">
                                <label for="endDate">End Date</label>
                                <%- include("../../partials/form/inputDateTime.ejs", {
                                    elementName: "endDate",
                                    elementValue: null,
                                    required: false
                                }) %>
                            </div>
                        </div>
                        <small class="text-muted">All times are in your local timezone.</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary wizard-back" data-target="announcement">Back</button>
                <button type="button" class="btn btn-primary wizard-next" data-target="announcement">Next</button>
                <button type="submit" form="announcementWizardForm" class="btn btn-success d-none wizard-submit">Schedule</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="discordWizardModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Schedule Discord Embed</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="discordWizardForm" method="post" action="<%= process.env.siteAddress %>/redirect/scheduler/discord/create">
                    <input type="hidden" name="timezoneOffset" value="">
                    <div class="wizard-step" data-step="1">
                        <div class="mb-3">
                            <label for="channelId">Channel</label>
                            <%- include("../../partials/form/inputSelect.ejs", {
                                elementName: "channelId",
                                elementValue: "null",
                                required: true,
                                optionElements: channelOptions
                            }) %>
                        </div>

                        <div class="mb-3">
                            <label for="embedTitle">Embed Title</label>
                            <%- include("../../partials/form/inputText.ejs", {
                                elementName: "embedTitle",
                                elementValue: null,
                                required: false
                            }) %>
                        </div>

                        <div class="mb-3">
                            <label for="embedDescription">Embed Description</label>
                            <%- include("../../partials/summerNoteEditor.ejs", {
                                editorElementName: "embedDescriptionEditor",
                                editorPOSTElementName: "embedDescription",
                                editorElementText: ""
                            }) %>
                        </div>

                        <div class="mb-3">
                            <label for="embedColor">Embed Color (Hex)</label>
                            <input type="color" class="form-control form-control-color" name="embedColor" value="#5865f2">
                        </div>
                    </div>

                    <div class="wizard-step d-none" data-step="2">
                        <div class="mb-3">
                            <label for="scheduledFor">Send At</label>
                            <%- include("../../partials/form/inputDateTime.ejs", {
                                elementName: "scheduledFor",
                                elementValue: null,
                                required: true
                            }) %>
                        </div>
                        <small class="text-muted">All times are in your local timezone.</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary wizard-back" data-target="discord">Back</button>
                <button type="button" class="btn btn-primary wizard-next" data-target="discord">Next</button>
                <button type="submit" form="discordWizardForm" class="btn btn-success d-none wizard-submit">Schedule</button>
            </div>
        </div>
    </div>
</div>

<script>
    const setupWizard = (modalId, onStepReset) => {
        const modal = document.getElementById(modalId);
        if (!modal) return;

        const steps = modal.querySelectorAll(".wizard-step");
        const nextButton = modal.querySelector(".wizard-next");
        const backButton = modal.querySelector(".wizard-back");
        const submitButton = modal.querySelector(".wizard-submit");
        let currentStep = 0;

        const renderStep = () => {
            steps.forEach((step, index) => {
                step.classList.toggle("d-none", index !== currentStep);
            });

            backButton.disabled = currentStep === 0;
            nextButton.classList.toggle("d-none", currentStep === steps.length - 1);
            submitButton.classList.toggle("d-none", currentStep !== steps.length - 1);
        };

        nextButton.addEventListener("click", () => {
            if (currentStep < steps.length - 1) {
                currentStep += 1;
                renderStep();
            }
        });

        backButton.addEventListener("click", () => {
            if (currentStep > 0) {
                currentStep -= 1;
                renderStep();
            }
        });

        modal.addEventListener("hidden.bs.modal", () => {
            currentStep = 0;
            renderStep();
            const form = modal.querySelector("form");
            if (form) {
                form.reset();
            }
            if (onStepReset) {
                onStepReset();
            }
            applyDateInputMinimums();
            updateTimezoneOffsets();
        });

        renderStep();
    };

    setupWizard("announcementWizardModal", () => {
        updateAnnouncementWizardFields();
        applyDateInputMinimums();
        updateTimezoneOffsets();
    });
    setupWizard("discordWizardModal");

    const announcementTypeSelect = document.querySelector("#announcementWizardForm select[name='announcementType']");
    const announcementFieldGroups = document.querySelectorAll("#announcementWizardForm [data-announcement-field]");

    const updateAnnouncementWizardFields = () => {
        const type = announcementTypeSelect?.value || "";

        announcementFieldGroups.forEach((group) => {
            const field = group.dataset.announcementField;
            let visible = true;

            if (field === "popupButtonText" || field === "popupImageUrl") {
                visible = type === "popup";
            }

            if (field === "colourMessageFormat") {
                visible = type === "motd" || type === "tip";
            }

            if (field === "link") {
                visible = type === "web" || type === "popup";
            }

            group.classList.toggle("d-none", !visible);
        });
    };

    if (announcementTypeSelect) {
        announcementTypeSelect.addEventListener("change", updateAnnouncementWizardFields);
        updateAnnouncementWizardFields();
    }

    const applyDateInputMinimums = () => {
        const now = new Date();
        const offset = now.getTimezoneOffset();
        const local = new Date(now.getTime() - offset * 60000).toISOString().slice(0, 16);
        document.querySelectorAll("#announcementWizardForm input[type='datetime-local'], #discordWizardForm input[type='datetime-local']").forEach((input) => {
            input.min = local;
        });
    };

    const updateTimezoneOffsets = () => {
        const offset = String(new Date().getTimezoneOffset());
        document.querySelectorAll("input[name='timezoneOffset']").forEach((input) => {
            input.value = offset;
        });
    };

    applyDateInputMinimums();
    updateTimezoneOffsets();

    const parseDateValue = (value) => {
        if (!value) return null;
        const normalized = value.includes(" ") ? value.replace(" ", "T") : value;
        const withTimezone = normalized.endsWith("Z") ? normalized : `${normalized}Z`;
        const date = new Date(withTimezone);
        if (Number.isNaN(date.getTime())) {
            return null;
        }
        return date;
    };

    document.querySelectorAll(".js-datetime").forEach((element) => {
        const isoValue = element.dataset.iso;
        const date = parseDateValue(isoValue);
        if (!date) {
            element.textContent = element.dataset.fallback || "";
            return;
        }

        element.textContent = date.toLocaleString();
    });
</script>

<%- include("../../modules/footer.ejs") %>
