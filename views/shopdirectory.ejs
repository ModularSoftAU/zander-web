<%- include("modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "The Shop Directory provides a comprehensive listing of available shops, showcasing items for sale, their prices, stock levels, and the shop owners' details to help you find what you're looking for quickly and easily."
}) %>

<%- include("modules/navigationBar.ejs") %>

<%- include("partials/miniHeader.ejs", {
  headerTitle: "Shop Directory",
  backgroundImage: globalImage
}) %>

<style>
  #shopTable {
    width: 100% !important;
  }
  #shopTable thead th {
    background-color: #2f508c;
    color: #fff;
    font-weight: 600;
    border-bottom: 2px solid #1c2f53;
    padding: 12px 16px;
    white-space: nowrap;
  }
  #shopTable tbody td {
    padding: 10px 16px;
    vertical-align: middle;
  }
  #shopTable tbody tr:hover {
    background-color: rgba(47, 80, 140, 0.05);
  }
  .shop-item-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
    margin-right: 8px;
    vertical-align: middle;
    border-radius: 4px;
    background: #f8f9fa;
  }
  .shop-owner-img {
    width: 24px;
    height: 24px;
    object-fit: cover;
    margin-right: 6px;
    vertical-align: middle;
    border-radius: 50%;
  }
  .shop-location {
    font-family: monospace;
    font-size: 0.85rem;
    color: #555;
  }
  .shop-price {
    font-weight: 600;
    color: #2f508c;
  }
  .shop-stock-out {
    color: #dc3545;
    font-weight: 600;
  }
  .shop-stock-in {
    color: #198754;
    font-weight: 600;
  }
  #shopLoading {
    text-align: center;
    padding: 60px 20px;
  }
  #shopLoading .spinner-border {
    width: 3rem;
    height: 3rem;
    color: #2f508c;
  }
  #shopError {
    display: none;
  }

  /* DataTables Bootstrap overrides */
  .dataTables_wrapper .dataTables_filter input {
    border: 1px solid #ced4da;
    border-radius: 6px;
    padding: 6px 12px;
    margin-left: 8px;
  }
  .dataTables_wrapper .dataTables_length select {
    border: 1px solid #ced4da;
    border-radius: 6px;
    padding: 4px 8px;
  }
  .dataTables_wrapper .dataTables_info {
    color: #6F8BA4;
    font-size: 0.9rem;
    padding-top: 12px;
  }
  .dataTables_wrapper .dataTables_paginate .paginate_button {
    border-radius: 4px !important;
    margin: 0 2px;
  }
  .dataTables_wrapper .dataTables_paginate .paginate_button.current {
    background: #2f508c !important;
    color: #fff !important;
    border-color: #2f508c !important;
  }
  .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
    background: #1c2f53 !important;
    color: #fff !important;
    border-color: #1c2f53 !important;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    #shopTable thead th,
    #shopTable tbody td {
      padding: 8px 10px;
      font-size: 0.85rem;
    }
    .shop-item-img {
      width: 24px;
      height: 24px;
    }
    .shop-owner-img {
      width: 20px;
      height: 20px;
    }
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_length {
      text-align: left !important;
      margin-bottom: 10px;
    }
  }
</style>

<section class="section">
  <div class="container">
    <div class="row mb-4">
      <div class="col-12">
        <p class="text-muted">Browse all available shops to find items, compare prices, and locate shop owners across the server.</p>
      </div>
    </div>

    <!-- Loading State -->
    <div id="shopLoading">
      <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
      <p class="text-muted mt-3">Loading shop directory...</p>
    </div>

    <!-- Error State -->
    <div id="shopError" class="alert alert-danger" role="alert">
      <strong>Error:</strong> <span id="shopErrorMessage">Failed to load shop data. Please try again later.</span>
    </div>

    <!-- Table (hidden until data loads) -->
    <div id="shopTableWrapper" style="display: none;">
      <div class="table-responsive">
        <table id="shopTable" class="table table-striped table-hover">
          <thead>
            <tr>
              <th>Item</th>
              <th>Shop Owner</th>
              <th>Amount</th>
              <th>Price</th>
              <th>Stock</th>
              <th>Location</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    $(document).ready(function() {
      fetch('/api/shop/get', {
        headers: { 'x-access-token': '<%= process.env.apiKey %>' }
      })
      .then(function(response) { return response.json(); })
      .then(function(data) {
        $('#shopLoading').hide();

        if (!data.success || !data.data || !data.data.length) {
          $('#shopError').show();
          $('#shopErrorMessage').text(data.message || 'No shops are currently available.');
          return;
        }

        var tbody = $('#shopTable tbody');
        data.data.forEach(function(shop) {
          var itemImg = shop.itemData && shop.itemData.image
            ? '<img src="' + $('<span>').text(shop.itemData.image).html() + '" alt="" class="shop-item-img">'
            : '';
          var itemName = shop.itemData && shop.itemData.displayName
            ? $('<span>').text(shop.itemData.displayName).html()
            : $('<span>').text(shop.item).html();

          var ownerImg = shop.userData && shop.userData.profilePicture
            ? '<img src="' + $('<span>').text(shop.userData.profilePicture).html() + '" alt="" class="shop-owner-img">'
            : '';
          var ownerName = shop.userData && shop.userData.username
            ? shop.userData.username
            : 'Unknown';
          var ownerLink = shop.userData && shop.userData.username
            ? '<a href="/profile/' + encodeURIComponent(ownerName) + '">' + $('<span>').text(ownerName).html() + '</a>'
            : $('<span>').text(ownerName).html();

          var stockClass = shop.stock <= 0 ? 'shop-stock-out' : 'shop-stock-in';
          var stockText = shop.stock < 0 ? 'Buying' : (shop.stock === 0 ? 'Out of Stock' : shop.stock);

          var row = '<tr>' +
            '<td>' + itemImg + ' ' + itemName + '</td>' +
            '<td>' + ownerImg + ' ' + ownerLink + '</td>' +
            '<td><code>' + $('<span>').text(shop.amount).html() + '</code></td>' +
            '<td class="shop-price"><code>' + $('<span>').text(shop.price).html() + '</code></td>' +
            '<td class="' + stockClass + '">' + $('<span>').text(stockText).html() + '</td>' +
            '<td class="shop-location"><code>' + $('<span>').text(shop.x + ', ' + shop.y + ', ' + shop.z).html() + '</code></td>' +
            '</tr>';
          tbody.append(row);
        });

        $('#shopTableWrapper').show();
        $('#shopTable').DataTable({
          paging: true,
          searching: true,
          ordering: true,
          info: true,
          pageLength: 25,
          order: [[0, 'asc']],
          language: {
            search: "Search shops:",
            lengthMenu: "Show _MENU_ shops per page",
            info: "Showing _START_ to _END_ of _TOTAL_ shops",
            emptyTable: "No shops available",
            zeroRecords: "No matching shops found"
          }
        });
      })
      .catch(function(err) {
        $('#shopLoading').hide();
        $('#shopError').show();
        console.error('Failed to load shop directory:', err);
      });
    });
  </script>
</section>

<%- include("modules/footer.ejs") %>
