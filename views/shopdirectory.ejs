<%- include("modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "The Shop Directory highlights every community shop with clear pricing, stock and owner information so you can jump straight into the world of trading.",
}) %>

<%- include("modules/navigationBar.ejs") %>

<%- include("partials/miniHeader.ejs", {
  headerTitle: "Shop Directory",
  backgroundImage: globalImage
}) %>

<section class="section section-shop-directory" data-page="shop-directory">
  <div class="container">
    <div class="shop-directory-hero text-center">
      <h2 class="h3">Explore every shop in one place</h2>
      <p class="shop-directory-subtitle mb-0">Browse the marketplace, compare prices, and head straight to the owners who stock what you need.</p>
    </div>

    <div class="shop-directory-controls" role="region" aria-label="Shop directory controls">
      <label class="shop-directory-search" for="shopSearch">
        <span class="shop-directory-search-label">Search</span>
        <input
          type="search"
          id="shopSearch"
          class="form-control"
          placeholder="Search by item or owner"
          autocomplete="off"
          spellcheck="false"
          enterkeyhint="search"
        />
      </label>
      <button type="button" class="btn btn-outline-primary shop-directory-refresh" data-shop-refresh>
        Refresh
      </button>
    </div>

    <p class="shop-directory-status" id="shopStatus" role="status" aria-live="polite"></p>

    <div class="shop-directory-surface" data-shop-surface>
      <div class="shop-directory-loader" data-shop-loader role="status" aria-live="polite">
        <div class="shop-directory-spinner" aria-hidden="true"></div>
        <p class="mb-0">Loading shop listings…</p>
      </div>

      <ul class="shop-directory-list" data-shop-list aria-live="polite" aria-busy="true"></ul>

      <button type="button" class="btn btn-outline-primary shop-directory-retry" data-shop-retry hidden>
        Try again
      </button>
    </div>
  </div>
</section>

<template id="shop-card-template">
  <li class="shop-card">
    <header class="shop-card-top">
      <div class="shop-card-item">
        <span class="shop-card-label">Item</span>
        <div class="shop-card-item-details">
          <img class="shop-card-item-image" data-shop-item-image src="/images/meta-siteLogo.png" alt="" loading="lazy" />
          <p class="shop-card-item-name" data-shop-item-name>Unknown item</p>
        </div>
      </div>
      <div class="shop-card-owner">
        <span class="shop-card-label">Owner</span>
        <div class="shop-card-owner-details">
          <img class="shop-card-owner-avatar" data-shop-owner-avatar src="/images/meta-siteLogo.png" alt="" loading="lazy" />
          <a class="shop-card-owner-link" data-shop-owner-link href="#">Owner</a>
          <span class="shop-card-owner-text" data-shop-owner-text hidden>Owner</span>
        </div>
      </div>
    </header>

    <dl class="shop-card-stats">
      <div class="shop-card-stat">
        <dt>Price</dt>
        <dd data-shop-item-price>—</dd>
      </div>
      <div class="shop-card-stat">
        <dt>Amount</dt>
        <dd data-shop-item-amount>—</dd>
      </div>
      <div class="shop-card-stat">
        <dt>Stock</dt>
        <dd data-shop-item-stock>—</dd>
      </div>
    </dl>

    <footer class="shop-card-footer">
      <span class="shop-card-label">Location</span>
      <code class="shop-card-location" data-shop-item-location>N/A</code>
    </footer>
  </li>
</template>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const listEl = document.querySelector('[data-shop-list]');
    const loaderEl = document.querySelector('[data-shop-loader]');
    const retryButton = document.querySelector('[data-shop-retry]');
    const refreshButton = document.querySelector('[data-shop-refresh]');
    const searchInput = document.getElementById('shopSearch');
    const statusEl = document.getElementById('shopStatus');
    const template = document.getElementById('shop-card-template');

    if (!listEl || !loaderEl || !retryButton || !refreshButton || !searchInput || !statusEl || !template) {
      console.error('Shop directory markup is incomplete.');
      return;
    }

    const DEFAULT_STATUS = 'Use the search box to quickly narrow down the shops shown below.';
    const FALLBACK_IMAGE = '/images/meta-siteLogo.png';
    let controller = null;
    let shops = [];

    function setStatus(message, tone = 'default') {
      statusEl.textContent = message;
      statusEl.classList.toggle('shop-directory-status--error', tone === 'error');
    }

    function toggleLoader(visible, message = 'Loading shop listings…') {
      const statusText = loaderEl.querySelector('p');
      if (statusText) {
        statusText.textContent = message;
      }

      loaderEl.hidden = !visible;
      listEl.setAttribute('aria-busy', visible ? 'true' : 'false');
    }

    function toggleRetry(show) {
      retryButton.hidden = !show;
      retryButton.disabled = !show;
    }

    function formatValue(value) {
      if (value === null || value === undefined) {
        return '—';
      }

      if (typeof value === 'number') {
        return value.toLocaleString();
      }

      if (typeof value === 'string' && value.trim().length === 0) {
        return '—';
      }

      return String(value);
    }

    function buildLocation(shop) {
      const coordinates = [shop?.x, shop?.y, shop?.z].filter((coord) => coord !== null && coord !== undefined);
      if (!coordinates.length) {
        return 'N/A';
      }

      return coordinates.map((coord) => {
        return typeof coord === 'number' ? coord.toLocaleString() : coord;
      }).join(', ');
    }

    function resolveImageUrl(url) {
      if (!url || typeof url !== 'string') {
        return FALLBACK_IMAGE;
      }

      return url;
    }

    function normalisePayload(payload) {
      if (Array.isArray(payload)) {
        return payload;
      }

      if (payload && Array.isArray(payload.data)) {
        return payload.data;
      }

      if (payload && Array.isArray(payload.shops)) {
        return payload.shops;
      }

      return [];
    }

    function createCard(shop) {
      const fragment = template.content.cloneNode(true);
      const itemImageEl = fragment.querySelector('[data-shop-item-image]');
      const itemNameEl = fragment.querySelector('[data-shop-item-name]');
      const ownerAvatarEl = fragment.querySelector('[data-shop-owner-avatar]');
      const ownerLinkEl = fragment.querySelector('[data-shop-owner-link]');
      const ownerTextEl = fragment.querySelector('[data-shop-owner-text]');
      const priceEl = fragment.querySelector('[data-shop-item-price]');
      const amountEl = fragment.querySelector('[data-shop-item-amount]');
      const stockEl = fragment.querySelector('[data-shop-item-stock]');
      const locationEl = fragment.querySelector('[data-shop-item-location]');

      const itemName = shop?.itemData?.displayName || shop?.itemName || 'Unknown item';
      const itemImage = resolveImageUrl(shop?.itemData?.image || shop?.itemImage);
      const ownerUsername = shop?.userData?.username || shop?.ownerName || '';
      const ownerAvatar = resolveImageUrl(shop?.userData?.profilePicture || shop?.ownerAvatar);

      if (itemImageEl) {
        itemImageEl.src = itemImage;
        itemImageEl.alt = itemName;
      }

      if (itemNameEl) {
        itemNameEl.textContent = itemName;
      }

      if (ownerAvatarEl) {
        ownerAvatarEl.src = ownerAvatar;
        ownerAvatarEl.alt = ownerUsername || 'Unknown owner';
      }

      if (ownerUsername && ownerLinkEl) {
        ownerLinkEl.textContent = ownerUsername;
        ownerLinkEl.href = `/profile/${encodeURIComponent(ownerUsername)}`;
        ownerLinkEl.hidden = false;
        if (ownerTextEl) {
          ownerTextEl.hidden = true;
        }
      } else if (ownerTextEl) {
        ownerTextEl.textContent = ownerUsername || 'Unknown owner';
        ownerTextEl.hidden = false;
        if (ownerLinkEl) {
          ownerLinkEl.hidden = true;
        }
      }

      if (priceEl) {
        priceEl.textContent = formatValue(shop?.price);
      }

      if (amountEl) {
        amountEl.textContent = formatValue(shop?.amount);
      }

      if (stockEl) {
        stockEl.textContent = formatValue(shop?.stock);
      }

      if (locationEl) {
        locationEl.textContent = buildLocation(shop);
      }

      return fragment;
    }

    function renderList(items) {
      const fragment = document.createDocumentFragment();
      items.forEach((shop) => {
        fragment.appendChild(createCard(shop));
      });

      listEl.innerHTML = '';
      listEl.appendChild(fragment);
      listEl.dataset.empty = items.length === 0 ? 'true' : 'false';
    }

    function applyFilter() {
      const query = searchInput.value.trim().toLowerCase();
      let filtered = shops;

      if (query) {
        filtered = shops.filter((shop) => {
          const itemName = (shop?.itemData?.displayName || shop?.itemName || '').toLowerCase();
          const ownerName = (shop?.userData?.username || shop?.ownerName || '').toLowerCase();
          return itemName.includes(query) || ownerName.includes(query);
        });
      }

      renderList(filtered);

      if (!shops.length) {
        setStatus('No shops are available right now. Please check back later.', 'default');
        return;
      }

      if (!filtered.length) {
        setStatus('No shops match your search just yet. Try a different item or owner name.', 'default');
        return;
      }

      if (!query && filtered.length === shops.length) {
        const summary = `${shops.length.toLocaleString()} shops loaded. ${DEFAULT_STATUS}`;
        setStatus(summary, 'default');
        return;
      }

      const summary = filtered.length === shops.length
        ? `${shops.length.toLocaleString()} shops loaded.`
        : `Showing ${filtered.length.toLocaleString()} of ${shops.length.toLocaleString()} shops.`;

      setStatus(summary, 'default');
    }

    async function loadShops({ showLoader = true, refresh = false } = {}) {
      if (controller) {
        controller.abort();
      }

      controller = new AbortController();
      toggleRetry(false);
      setStatus(refresh ? 'Refreshing the shop directory…' : 'Fetching the latest shop data…', 'default');

      if (showLoader) {
        toggleLoader(true, refresh ? 'Refreshing shop listings…' : 'Loading shop listings…');
      }

      try {
        const fetchUrl = refresh ? '/shopdirectory/data?refresh=true' : '/shopdirectory/data';
        const response = await fetch(fetchUrl, {
          method: 'GET',
          headers: { 'Accept': 'application/json' },
          signal: controller.signal,
        });

        if (!response.ok) {
          let errorMessage = `Unable to load shop directory (status ${response.status}).`;
          try {
            const errorPayload = await response.json();
            if (errorPayload && typeof errorPayload.message === 'string') {
              errorMessage = errorPayload.message;
            }
          } catch (error) {
            // Ignore parsing errors for non-JSON responses.
          }

          throw new Error(errorMessage);
        }

        const payload = await response.json();
        shops = normalisePayload(payload);

        if (!Array.isArray(shops)) {
          shops = [];
        }

        if (!shops.length) {
          setStatus('No shops are available right now. Please check back later.', 'default');
        } else {
          setStatus(DEFAULT_STATUS, 'default');
        }

        applyFilter();
      } catch (error) {
        if (error.name === 'AbortError') {
          return;
        }

        console.error('Failed to load shop directory', error);
        setStatus(error.message || 'We could not load the shop directory. Please try again shortly.', 'error');
        listEl.innerHTML = '';
        listEl.dataset.empty = 'true';
        toggleRetry(true);
      } finally {
        toggleLoader(false);
      }
    }

    retryButton.addEventListener('click', () => {
      retryButton.disabled = true;
      loadShops({ showLoader: true, refresh: true });
    });

    refreshButton.addEventListener('click', () => {
      loadShops({ showLoader: true, refresh: true });
    });

    searchInput.addEventListener('input', () => {
      applyFilter();
    });

    loadShops({ showLoader: true });
  });
</script>

<%- include("modules/footer.ejs") %>
