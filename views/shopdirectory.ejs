<%- include("modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "The Shop Directory provides a comprehensive listing of available shops, showcasing items for sale, their prices, stock levels, and the shop owners' details to help you find what you're looking for quickly and easily."
}) %>

<%- include("modules/navigationBar.ejs") %>

<%- include("partials/miniHeader.ejs", {
  headerTitle: "Shop Directory",
  backgroundImage: globalImage
}) %>

<style>
  #shopTable {
    width: 100% !important;
  }
  #shopTable thead th {
    background-color: #2f508c;
    color: #fff;
    font-weight: 600;
    border-bottom: 2px solid #1c2f53;
    padding: 12px 16px;
    white-space: nowrap;
  }
  #shopTable tbody td {
    padding: 10px 16px;
    vertical-align: middle;
  }
  #shopTable tbody tr:hover {
    background-color: rgba(47, 80, 140, 0.05);
  }
  .shop-item-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
    margin-right: 8px;
    vertical-align: middle;
    border-radius: 4px;
    background: #f8f9fa;
  }
  .shop-owner-img {
    width: 24px;
    height: 24px;
    object-fit: cover;
    margin-right: 6px;
    vertical-align: middle;
    border-radius: 50%;
  }
  .shop-location {
    font-family: monospace;
    font-size: 0.85rem;
    color: #555;
  }
  .shop-price {
    font-weight: 600;
    color: #2f508c;
  }
  .shop-stock-out {
    color: #dc3545;
    font-weight: 600;
  }
  .shop-stock-in {
    color: #198754;
    font-weight: 600;
  }

  /* DataTables Bootstrap overrides */
  .dataTables_wrapper .dataTables_filter input {
    border: 1px solid #ced4da;
    border-radius: 6px;
    padding: 6px 12px;
    margin-left: 8px;
  }
  .dataTables_wrapper .dataTables_length select {
    border: 1px solid #ced4da;
    border-radius: 6px;
    padding: 4px 8px;
  }
  .dataTables_wrapper .dataTables_info {
    color: #6F8BA4;
    font-size: 0.9rem;
    padding-top: 12px;
  }
  .dataTables_wrapper .dataTables_paginate .paginate_button {
    border-radius: 4px !important;
    margin: 0 2px;
  }
  .dataTables_wrapper .dataTables_paginate .paginate_button.current {
    background: #2f508c !important;
    color: #fff !important;
    border-color: #2f508c !important;
  }
  .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
    background: #1c2f53 !important;
    color: #fff !important;
    border-color: #1c2f53 !important;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    #shopTable thead th,
    #shopTable tbody td {
      padding: 8px 10px;
      font-size: 0.85rem;
    }
    .shop-item-img {
      width: 24px;
      height: 24px;
    }
    .shop-owner-img {
      width: 20px;
      height: 20px;
    }
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_length {
      text-align: left !important;
      margin-bottom: 10px;
    }
  }
</style>

<section class="section">
  <div class="container">
    <div class="row mb-4">
      <div class="col-12">
        <p class="text-muted">Browse all available shops to find items, compare prices, and locate shop owners across the server.</p>
      </div>
    </div>

    <% if (!shopApiData.success || !shopApiData.data || !shopApiData.data.length) { %>
      <div class="alert alert-info" role="alert">
        <%= shopApiData.message || 'No shops are currently available.' %>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table id="shopTable" class="table table-striped table-hover">
          <thead>
            <tr>
              <th>Item</th>
              <th>Shop Owner</th>
              <th>Amount</th>
              <th>Price</th>
              <th>Stock</th>
              <th>Location</th>
            </tr>
          </thead>
          <tbody>
            <% shopApiData.data.forEach(function(shop) { %>
              <tr>
                <td>
                  <% if (shop.itemData && shop.itemData.image) { %>
                    <img src="<%= shop.itemData.image %>" alt="" class="shop-item-img">
                  <% } %>
                  <%= shop.itemData && shop.itemData.displayName ? shop.itemData.displayName : shop.item %>
                </td>
                <td>
                  <% if (shop.userData && shop.userData.profilePicture) { %>
                    <img src="<%= shop.userData.profilePicture %>" alt="" class="shop-owner-img">
                  <% } %>
                  <% if (shop.userData && shop.userData.username) { %>
                    <a href="/profile/<%= encodeURIComponent(shop.userData.username) %>"><%= shop.userData.username %></a>
                  <% } else { %>
                    Unknown
                  <% } %>
                </td>
                <td><code><%= shop.amount %></code></td>
                <td class="shop-price"><code><%= shop.price %></code></td>
                <td class="<%= shop.stock <= 0 ? 'shop-stock-out' : 'shop-stock-in' %>">
                  <%= shop.stock < 0 ? 'Buying' : (shop.stock === 0 ? 'Out of Stock' : shop.stock) %>
                </td>
                <td class="shop-location">
                  <code><%= shop.x %>, <%= shop.y %>, <%= shop.z %></code>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <script>
        $(document).ready(function() {
          $('#shopTable').DataTable({
            paging: true,
            searching: true,
            ordering: true,
            info: true,
            pageLength: 25,
            order: [[0, 'asc']],
            language: {
              search: "Search shops:",
              lengthMenu: "Show _MENU_ shops per page",
              info: "Showing _START_ to _END_ of _TOTAL_ shops",
              emptyTable: "No shops available",
              zeroRecords: "No matching shops found"
            }
          });
        });
      </script>
    <% } %>
  </div>
</section>

<%- include("modules/footer.ejs") %>
