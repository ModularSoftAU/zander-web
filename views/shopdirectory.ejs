<%- include("modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "The Shop Directory provides a comprehensive listing of available shops, showcasing items for sale, their prices, stock levels, and the shop owners' details to help you find what you're looking for quickly and easily."
}) %>

<%- include("modules/navigationBar.ejs") %>

<%- include("partials/miniHeader.ejs", {
  headerTitle: "Shop Directory",
  backgroundImage: globalImage
}) %>

<style>
  #shopTable {
    width: 100% !important;
  }
  #shopTable thead th {
    background-color: #2f508c;
    color: #fff;
    font-weight: 600;
    border-bottom: 2px solid #1c2f53;
    padding: 12px 16px;
    white-space: nowrap;
  }
  #shopTable tbody td {
    padding: 10px 16px;
    vertical-align: middle;
  }
  #shopTable tbody tr:hover {
    background-color: rgba(47, 80, 140, 0.05);
  }
  .shop-item-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
    margin-right: 8px;
    vertical-align: middle;
    border-radius: 4px;
    background: #f8f9fa;
  }
  .shop-owner-img {
    width: 24px;
    height: 24px;
    object-fit: cover;
    margin-right: 6px;
    vertical-align: middle;
    border-radius: 50%;
  }
  .shop-location {
    font-family: monospace;
    font-size: 0.85rem;
    color: #555;
  }
  .shop-price {
    font-weight: 600;
    color: #2f508c;
  }
  .shop-stock-out {
    color: #dc3545;
    font-weight: 600;
  }
  .shop-stock-in {
    color: #198754;
    font-weight: 600;
  }
  .shop-search-box {
    max-width: 500px;
  }
  .shop-search-box .input-group {
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    border-radius: 8px;
    overflow: hidden;
  }
  .shop-search-box input {
    border: 2px solid #2f508c;
    border-right: none;
    padding: 12px 16px;
    font-size: 1rem;
  }
  .shop-search-box input:focus {
    box-shadow: none;
    border-color: #2f508c;
  }
  .shop-search-box .btn {
    border: 2px solid #2f508c;
    border-left: none;
    background: #2f508c;
    color: #fff;
    padding: 12px 20px;
  }
  .shop-search-box .btn:hover {
    background: #1c2f53;
  }
  #searchHint {
    font-size: 0.85rem;
    color: #6F8BA4;
    margin-top: 6px;
  }
  #shopResults {
    min-height: 100px;
  }
  .shop-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
  }
  .shop-pagination .btn {
    min-width: 90px;
  }
  .shop-pagination .page-info {
    font-size: 0.9rem;
    color: #6F8BA4;
    margin: 0 12px;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    #shopTable thead th,
    #shopTable tbody td {
      padding: 8px 10px;
      font-size: 0.85rem;
    }
    .shop-item-img {
      width: 24px;
      height: 24px;
    }
    .shop-owner-img {
      width: 20px;
      height: 20px;
    }
  }
</style>

<section class="section">
  <div class="container">
    <div class="row mb-4">
      <div class="col-12">
        <p class="text-muted mb-3">Search for items across all available shops to compare prices, check stock levels, and find shop locations.</p>
        <div class="shop-search-box">
          <div class="input-group">
            <input type="text" id="shopSearchInput" class="form-control" placeholder="Search items (e.g. diamond, netherite, potion)..." autofocus>
            <button class="btn" type="button" id="shopSearchBtn">
              <i class="fa fa-search"></i> Search
            </button>
          </div>
          <div id="searchHint">Type at least 2 characters to search.</div>
        </div>
      </div>
    </div>

    <div id="shopResults">
      <div class="text-center text-muted py-5">
        <i class="fa fa-search fa-2x mb-3 d-block" style="opacity: 0.3;"></i>
        <p>Enter an item name above to search the shop directory.</p>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  const searchInput = document.getElementById('shopSearchInput');
  const searchBtn = document.getElementById('shopSearchBtn');
  const searchHint = document.getElementById('searchHint');
  const resultsContainer = document.getElementById('shopResults');

  let debounceTimer = null;
  let currentPage = 1;
  let currentQuery = '';

  function debounce(fn, delay) {
    return function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(fn, delay);
    };
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function renderLoading() {
    resultsContainer.innerHTML = `
      <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
        <p class="text-muted mt-2">Searching shops...</p>
      </div>`;
  }

  function renderEmpty(message) {
    resultsContainer.innerHTML = `
      <div class="alert alert-info" role="alert">
        ${escapeHtml(message || 'No shops found matching your search.')}
      </div>`;
  }

  function renderError(message) {
    resultsContainer.innerHTML = `
      <div class="alert alert-danger" role="alert">
        ${escapeHtml(message || 'An error occurred while searching. Please try again.')}
      </div>`;
  }

  function renderResults(data, pagination) {
    let html = `<div class="table-responsive">
      <table id="shopTable" class="table table-striped table-hover">
        <thead>
          <tr>
            <th>Item</th>
            <th>Shop Owner</th>
            <th>Amount</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Location</th>
          </tr>
        </thead>
        <tbody>`;

    data.forEach(function(shop) {
      const itemImg = (shop.itemData && shop.itemData.image)
        ? `<img src="${escapeHtml(shop.itemData.image)}" alt="" class="shop-item-img" onerror="this.style.display='none'">`
        : '';
      const displayName = (shop.itemData && shop.itemData.displayName)
        ? escapeHtml(shop.itemData.displayName)
        : escapeHtml(shop.item);

      const profileImg = (shop.userData && shop.userData.profilePicture)
        ? `<img src="${escapeHtml(shop.userData.profilePicture)}" alt="" class="shop-owner-img">`
        : '';
      const username = (shop.userData && shop.userData.username)
        ? `<a href="/profile/${encodeURIComponent(shop.userData.username)}">${escapeHtml(shop.userData.username)}</a>`
        : 'Unknown';

      const stockClass = shop.stock <= 0 ? 'shop-stock-out' : 'shop-stock-in';
      const stockText = shop.stock < 0 ? 'Buying' : (shop.stock === 0 ? 'Out of Stock' : shop.stock);

      html += `<tr>
        <td>${itemImg}${displayName}</td>
        <td>${profileImg}${username}</td>
        <td><code>${escapeHtml(String(shop.amount))}</code></td>
        <td class="shop-price"><code>${escapeHtml(String(shop.price))}</code></td>
        <td class="${stockClass}">${escapeHtml(String(stockText))}</td>
        <td class="shop-location"><code>${escapeHtml(String(shop.x))}, ${escapeHtml(String(shop.y))}, ${escapeHtml(String(shop.z))}</code></td>
      </tr>`;
    });

    html += '</tbody></table></div>';

    // Pagination
    if (pagination && pagination.totalPages > 1) {
      html += `<div class="shop-pagination">
        <button class="btn btn-sm btn-outline-primary" id="prevPageBtn" ${pagination.page <= 1 ? 'disabled' : ''}>
          <i class="fa fa-chevron-left"></i> Previous
        </button>
        <span class="page-info">Page ${pagination.page} of ${pagination.totalPages} (${pagination.totalResults} results)</span>
        <button class="btn btn-sm btn-outline-primary" id="nextPageBtn" ${pagination.page >= pagination.totalPages ? 'disabled' : ''}>
          Next <i class="fa fa-chevron-right"></i>
        </button>
      </div>`;
    } else if (pagination) {
      html += `<div class="text-center mt-2"><span class="text-muted" style="font-size:0.85rem;">${pagination.totalResults} result(s) found</span></div>`;
    }

    resultsContainer.innerHTML = html;

    // Bind pagination buttons
    const prevBtn = document.getElementById('prevPageBtn');
    const nextBtn = document.getElementById('nextPageBtn');
    if (prevBtn) prevBtn.addEventListener('click', function() { changePage(-1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { changePage(1); });
  }

  function changePage(delta) {
    currentPage += delta;
    if (currentPage < 1) currentPage = 1;
    fetchShops(currentQuery, currentPage);
  }

  async function fetchShops(query, page) {
    renderLoading();
    try {
      const url = `/api/shop/get?material=${encodeURIComponent(query)}&page=${page}`;
      const response = await fetch(url);
      const result = await response.json();

      if (!result.success) {
        renderEmpty(result.message);
        return;
      }

      if (!result.data || !result.data.length) {
        renderEmpty('No shops found matching your search.');
        return;
      }

      renderResults(result.data, result.pagination);
    } catch (err) {
      console.error('Shop search error:', err);
      renderError('Failed to fetch shop data. Please try again.');
    }
  }

  function doSearch() {
    const query = searchInput.value.trim();
    if (query.length < 2) {
      searchHint.textContent = 'Type at least 2 characters to search.';
      return;
    }
    searchHint.textContent = '';
    currentQuery = query;
    currentPage = 1;
    fetchShops(query, 1);
  }

  searchInput.addEventListener('input', debounce(doSearch, 400));
  searchBtn.addEventListener('click', doSearch);
  searchInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      clearTimeout(debounceTimer);
      doSearch();
    }
  });
})();
</script>

<%- include("modules/footer.ejs") %>
