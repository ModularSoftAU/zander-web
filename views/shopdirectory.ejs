<%- include("modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "The Shop Directory provides a comprehensive listing of available shops, showcasing items for sale, their prices, stock levels, and the shop owners' details to help you find what you're looking for quickly and easily."
}) %>

<%- include("modules/navigationBar.ejs") %>

<%- include("partials/miniHeader.ejs", {
  headerTitle: "Shop Directory",
  backgroundImage: globalImage
}) %>

<section class="section">
  <div class="container">
    <div class="shop-directory">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 mb-3">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="includeOutOfStock" <%= includeOutOfStock ? "checked" : "" %>>
          <label class="form-check-label" for="includeOutOfStock">Show out of stock shops</label>
        </div>
        <small class="text-muted">Toggle to include shops that currently have no stock available.</small>
      </div>
      <table id="shopTable" class="display shop-directory__table">
        <thead>
          <tr>
            <th>Item</th>
            <th>Shop Owner</th>
            <th>Amount</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Location</th>
          </tr>
        </thead>
        <tbody>
          <% (shopApiData.data || []).forEach(shop => { %>
            <tr>
              <td data-label="Item" class="shop-directory__item">
                <img src="<%= shop.itemData.image %>" alt="<%= shop.itemData.displayName %>" class="shop-directory__item-image" loading="lazy" decoding="async" width="40" height="40">
                <span class="shop-directory__item-name"><%= shop.itemData.displayName %></span>
              </td>
              <td data-label="Shop Owner" class="shop-directory__owner" data-order="<%= shop.userData.username %>">
                <img src="<%= shop.userData.profilePicture %>" alt="<%= shop.userData.username %>" class="shop-directory__owner-avatar" loading="lazy" decoding="async" width="28" height="28">
                <a href="/profile/<%= shop.userData.username %>"><%= shop.userData.username %></a>
              </td>
              <td data-label="Amount"><code><%= shop.amount %></code></td>
              <td data-label="Price"><code><%= shop.price %></code></td>
              <td data-label="Stock"><code><%= shop.stock %></code></td>
              <td data-label="Location"><code><%= shop.x %>, <%= shop.y %>, <%= shop.z %></code></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <div class="mt-3 d-flex justify-content-between align-items-center">
        <button id="loadMoreShops" class="btn btn-primary" <%= shopApiData.meta?.hasMore ? "" : "disabled" %>>Load more shops</button>
        <small id="loadMoreStatus" class="text-muted"></small>
      </div>
    </div>
  </div>

  <script>
    $(document).ready(function() {
      const tableElement = $('#shopTable');
      const shopTable = tableElement.DataTable({
        "paging": true,
        "searching": true,
        "ordering": true,
        "info": true,
        "pageLength": 25,
        "lengthMenu": [[10, 25, 50, 100], [10, 25, 50, 100]],
        "deferRender": true,
        "order": [],
        "columnDefs": [
          { "targets": [0], "orderable": false }
        ]
      });

      const meta = <%- JSON.stringify(shopApiData.meta || {}) %>;
      const loadMoreButton = document.getElementById('loadMoreShops');
      const loadMoreStatus = document.getElementById('loadMoreStatus');
      const includeOutOfStockToggle = document.getElementById('includeOutOfStock');
      let loadedCount = <%- (shopApiData.data || []).length %>;
      const pageSize = meta.limit || 50;
      let includeOutOfStock = <%= includeOutOfStock ? "true" : "false" %>;

      const setStatus = (message, isError = false) => {
        if (!loadMoreStatus) return;
        loadMoreStatus.textContent = message;
        loadMoreStatus.classList.toggle('text-danger', isError);
        loadMoreStatus.classList.toggle('text-muted', !isError);
      };

      const updateButtonState = () => {
        if (!loadMoreButton) return;
        if (meta.hasMore) {
          loadMoreButton.disabled = false;
          loadMoreButton.textContent = 'Load more shops';
        } else {
          loadMoreButton.disabled = true;
          loadMoreButton.textContent = 'All shops loaded';
        }
      };

      const createShopRow = (shop) => {
        const row = document.createElement('tr');

        const itemCell = document.createElement('td');
        itemCell.dataset.label = 'Item';
        itemCell.className = 'shop-directory__item';
        const itemImage = document.createElement('img');
        itemImage.src = shop?.itemData?.image || '';
        itemImage.alt = shop?.itemData?.displayName || 'Item';
        itemImage.className = 'shop-directory__item-image';
        itemImage.loading = 'lazy';
        itemImage.decoding = 'async';
        itemImage.width = 40;
        itemImage.height = 40;
        const itemName = document.createElement('span');
        itemName.className = 'shop-directory__item-name';
        itemName.textContent = shop?.itemData?.displayName || shop?.item || 'Unknown Item';
        itemCell.append(itemImage, itemName);

        const ownerCell = document.createElement('td');
        ownerCell.dataset.label = 'Shop Owner';
        ownerCell.className = 'shop-directory__owner';
        ownerCell.setAttribute('data-order', shop?.userData?.username || '');
        const ownerAvatar = document.createElement('img');
        ownerAvatar.src = shop?.userData?.profilePicture || '';
        ownerAvatar.alt = shop?.userData?.username || 'Owner';
        ownerAvatar.className = 'shop-directory__owner-avatar';
        ownerAvatar.loading = 'lazy';
        ownerAvatar.decoding = 'async';
        ownerAvatar.width = 28;
        ownerAvatar.height = 28;
        const ownerLink = document.createElement('a');
        ownerLink.href = `/profile/${shop?.userData?.username || ''}`;
        ownerLink.textContent = shop?.userData?.username || 'Unknown';
        ownerCell.append(ownerAvatar, ownerLink);

        const amountCell = document.createElement('td');
        amountCell.dataset.label = 'Amount';
        const amountCode = document.createElement('code');
        amountCode.textContent = shop?.amount ?? '';
        amountCell.append(amountCode);

        const priceCell = document.createElement('td');
        priceCell.dataset.label = 'Price';
        const priceCode = document.createElement('code');
        priceCode.textContent = shop?.price ?? '';
        priceCell.append(priceCode);

        const stockCell = document.createElement('td');
        stockCell.dataset.label = 'Stock';
        const stockCode = document.createElement('code');
        stockCode.textContent = shop?.stock ?? '';
        stockCell.append(stockCode);

        const locationCell = document.createElement('td');
        locationCell.dataset.label = 'Location';
        const locationCode = document.createElement('code');
        locationCode.textContent = `${shop?.x ?? ''}, ${shop?.y ?? ''}, ${shop?.z ?? ''}`;
        locationCell.append(locationCode);

        row.append(
          itemCell,
          ownerCell,
          amountCell,
          priceCell,
          stockCell,
          locationCell
        );

        return row;
      };

      const addShopsToTable = (shops) => {
        shops.forEach((shop) => {
          shopTable.row.add(createShopRow(shop));
        });
        shopTable.draw(false);
      };

      const buildQueryString = (offsetValue, limitValue) => {
        const params = new URLSearchParams({
          offset: offsetValue,
          limit: limitValue,
        });

        if (includeOutOfStock) {
          params.set('includeOutOfStock', 'true');
        }

        return params.toString();
      };

      const fetchShops = async (offsetValue, limitValue) => {
        const queryString = buildQueryString(offsetValue, limitValue);
        const response = await fetch(`/api/shop/get?${queryString}`);
        return response.json();
      };

      const resetTable = () => {
        shopTable.clear();
        shopTable.draw();
        loadedCount = 0;
      };

      const totalToShow = meta.total || loadedCount;
      setStatus(`Showing ${loadedCount} of ${totalToShow} shops.`);
      updateButtonState();

      loadMoreButton?.addEventListener('click', async () => {
        if (!meta.hasMore) return;
        loadMoreButton.disabled = true;
        loadMoreButton.textContent = 'Loading...';
        setStatus('Loading more shops...');

        try {
          const payload = await fetchShops(loadedCount, pageSize);

          if (!payload?.success) {
            throw new Error(payload?.message || 'Unable to load additional shops.');
          }

          if (!payload?.data?.length) {
            meta.hasMore = payload.meta?.hasMore ?? false;
            meta.total = payload.meta?.total ?? meta.total;
            setStatus('All shops loaded.');
            updateButtonState();
            return;
          }

          addShopsToTable(payload.data);
          loadedCount += payload.data.length;
          meta.hasMore = payload.meta?.hasMore ?? false;
          meta.total = payload.meta?.total ?? meta.total;

          setStatus(`Showing ${loadedCount} of ${meta.total || loadedCount} shops.`);
          updateButtonState();
        } catch (error) {
          console.error(error);
          setStatus('Unable to load more shops right now. Please try again.', true);
          loadMoreButton.disabled = false;
          loadMoreButton.textContent = 'Load more shops';
        }
      });

      includeOutOfStockToggle?.addEventListener('change', async (event) => {
        includeOutOfStock = event.target.checked;
        setStatus('Updating shops...');
        loadMoreButton.disabled = true;

        try {
          const payload = await fetchShops(0, pageSize);

          if (!payload?.success) {
            throw new Error(payload?.message || 'Unable to fetch shops.');
          }

          resetTable();
          addShopsToTable(payload.data || []);
          loadedCount = payload.data?.length || 0;
          meta.hasMore = payload.meta?.hasMore ?? false;
          meta.total = payload.meta?.total ?? loadedCount;
          meta.limit = payload.meta?.limit ?? pageSize;

          if (!payload?.data?.length) {
            setStatus('No shops to display with the current filters.');
            updateButtonState();
            return;
          }

          setStatus(`Showing ${loadedCount} of ${meta.total || loadedCount} shops.`);
          updateButtonState();
        } catch (error) {
          console.error(error);
          setStatus('Unable to update shop list right now. Please try again.', true);
          event.target.checked = !includeOutOfStock;
          includeOutOfStock = event.target.checked;
          updateButtonState();
        }
      });
    });
  </script>
</section>

<%- include("modules/footer.ejs") %>
