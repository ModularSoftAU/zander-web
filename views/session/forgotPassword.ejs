<%- include("../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Reset your password."
}) %>

<%- include("../modules/navigationBar.ejs") %>

<%- include("../partials/miniHeader.ejs", {
  headerTitle: "Forgot password",
  backgroundImage: globalImage
}) %>

<section class="section section-auth">
  <div class="container">
    <div class="row justify-content-center align-items-center g-5">
      <div class="col-12 col-lg-5 col-xl-4 order-2 order-lg-1">
        <% if (req.cookies.alertType) { %>
          <div class="mb-3">
            <%- include("../partials/alert.ejs", {
              alertType: req.cookies.alertType,
              content: req.cookies.alertContent
            }) %>
          </div>
        <% } %>

        <div class="card shadow-sm border-0 auth-card">
          <div class="card-body p-4 p-md-5">
            <h2 class="h4 mb-4 text-center text-lg-start">Forgot your password?</h2>
            <% if (!emailServiceConfigured) { %>
              <div class="alert alert-warning" role="alert">
                Password reset emails cannot be sent right now. Please contact an administrator for assistance.
              </div>
            <% } %>
            <form method="post" action="/forgot-password" class="row g-3">
              <div class="col-12">
                <label for="email" class="form-label">Email address</label>
                <input type="email" class="form-control" id="forgotPasswordEmail" name="email" required autocomplete="email">
                <small class="form-text text-muted">We'll send you a link to set a new password.</small>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-primary w-100" <%= emailServiceConfigured ? "" : "disabled" %>>Send reset link</button>
              </div>
            </form>
            <div class="pt-3 text-center text-lg-start">
              <small class="d-block text-muted"><a href="/login">Return to sign in</a></small>
            </div>
          </div>
        </div>
      </div>
      <div class="col-10 col-sm-8 col-lg-5 col-xl-4 order-1 order-lg-2 text-center">
        <div class="auth-illustration mx-auto">
          <img class="img-fluid floating" src="images/session/loginImage.png" alt="Forgot password illustration" draggable="false">
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../modules/footer.ejs") %>
