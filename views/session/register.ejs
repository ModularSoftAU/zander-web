<%- include("../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Register for a web account."
}) %>

<%- include("../modules/navigationBar.ejs") %>

<%- include("../partials/miniHeader.ejs", {
  headerTitle: "Register",
  backgroundImage: globalImage
}) %>

<section class="section section-auth">
  <div class="container">
    <div class="row justify-content-center align-items-center g-5">
      <div class="col-12 col-lg-5 col-xl-4 order-2 order-lg-1">
        <% if (req.cookies.alertType) { %>
          <div class="mb-3">
            <%- include("../partials/alert.ejs", {
              alertType: req.cookies.alertType,
              content: req.cookies.alertContent
            }) %>
          </div>
        <% } %>

        <div class="card shadow-sm border-0 auth-card">
          <div class="card-body p-4 p-md-5">
            <h2 class="h4 mb-4 text-center text-lg-start">Create your account</h2>
            <form method="post" action="/register" class="row g-3">
              <div class="col-12">
                <label for="username" class="form-label">Minecraft username</label>
                <input type="text" class="form-control" name="username" maxlength="16" required>
                <small class="form-text text-muted">We use your existing Minecraft account to link your web profile.</small>
              </div>
              <div class="col-12">
                <label for="email" class="form-label">Email address</label>
                <input type="email" class="form-control" name="email" required>
              </div>
              <div class="col-12 col-md-6">
                <label for="password" class="form-label">Password</label>
                <input type="password" class="form-control" name="password" minlength="8" required>
              </div>
              <div class="col-12 col-md-6">
                <label for="confirmPassword" class="form-label">Confirm password</label>
                <input type="password" class="form-control" name="confirmPassword" minlength="8" required>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-primary w-100">Create account</button>
              </div>
            </form>
            <div class="pt-3 text-center text-lg-start">
              <small class="d-block text-muted">Already have an account? <a href="/login">Sign in here</a>.</small>
            </div>
          </div>
        </div>
      </div>
      <div class="col-10 col-sm-8 col-lg-5 col-xl-4 order-1 order-lg-2 text-center">
        <div class="auth-illustration mx-auto">
          <img class="img-fluid floating" src="images/session/registerImage.png" alt="Register illustration" draggable="false">
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../modules/footer.ejs") %>
