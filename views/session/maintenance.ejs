<%- include("../modules/header.ejs", {
  pageTitle: pageTitle,
  pageDescription: "The site is temporarily unavailable."
}) %>

<%- include("../modules/navigationBar.ejs", {
  features: features
}) %>

<%- include("../partials/miniHeader.ejs", {
  headerTitle: "Down for Maintenance",
  backgroundImage: globalImage
}) %>

<section class="section">
  <div class="container">
    <div class="row">
      <div class="col-12 col-md-6" style="min-height:500px;">
        <div class="text-center">
          <img class="floating" style="margin-top:10px;" src="/images/session/errorImage.png" height="300px" draggable="false">
        </div>
      </div>
      <div class="col-12 col-md-6">
        <h3>We'll be back shortly</h3>
        <p>The site is temporarily unavailable while we perform maintenance or resolve a technical issue.</p>
        <small class="text-muted">If this continues, please reach out via <a style="color: rgb(75, 64, 224);" href="<%= config.siteConfiguration.platforms.discord %>">our Community Discord</a>.</small>
      </div>
    </div>
  </div>
</section>

<%- include("../modules/footer.ejs") %>
