<textarea id="<%= editorElementName %>" name="<%= editorPOSTElementName %>"><%= editorElementText %></textarea>

<script>
  $(document).ready(function() {
    window.emojis = window.emojis || [];
    window.emojiUrls = window.emojiUrls || {};

    function updateEmojiData(data) {
      if (!data) return;

      window.emojis = Object.keys(data);
      window.emojiUrls = data;
    }

    function fetchEmojiData(url) {
      return $.ajax({
        url: url,
        dataType: 'json',
        timeout: 5000,
      });
    }

    var hasCustomEmojiData = false;

    fetchEmojiData('https://api.github.com/emojis')
      .done(function(data) {
        if (!hasCustomEmojiData) {
          updateEmojiData(data);
        }
      })
      .fail(function() {
        console.warn('Unable to load GitHub emoji list.');
      });

    fetchEmojiData('<%= process.env.siteAddress %>/emojis')
      .done(function(data) {
        hasCustomEmojiData = true;
        updateEmojiData(data);
      })
      .fail(function() {
        console.warn('Unable to load custom emoji list.');
      });

    // ── Custom toolbar buttons ─────────────────────────────────────────────
    // The built-in 'style' dropdown is broken in Summernote 0.8.x + BS5
    // (dropdown items don't fire). Replace with explicit format buttons.
    // The quote button wraps the current block in <blockquote>.
    $.extend($.summernote.plugins, {
      formatNormal: function (ctx) {
        ctx.memo('button.formatNormal', function () {
          return $.summernote.ui.button({
            contents: 'Normal',
            tooltip: 'Normal text',
            click: function () { ctx.invoke('editor.formatBlock', 'p'); }
          }).render();
        });
      },
      formatH1: function (ctx) {
        ctx.memo('button.formatH1', function () {
          return $.summernote.ui.button({
            contents: '<b>H1</b>',
            tooltip: 'Heading 1',
            click: function () { ctx.invoke('editor.formatBlock', 'h1'); }
          }).render();
        });
      },
      formatH2: function (ctx) {
        ctx.memo('button.formatH2', function () {
          return $.summernote.ui.button({
            contents: '<b>H2</b>',
            tooltip: 'Heading 2',
            click: function () { ctx.invoke('editor.formatBlock', 'h2'); }
          }).render();
        });
      },
      formatH3: function (ctx) {
        ctx.memo('button.formatH3', function () {
          return $.summernote.ui.button({
            contents: '<b>H3</b>',
            tooltip: 'Heading 3',
            click: function () { ctx.invoke('editor.formatBlock', 'h3'); }
          }).render();
        });
      },
      quoteBlock: function (ctx) {
        ctx.memo('button.quoteBlock', function () {
          return $.summernote.ui.button({
            contents: '<i class="fa-solid fa-quote-left fa-fw"></i>',
            tooltip: 'Quote',
            click: function () { ctx.invoke('editor.formatBlock', 'blockquote'); }
          }).render();
        });
      }
    });

    $('#<%= editorElementName %>').summernote({
        height: 250,
        minHeight: null,
        maxHeight: null,
        focus: false,
        emoji: true,
        toolbar: [
          ['format', ['formatNormal', 'formatH1', 'formatH2', 'formatH3']],
          ['font', ['bold', 'italic', 'underline', 'strikethrough', 'clear']],
          ['color', ['color']],
          ['para', ['ul', 'ol', 'paragraph', 'quoteBlock']],
          ['table', ['table']],
          ['insert', ['link', 'picture', 'video']],
          ['view', ['fullscreen', 'help']]
        ],
        hint: {
            match: /:([\-+\w]+)$/,
            search: function (keyword, callback) {
            callback($.grep(emojis, function (item) {
                return item.indexOf(keyword)  === 0;
            }));
            },
            template: function (item) {
            var content = emojiUrls[item];
            return '<img src="' + content + '" width="20" /> :' + item + ':';
            },
            content: function (item) {
            var url = emojiUrls[item];
            if (url) {
                return $('<img />').attr('src', url).css('width', 20)[0];
            }
            return '';
            }
        }
    });

    $('div.note-group-select-from-files').remove();

    // Force-sync the backing textarea right before the form submits.
    // Summernote updates the textarea on change events but may not flush on
    // a rapid submit; doing this guarantees content is never lost.
    $('#<%= editorElementName %>').closest('form').on('submit', function () {
      document.getElementById('<%= editorElementName %>').value =
        $('#<%= editorElementName %>').summernote('code');
    });

  });
</script>
