<% if (requirements && requirements.length) { %>
  <div class="password-requirements" id="<%= containerId %>">
    <p class="password-requirements__title small text-muted mb-1">Password requirements:</p>
    <ul class="password-requirements__list list-unstyled mb-0 small">
      <% requirements.forEach(function (requirement) { %>
        <li class="password-requirements__item" data-rule="<%= requirement.id %>">
          <span class="password-requirements__icon" aria-hidden="true"></span>
          <span><%= requirement.message %></span>
        </li>
      <% }); %>
    </ul>
  </div>
  <script>
    (function () {
      const container = document.getElementById('<%= containerId %>');
      if (!container) return;
      const passwordInput = document.getElementById('<%= inputId %>');
      if (!passwordInput) return;
      const policy = <%- JSON.stringify(policy) %>;
      const items = container.querySelectorAll('[data-rule]');

      function meetsRequirement(rule, value) {
        switch (rule) {
          case 'minLength':
            return value.length >= (policy.minLength || 0);
          case 'complexity': {
            const hasUppercase = /[A-Z]/.test(value);
            const hasLowercase = /[a-z]/.test(value);
            const hasNumber = /[0-9]/.test(value);
            const hasSpecial = /[^\w\s]/.test(value);

            const meetsUppercase = !policy.requireUppercase || hasUppercase;
            const meetsLowercase = !policy.requireLowercase || hasLowercase;
            const meetsNumber = !policy.requireNumber || hasNumber;
            const meetsSpecial = !policy.requireSpecial || hasSpecial;

            return (
              meetsUppercase &&
              meetsLowercase &&
              meetsNumber &&
              meetsSpecial
            );
          }
          default:
            return false;
        }
      }

      function updateRequirements(value) {
        items.forEach(function (item) {
          const rule = item.getAttribute('data-rule');
          item.classList.toggle('is-met', meetsRequirement(rule, value));
        });
      }

      passwordInput.addEventListener('input', function (event) {
        updateRequirements(event.target.value || '');
      });

      updateRequirements(passwordInput.value || '');
    })();
  </script>
<% } %>
