<input 
    type="datetime-local" 
    class="form-control input-default"
    name="<%= elementName %>"
    <% if (elementValue) { %>
        value="<%= elementValue %>"
    <% } %>
    <% if (elementAttributes) { %>
        <%- elementAttributes %>
    <% } %>
    <% if (required) { %>
        required
    <% } %>
>
