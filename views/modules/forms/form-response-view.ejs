<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "View your form response"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: form.name,
  backgroundImage: globalImage
}) %>

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <% if (req.cookies.alertType) { %>
                    <%- include("../../partials/alert.ejs", {
                        alertType: req.cookies.alertType,
                        content: req.cookies.alertContent
                    }) %>
                <% } %>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="mb-1">Response #<%= response.responseId %></h4>
                        <small class="text-muted">Submitted <%= moment(response.submittedAt).fromNow() %></small>
                    </div>
                    <span class="badge bg-<%= response.status === 'new' ? 'primary' : response.status === 'reviewed' ? 'info' : response.status === 'converted' ? 'success' : 'secondary' %>">
                        <%= response.status %>
                    </span>
                </div>

                <div class="card">
                    <div class="card-body">
                        <% formattedAnswers.forEach(function(answer) { %>
                            <div class="mb-3">
                                <label class="form-label fw-bold"><%= answer.label %></label>
                                <p class="mb-0"><%= answer.value %></p>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <% if (response.status === 'converted' && response.ticketId) { %>
                    <div class="alert alert-info mt-3">
                        <i class="fas fa-ticket-alt me-1"></i> This response has been converted to
                        <a href="/support/ticket/<%= response.ticketId %>">Ticket #<%= response.ticketId %></a>.
                    </div>
                <% } %>

                <div class="mt-3">
                    <a href="/my/forms/responses" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Back to My Responses
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include("../../modules/footer.ejs") %>
