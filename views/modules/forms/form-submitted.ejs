<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Your response has been submitted."
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Response Submitted",
  backgroundImage: globalImage
}) %>

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center">
                <div class="mb-4">
                    <i class="fas fa-check-circle text-success" style="font-size: 4rem;"></i>
                </div>
                <h3>Your response has been recorded</h3>
                <p class="text-muted">Thank you for your submission<%= form ? ` to ${form.name}` : '' %>.</p>
                <div class="mt-4">
                    <a href="/" class="btn btn-primary">Return Home</a>
                    <% if (form) { %>
                        <a href="/forms/<%= form.slug %>" class="btn btn-outline-secondary ms-2">Submit Another</a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include("../../modules/footer.ejs") %>
