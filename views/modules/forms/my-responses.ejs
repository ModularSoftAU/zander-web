<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "View your form responses"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "My Form Responses",
  backgroundImage: globalImage
}) %>

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">

                <% if (responses.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-inbox text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-3">You haven't submitted any form responses yet.</p>
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Form</th>
                                    <th>Submitted</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% responses.forEach(function(response) { %>
                                    <tr>
                                        <td><%= response.responseId %></td>
                                        <td><%= response.formName %></td>
                                        <td><%= moment(response.submittedAt).fromNow() %></td>
                                        <td>
                                            <span class="badge bg-<%= response.status === 'new' ? 'primary' : response.status === 'reviewed' ? 'info' : response.status === 'converted' ? 'success' : 'secondary' %>">
                                                <%= response.status %>
                                            </span>
                                        </td>
                                        <td>
                                            <a href="/forms/<%= response.formSlug %>/response/<%= response.responseId %>" class="btn btn-sm btn-outline-primary">
                                                View
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>

            </div>
        </div>
    </div>
</section>

<%- include("../../modules/footer.ejs") %>
