<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Submit a punishment appeal for staff review."
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
    headerTitle: "Appeal",
    globalImage,
}) %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                        <div>
                            <h5 class="mb-2">Appeal guidance</h5>
                            <p class="text-muted mb-0">
                                Appeals are reviewed by staff. Make sure you are signed in, pick the punishment you want to appeal,
                                then provide clear details on the next page.
                            </p>
                        </div>
                        <% if (!isLoggedIn) { %>
                            <a href="/login?returnTo=/appeal" class="btn btn-outline-primary">Log in to appeal</a>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <% if (!isLoggedIn) { %>
                        <div class="alert alert-info mb-0" role="alert">
                            Please log in to see the punishments tied to your account.
                        </div>
                    <% } else { %>
                        <h5 class="mb-3">Minecraft Punishments</h5>
                        <% const punishments = appealPunishmentsApiData && Array.isArray(appealPunishmentsApiData.data) ? appealPunishmentsApiData.data : []; %>
                        <% if (!punishments.length) { %>
                            <div class="alert alert-warning mb-0" role="alert">
                                No Minecraft punishments found.
                            </div>
                        <% } else { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th scope="col">Punishment ID</th>
                                            <th scope="col">Type</th>
                                            <th scope="col">Reason</th>
                                            <th scope="col">Date</th>
                                            <th scope="col">Punished By</th>
                                            <th scope="col">Expires</th>
                                            <th scope="col"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% punishments.forEach(function (punishment, index) { %>
                                            <% const typeLabel = punishment.type || "Unknown"; %>
                                            <% const punishedBy = punishment.bannedByUsername || punishment.bannedByUuid || "System"; %>
                                            <% const hasValidDate = punishment.dateStart && new Date(punishment.dateStart).getTime() > 0; %>
                                            <% const punishmentId = punishment.id || punishment.punishmentId || punishment.punishment_id || "-"; %>
                                            <% const fallbackKey = hasValidDate ? `${typeLabel}-${new Date(punishment.dateStart).getTime()}` : String(index); %>
                                            <% const punishmentKey = String(punishment.id || punishment.punishmentId || punishment.punishment_id || fallbackKey); %>
                                            <% let typeBadge = "bg-secondary"; %>
                                            <% if (typeLabel === "ban") typeBadge = "bg-danger"; %>
                                            <% if (typeLabel === "mute") typeBadge = "bg-warning text-dark"; %>
                                            <% if (typeLabel === "kick") typeBadge = "bg-secondary"; %>
                                            <% if (typeLabel === "warning") typeBadge = "bg-info text-dark"; %>
                                            <% const hasValidEndDate = punishment.dateEnd && new Date(punishment.dateEnd).getTime() > 0; %>
                                            <% const isExpired = hasValidEndDate && new Date(punishment.dateEnd) < new Date(); %>
                                            <tr>
                                                <th scope="row"><%= punishmentId %></th>
                                                <td><span class="badge <%= typeBadge %> text-uppercase"><%= typeLabel %></span></td>
                                                <td><%= punishment.reason || "No reason provided." %></td>
                                                <td>
                                                    <% if (hasValidDate) { %>
                                                        <span data-relative-time="<%= new Date(punishment.dateStart).toISOString() %>" data-relative-format="datetime"></span>
                                                    <% } else { %>
                                                        Unknown date
                                                    <% } %>
                                                </td>
                                                <td><%= punishedBy %></td>
                                                <td>
                                                    <% if (punishment.type === "ban") { %>
                                                        <% if (hasValidEndDate) { %>
                                                            <% if (isExpired) { %>
                                                                Expired
                                                            <% } else { %>
                                                                <span data-relative-time="<%= new Date(punishment.dateEnd).toISOString() %>"></span>
                                                            <% } %>
                                                        <% } else { %>
                                                            Permanent
                                                        <% } %>
                                                    <% } else { %>
                                                        —
                                                    <% } %>
                                                </td>
                                                <td class="text-end">
                                                    <% if (appealTicketsByKey && appealTicketsByKey[punishmentKey]) { %>
                                                        <a href="/support/ticket/<%= appealTicketsByKey[punishmentKey] %>" class="btn btn-sm btn-outline-primary">Open ticket</a>
                                                    <% } else { %>
                                                        <a href="/appeal/start?punishmentIndex=<%= index %>" class="btn btn-sm btn-primary">Appeal</a>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>
                    <% } %>
                </div>
            </div>

            <% if (isLoggedIn) { %>
            <% const dPunishments = (typeof discordPunishmentsData !== 'undefined' && Array.isArray(discordPunishmentsData)) ? discordPunishmentsData : []; %>
            <% if (dPunishments.length) { %>
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="mb-3"><i class="fa-brands fa-discord me-2"></i>Discord Punishments</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">ID</th>
                                    <th scope="col">Platform</th>
                                    <th scope="col">Type</th>
                                    <th scope="col">Reason</th>
                                    <th scope="col">Date</th>
                                    <th scope="col">Staff</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Expires</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% dPunishments.forEach(function (dp) { %>
                                    <% let dpBadge = "bg-secondary"; %>
                                    <% if (dp.type === "PERM_BAN" || dp.type === "TEMP_BAN") dpBadge = "bg-danger"; %>
                                    <% if (dp.type === "PERM_MUTE" || dp.type === "TEMP_MUTE") dpBadge = "bg-warning text-dark"; %>
                                    <% if (dp.type === "DISCORD_KICK") dpBadge = "bg-secondary"; %>
                                    <% if (dp.type === "WARN") dpBadge = "bg-info text-dark"; %>
                                    <% const dpHasExpiry = dp.expires_at && new Date(dp.expires_at).getTime() > 0; %>
                                    <% const dpExpired = dpHasExpiry && new Date(dp.expires_at) < new Date(); %>
                                    <tr>
                                        <th scope="row"><%= dp.id %></th>
                                        <td><span class="badge bg-primary">Discord</span></td>
                                        <td><span class="badge <%= dpBadge %> text-uppercase"><%= dp.type.replace(/_/g, ' ') %></span></td>
                                        <td><%= dp.reason || "No reason provided." %></td>
                                        <td>
                                            <% if (dp.created_at) { %>
                                                <span data-relative-time="<%= new Date(dp.created_at).toISOString() %>" data-relative-format="datetime"></span>
                                            <% } else { %>
                                                Unknown
                                            <% } %>
                                        </td>
                                        <td><%= dp.actor_name_snapshot || "System" %></td>
                                        <td><span class="badge bg-<%= dp.status === 'ACTIVE' ? 'danger' : dp.status === 'EXPIRED' || dp.status === 'LIFTED' || dp.status === 'APPEALED' ? 'success' : 'secondary' %>"><%= dp.status %></span></td>
                                        <td>
                                            <% if (dpHasExpiry) { %>
                                                <% if (dpExpired) { %>
                                                    Expired
                                                <% } else { %>
                                                    <span data-relative-time="<%= new Date(dp.expires_at).toISOString() %>"></span>
                                                <% } %>
                                            <% } else if (dp.type.includes("PERM")) { %>
                                                Permanent
                                            <% } else { %>
                                                —
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <% } %>
            <% } %>
        </div>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>
