<%- include("../header.ejs", {
    pageTitle: pageTitle,
    pageDescription: pageDescription
}) %>

<%- include("../navigationBar.ejs") %>

<% if (event.bannerUrl) { %>
<div style="background:url('<%= event.bannerUrl %>') center/cover no-repeat;height:300px;position:relative;">
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.4);"></div>
    <div class="container h-100 d-flex align-items-end pb-4 position-relative">
        <div class="text-white">
            <h1 class="display-5 fw-bold mb-1"><%= event.title %></h1>
            <span class="badge bg-primary me-2"><%= event.eventType %></span>
        </div>
    </div>
</div>
<% } else { %>
<%- include("../../partials/miniHeader.ejs", { headerTitle: event.title, backgroundImage: globalImage }) %>
<% } %>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <!-- Main Content -->
            <div class="col-lg-8">
                <% if (event.description) { %>
                <div class="card mb-4">
                    <div class="card-header"><i class="fas fa-info-circle me-2"></i>About This Event</div>
                    <div class="card-body event-description">
                        <%- event.description %>
                    </div>
                </div>
                <% } %>

                <!-- Hosts -->
                <% if (event.hosts && event.hosts.length > 0) { %>
                <div class="card mb-4">
                    <div class="card-header"><i class="fas fa-users me-2"></i>Event Team</div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-3">
                            <% event.hosts.forEach(h => { %>
                            <div class="d-flex align-items-center gap-2 border rounded px-3 py-2">
                                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white" style="width:40px;height:40px;font-size:1.2rem;flex-shrink:0;">
                                    <i class="fas fa-user"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold"><%= h.displayName || 'Unknown' %></div>
                                    <small class="text-muted text-capitalize"><%= h.role.replace('_',' ') %></small>
                                </div>
                            </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
                <% } %>

                <!-- External Links -->
                <% if (externalLinks && externalLinks.length > 0) { %>
                <div class="card mb-4">
                    <div class="card-header"><i class="fas fa-link me-2"></i>Links</div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-2">
                            <% externalLinks.forEach(link => { %>
                                <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-external-link-alt me-1"></i><%= link.label || link.url %>
                                </a>
                            <% }) %>
                        </div>
                    </div>
                </div>
                <% } %>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Event Info Card -->
                <div class="card mb-3 sticky-top" style="top:20px">
                    <% if (event.logoUrl) { %>
                    <div class="text-center pt-3">
                        <img src="<%= event.logoUrl %>" alt="Event Logo" style="max-height:80px;max-width:160px;object-fit:contain;">
                    </div>
                    <% } %>
                    <div class="card-body">
                        <h5 class="card-title"><%= event.title %></h5>

                        <ul class="list-unstyled mb-3">
                            <li class="mb-2">
                                <i class="fas fa-calendar-day me-2 text-primary"></i>
                                <strong>Starts:</strong><br>
                                <span class="ms-4 js-datetime-full" data-iso="<%= event.startAt %>"></span><br>
                                <span class="ms-4 text-muted small js-datetime-relative" data-iso="<%= event.startAt %>"></span>
                            </li>
                            <li class="mb-2">
                                <i class="fas fa-calendar-check me-2 text-secondary"></i>
                                <strong>Ends:</strong><br>
                                <span class="ms-4 js-datetime-full" data-iso="<%= event.endAt %>"></span>
                            </li>
                            <% if (event.locationLabel) { %>
                            <li class="mb-2">
                                <i class="fas fa-map-marker-alt me-2 text-danger"></i>
                                <strong>Location:</strong> <%= event.locationLabel %>
                            </li>
                            <% } %>
                            <% if (event.serverName) { %>
                            <li class="mb-2">
                                <i class="fas fa-server me-2 text-info"></i>
                                <strong>Server:</strong> <%= event.serverName %>
                                <% if (event.serverIp) { %><br><span class="ms-4 font-monospace small"><%= event.serverIp %></span><% } %>
                            </li>
                            <% } %>
                            <% if (event.eventType === 'recurring') { %>
                            <li class="mb-2">
                                <i class="fas fa-redo me-2 text-success"></i>
                                <strong>Type:</strong> Recurring event
                            </li>
                            <% } %>
                        </ul>

                        <!-- Discord timestamp -->
                        <div class="mb-3 p-2 bg-light rounded small">
                            <strong>Discord Timestamp:</strong><br>
                            <code id="discordTimestamp">&lt;t:<%= startTs %>:F&gt;</code>
                            <button class="btn btn-xs btn-outline-secondary ms-2" onclick="copyDiscordTs()">Copy</button>
                        </div>

                        <!-- Calendar Links -->
                        <div class="d-grid gap-2">
                            <a href="<%= gcalUrl %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline-danger btn-sm">
                                <i class="fab fa-google me-2"></i>Add to Google Calendar
                            </a>
                        </div>

                        <% if (tags && tags.length > 0) { %>
                        <div class="mt-3">
                            <% tags.forEach(tag => { %>
                                <span class="badge bg-secondary me-1"><%= tag %></span>
                            <% }) %>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Back link -->
        <div class="mt-4">
            <a href="/events" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left me-2"></i>All Events
            </a>
        </div>
    </div>
</section>

<%- include("../footer.ejs") %>

<style>
.btn-xs { padding: 0.15rem 0.4rem; font-size: 0.75rem; }
.event-description img { max-width: 100%; }
</style>

<script>
function copyDiscordTs() {
    const text = document.getElementById('discordTimestamp').textContent;
    navigator.clipboard.writeText(text).then(() => {
        const btn = document.querySelector('[onclick="copyDiscordTs()"]');
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 2000);
    });
}

document.querySelectorAll('.js-datetime-full').forEach(el => {
    const d = el.dataset.iso ? new Date(el.dataset.iso) : null;
    el.textContent = d && !isNaN(d) ? d.toLocaleString(undefined, {
        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
        hour: '2-digit', minute: '2-digit', timeZoneName: 'short'
    }) : '—';
});

document.querySelectorAll('.js-datetime-relative').forEach(el => {
    const d = el.dataset.iso ? new Date(el.dataset.iso) : null;
    if (!d || isNaN(d)) { el.textContent = ''; return; }
    const now = new Date();
    const diff = d - now;
    if (diff < 0) {
        el.textContent = 'This event has passed';
        return;
    }
    const days = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    if (days > 0) el.textContent = `Starts in ${days} day${days !== 1 ? 's' : ''}`;
    else if (hours > 0) el.textContent = `Starts in ${hours} hour${hours !== 1 ? 's' : ''}`;
    else el.textContent = 'Starting soon!';
});
</script>
