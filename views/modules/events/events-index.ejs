<%- include("../header.ejs", {
    pageTitle: pageTitle,
    pageDescription: pageDescription
}) %>

<%- include("../navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Events",
  backgroundImage: globalImage
}) %>

<section class="py-5">
    <div class="container">
        <!-- Upcoming Events -->
        <% if (upcomingEvents && upcomingEvents.length > 0) { %>
        <div class="mb-5">
            <h2 class="h3 mb-4"><i class="fas fa-calendar-alt me-2"></i>Upcoming Events</h2>
            <div class="row g-4">
                <% upcomingEvents.forEach(ev => { %>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm event-card">
                        <% if (ev.bannerUrl) { %>
                            <img src="<%= ev.bannerUrl %>" class="card-img-top" alt="<%= ev.title %>" style="height:180px;object-fit:cover;">
                        <% } %>
                        <div class="card-body d-flex flex-column">
                            <% if (ev.featured) { %><span class="badge bg-warning text-dark mb-1"><i class="fas fa-star me-1"></i>Featured</span><% } %>
                            <h5 class="card-title"><a href="/events/<%= ev.slug %>" class="text-decoration-none"><%= ev.title %></a></h5>
                            <div class="text-muted small mb-2">
                                <i class="fas fa-clock me-1"></i>
                                <span class="js-datetime" data-iso="<%= ev.startAt %>" data-fallback="TBA"></span>
                            </div>
                            <% if (ev.locationLabel) { %>
                                <div class="text-muted small mb-2"><i class="fas fa-map-marker-alt me-1"></i><%= ev.locationLabel %></div>
                            <% } %>
                            <% if (ev.serverName) { %>
                                <div class="text-muted small mb-2"><i class="fas fa-server me-1"></i><%= ev.serverName %></div>
                            <% } %>
                            <% if (ev.hosts && ev.hosts.length > 0) { %>
                                <div class="text-muted small mb-3">
                                    <i class="fas fa-user me-1"></i>Hosted by <%= ev.hosts.map(h => h.displayName || 'Unknown').join(', ') %>
                                </div>
                            <% } %>
                            <div class="mt-auto">
                                <a href="/events/<%= ev.slug %>" class="btn btn-sm btn-primary">View Event</a>
                                <small class="text-muted ms-2">
                                    <i class="fas fa-tag me-1"></i><%= ev.eventType %>
                                </small>
                            </div>
                        </div>
                        <div class="card-footer text-muted small">
                            Ends <span class="js-datetime" data-iso="<%= ev.endAt %>" data-fallback="—"></span>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
        <% } else { %>
        <div class="mb-5">
            <h2 class="h3 mb-4">Upcoming Events</h2>
            <div class="alert alert-info">No upcoming events scheduled. Check back soon!</div>
        </div>
        <% } %>

        <!-- All Events -->
        <% if (allEvents.events && allEvents.events.length > 0) { %>
        <div>
            <h2 class="h3 mb-4"><i class="fas fa-history me-2"></i>All Events</h2>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Event</th>
                            <th>Date</th>
                            <th>Type</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% allEvents.events.forEach(ev => { %>
                        <tr>
                            <td>
                                <strong><a href="/events/<%= ev.slug %>"><%= ev.title %></a></strong>
                                <% if (ev.locationLabel) { %><br><small class="text-muted"><i class="fas fa-map-marker-alt me-1"></i><%= ev.locationLabel %></small><% } %>
                            </td>
                            <td><small class="js-datetime" data-iso="<%= ev.startAt %>"></small></td>
                            <td><span class="badge bg-secondary"><%= ev.eventType %></span></td>
                            <td><a href="/events/<%= ev.slug %>" class="btn btn-xs btn-outline-primary">View</a></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <% if (allEvents.total > 12) { %>
            <nav class="mt-3">
                <ul class="pagination pagination-sm justify-content-center">
                    <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="/events?page=<%= currentPage - 1 %>">Previous</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">Page <%= currentPage %> of <%= Math.ceil(allEvents.total / 12) %></span>
                    </li>
                    <li class="page-item <%= currentPage >= Math.ceil(allEvents.total / 12) ? 'disabled' : '' %>">
                        <a class="page-link" href="/events?page=<%= currentPage + 1 %>">Next</a>
                    </li>
                </ul>
            </nav>
            <% } %>
        </div>
        <% } %>
    </div>
</section>

<%- include("../footer.ejs") %>

<style>
.btn-xs { padding: 0.15rem 0.4rem; font-size: 0.75rem; }
.event-card { transition: transform 0.15s; }
.event-card:hover { transform: translateY(-2px); }
</style>
<script>
document.querySelectorAll('.js-datetime').forEach(el => {
    const d = el.dataset.iso ? new Date(el.dataset.iso) : null;
    el.textContent = d && !isNaN(d) ? d.toLocaleDateString(undefined, { weekday:'short', year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : (el.dataset.fallback || '—');
});
</script>
