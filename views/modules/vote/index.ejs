<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: pageDescription
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Vote",
  backgroundImage: globalImage
}) %>

<div class="container my-5">
    <div class="row g-4">

        <!-- Voting Sites -->
        <div class="col-lg-7">
            <h2 class="h4 mb-3">Vote for Us</h2>
            <p class="text-muted">Vote daily on the sites below to earn in-game rewards and help us grow!</p>

            <% if (!sitesData.success || !sitesData.data || !sitesData.data.length) { %>
                <div class="alert alert-info">No voting sites are available right now. Check back soon!</div>
            <% } else { %>
                <div class="d-flex flex-column gap-3">
                    <% sitesData.data.forEach(function(site) { %>
                        <a href="<%= site.vote_url %>" target="_blank" rel="noopener" class="card card-body text-decoration-none d-flex flex-row align-items-center justify-content-between gap-3 shadow-sm border-start border-primary border-3">
                            <div>
                                <strong class="d-block"><%= site.site_name %></strong>
                                <small class="text-muted"><code><%= site.service_name %></code></small>
                            </div>
                            <span class="btn btn-sm btn-primary">Vote &rarr;</span>
                        </a>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- Leaderboard -->
        <div class="col-lg-5">
            <h2 class="h4 mb-3">Top Voters — <%= currentMonth %></h2>

            <% if (!leaderboardData.success || !leaderboardData.data || !leaderboardData.data.length) { %>
                <p class="text-muted">No votes recorded yet this month. Be the first!</p>
            <% } else { %>
                <ol class="list-group list-group-numbered">
                    <% leaderboardData.data.forEach(function(entry, index) { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>
                                <% if (index === 0) { %><i class="fas fa-crown text-warning me-1"></i><% } %>
                                <strong><%= entry.player_name %></strong>
                            </span>
                            <span class="badge bg-primary rounded-pill"><%= entry.vote_count %> votes</span>
                        </li>
                    <% }) %>
                </ol>
                <p class="text-muted small mt-2">The top voter each month earns a special monthly reward!</p>
            <% } %>
        </div>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>
