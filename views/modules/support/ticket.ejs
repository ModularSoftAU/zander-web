<%- include('../../modules/header.ejs', {
    pageTitle: pageTitle,
    pageDescription: "View Support Ticket"
}) %>

<%- include('../../modules/navigationBar.ejs') %>

<%- include('../../partials/miniHeader.ejs', {
    headerTitle: `Ticket #${ticket.ticketId}`,
    globalImage,
}) %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <h2 class="mb-1"><%= ticket.title %></h2>
                    <% const statusClass = {
                        open: "bg-success",
                        closed: "bg-secondary",
                        pending: "bg-warning text-dark"
                    }[ticket.status] || "bg-secondary"; %>
                    <span class="badge rounded-pill <%= statusClass %>"><%= ticket.status %></span>
                    <% if (ticket.isEscalated) { %>
                        <span class="badge rounded-pill bg-warning text-dark">Escalated</span>
                    <% } %>
                    <% if (ticket.isLocked) { %>
                        <span class="badge rounded-pill bg-dark">Locked</span>
                    <% } %>
                </div>
            </div>
        </div>
        <div class="card-body">
            <p><strong>Created At:</strong> <span data-relative-time="<%= new Date(ticket.createdAt).toISOString() %>"></span></p>
            <% const currentCategory = (categories || []).find((category) => category.categoryId === ticket.categoryId); %>
            <p class="mb-0"><strong>Category:</strong> <%= currentCategory?.name || 'Uncategorized' %></p>
            <div class="mt-3">
                <h4>Participants</h4>
                <div class="d-flex flex-wrap gap-2">
                    <span class="rank-pill" style="--rank-pill-bg: #3b82f6; --rank-pill-text: #ffffff;">Owner: <%= ownerUser?.username || ticket.userId %></span>
                    <% participants.users.forEach((participant) => { %>
                        <span class="rank-pill" style="--rank-pill-bg: #06b6d4; --rank-pill-text: #ffffff;">User: <%= participant.username || participant.userId %></span>
                    <% }); %>
                    <% participants.groups.forEach((group) => { %>
                        <span class="rank-pill" style="--rank-pill-bg: <%= group.badgeColor || '#6c757d' %>; --rank-pill-text: <%= group.textColor || '#fff' %>;">Group: <%= group.roleName || group.rankSlug || group.roleId %></span>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header">
            <h2>Messages</h2>
        </div>
        <div class="card-body">
            <% messages.forEach(message => { %>
                <% if (message.messageType === 'status') { %>
                    <div class="alert alert-secondary d-flex align-items-center gap-2" role="status">
                        <div><span class="badge bg-dark">Status</span></div>
                        <div class="flex-fill">
                            <div class="fw-semibold"><%- message.renderedMessage %></div>
                            <div class="text-muted small local-datetime" data-timestamp="<%= new Date(message.createdAt).toISOString() %>"></div>
                        </div>
                    </div>
                <% } else { %>
                    <% const topRank = (message.ranks && message.ranks.length) ? message.ranks[0] : null; %>
                    <% const cardClasses = ["card", "mb-3"];
                       if (message.isInternal) {
                           cardClasses.push("border-warning", "bg-light");
                       }
                    %>
                    <div class="<%= cardClasses.join(' ') %>">
                        <div class="card-body d-flex">
                            <div class="me-3">
                                <% if (message.avatarUrl) { %>
                                    <img src="<%= message.avatarUrl %>" alt="<%= message.username %> avatar" class="rounded-circle" width="56" height="56">
                                <% } else { %>
                                    <div class="rounded-circle bg-secondary" style="width:56px;height:56px;"></div>
                                <% } %>
                            </div>
                            <div class="flex-fill">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <% const usernameContent = message.profileUrl ? `<a href="${message.profileUrl}" class="text-decoration-none" style="color: ${topRank?.badgeColor || '#0f172a'};">${message.username}</a>` : `<span style="color: ${topRank?.badgeColor || '#0f172a'};">${message.username}</span>`; %>
                                    <strong><%- usernameContent %></strong>
                                    <% if (message.isInternal) { %>
                                        <span class="badge bg-warning text-dark">Internal note</span>
                                    <% } %>
                                    <span class="text-muted small local-datetime" data-timestamp="<%= new Date(message.createdAt).toISOString() %>"></span>
                                </div>
                                <% if (message.ranks && message.ranks.length) { %>
                                    <div class="d-flex flex-wrap gap-2 mt-1">
                                        <% message.ranks.forEach((rank) => { %>
                                            <span class="rank-pill" style="--rank-pill-bg: <%= rank.badgeColor || '#1f2937' %>; --rank-pill-text: <%= rank.textColor || '#ffffff' %>;"><%= rank.displayName %></span>
                                        <% }); %>
                                    </div>
                                <% } %>
                                <p class="mt-2 mb-1"><%- message.renderedMessage %></p>
                            </div>
                        </div>
                    </div>
                <% } %>
            <% }) %>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h2 class="mb-0">Reply</h2>
            <% if (canManageTicket) { %>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <form action="/support/ticket/<%= ticket.ticketId %>/status" method="POST" class="d-flex gap-2">
                        <% if (ticket.status === 'open' || ticket.status === 'pending') { %>
                            <button type="submit" name="status" value="closed" class="btn btn-outline-danger">Close ticket</button>
                        <% } %>
                        <% if (ticket.status === 'closed' || ticket.status === 'pending') { %>
                            <button type="submit" name="status" value="open" class="btn btn-outline-success">Reopen ticket</button>
                        <% } %>
                    </form>
                    <% const showActionsMenu = canManageParticipants || isStaff || canEscalate || canManageLock; %>
                    <% if (showActionsMenu) { %>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="ticketActions" data-bs-toggle="dropdown" aria-expanded="false">
                                Actions
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="ticketActions">
                                <% if (canManageParticipants) { %>
                                    <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#addUserModal">Add user</button></li>
                                    <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#addGroupModal">Add group</button></li>
                                    <% if (participants.users.length) { %>
                                        <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#removeUserModal">Remove user</button></li>
                                    <% } %>
                                    <% if (participants.groups.length) { %>
                                        <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#removeGroupModal">Remove group</button></li>
                                    <% } %>
                                <% } %>
                                <% if (isStaff) { %>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#changeStatusModal">Change status</button></li>
                                    <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#changeCategoryModal">Change category</button></li>
                                <% } %>
                                <% if (canEscalate) { %>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form action="/support/ticket/<%= ticket.ticketId %>/escalation" method="POST" class="px-3 py-1">
                                            <input type="hidden" name="action" value="<%= ticket.isEscalated ? 'deescalate' : 'escalate' %>">
                                            <button type="submit" class="dropdown-item px-0"><%= ticket.isEscalated ? 'Deescalate ticket' : 'Escalate ticket' %></button>
                                        </form>
                                    </li>
                                <% } %>
                                <% if (canManageLock) { %>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form action="/support/ticket/<%= ticket.ticketId %>/lock" method="POST" class="px-3 py-1">
                                            <input type="hidden" name="action" value="<%= ticket.isLocked ? 'unlock' : 'lock' %>">
                                            <button type="submit" class="dropdown-item px-0"><%= ticket.isLocked ? 'Unlock ticket' : 'Lock ticket' %></button>
                                        </form>
                                    </li>
                                <% } %>
                            </ul>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>
        <div class="card-body">
            <% if (ticket.status === 'open' || ticket.status === 'pending') { %>
                <% if (!isMinecraftLinked) { %>
                    <div class="alert alert-warning" role="alert">
                        <h5 class="alert-heading">Minecraft account not linked</h5>
                        <p class="mb-2">You need to link your Minecraft account before you can reply to tickets. To link your account:</p>
                        <ol class="mb-2">
                            <li>Log in to one of the verification servers listed on the <a href="/register/minecraft" class="alert-link">Minecraft verification page</a>.</li>
                            <li>The server will give you a 6-digit code.</li>
                            <li>Enter the code on that page to link your account.</li>
                        </ol>
                        <p class="mb-0">Once your account is linked, return here to reply. If you need help, please contact a staff member.</p>
                    </div>
                <% } else if (!canReplyDuringEscalation) { %>
                    <p class="mb-0 text-muted">This ticket is escalated. Only escalation staff or the ticket opener may reply.</p>
                <% } else { %>
                    <form action="/support/ticket/<%= ticket.ticketId %>" method="POST">
                        <% if (isStaff) { %>
                            <div class="form-group mb-3">
                                <label class="form-label">Reply visibility</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="visibility" id="visibilityPublic" value="public" checked>
                                    <label class="form-check-label" for="visibilityPublic">Public reply (visible to everyone on the ticket)</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="visibility" id="visibilityInternal" value="internal">
                                    <label class="form-check-label" for="visibilityInternal">Internal note (staff only, not sent to Discord)</label>
                                </div>
                            </div>
                        <% } else { %>
                            <input type="hidden" name="visibility" value="public">
                        <% } %>
                        <div class="form-group">
                            <label for="message">Message</label>
                            <textarea name="message" id="message" rows="5" class="form-control" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Reply</button>
                    </form>
                <% } %>
            <% } else { %>
                <p class="mb-0 text-muted">This ticket is closed. Reopen it to add a new reply.</p>
            <% } %>
        </div>
    </div>

    <% if (canManageTicket && canManageParticipants) { %>
        <div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="addUserModalLabel">Add user to ticket</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form action="/support/ticket/<%= ticket.ticketId %>/add-user" method="POST">
                        <div class="modal-body">
                            <div class="form-group">
                                <label for="userIdentifier">Username or user ID</label>
                                <input type="hidden" id="userIdInput" name="userId" value="">
                                <input type="text" class="form-control" id="userIdentifier" name="userIdentifier" placeholder="Search by username or paste user ID" autocomplete="off">
                                <div id="userSuggestions" class="list-group mt-2"></div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Add user</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade" id="addGroupModal" tabindex="-1" aria-labelledby="addGroupModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="addGroupModalLabel">Add group to ticket</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form action="/support/ticket/<%= ticket.ticketId %>/add-group" method="POST">
                        <div class="modal-body">
                            <div class="form-group">
                                <label for="groupRoleId">Select a group</label>
                                <select class="form-control" id="groupRoleId" name="groupRoleId" required>
                                    <option value="">Select a group</option>
                                    <% rankOptions.forEach((rank) => { %>
                                        <option value="<%= rank.id %>"><%= rank.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Add group</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <% if (participants.users.length) { %>
            <div class="modal fade" id="removeUserModal" tabindex="-1" aria-labelledby="removeUserModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="removeUserModalLabel">Remove user from ticket</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form action="/support/ticket/<%= ticket.ticketId %>/remove-user" method="POST">
                            <div class="modal-body">
                                <div class="form-group">
                                    <label for="removeUserId">Select user</label>
                                    <select class="form-control" id="removeUserId" name="removeUserId" required>
                                        <option value="">Select user</option>
                                        <% participants.users.forEach((participant) => { %>
                                            <option value="<%= participant.userId %>"><%= participant.username || participant.userId %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger">Remove user</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        <% } %>

        <% if (participants.groups.length) { %>
            <div class="modal fade" id="removeGroupModal" tabindex="-1" aria-labelledby="removeGroupModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="removeGroupModalLabel">Remove group from ticket</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form action="/support/ticket/<%= ticket.ticketId %>/remove-group" method="POST">
                            <div class="modal-body">
                                <div class="form-group">
                                    <label for="removeGroupRoleId">Select group</label>
                                    <select class="form-control" id="removeGroupRoleId" name="removeGroupRoleId" required>
                                        <option value="">Select group</option>
                                        <% participants.groups.forEach((group) => { %>
                                            <option value="<%= group.roleId %>"><%= group.roleName || group.rankSlug || group.roleId %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger">Remove group</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        <% } %>

        <% if (isStaff) { %>
            <div class="modal fade" id="changeStatusModal" tabindex="-1" aria-labelledby="changeStatusModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="changeStatusModalLabel">Change ticket status</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form action="/support/ticket/<%= ticket.ticketId %>/status" method="POST">
                            <div class="modal-body">
                                <div class="form-group">
                                    <label for="statusSelect">Select status</label>
                                    <select class="form-control" id="statusSelect" name="status" required>
                                        <option value="open" <%= ticket.status === 'open' ? 'selected' : '' %>>Open</option>
                                        <option value="pending" <%= ticket.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                        <option value="closed" <%= ticket.status === 'closed' ? 'selected' : '' %>>Closed</option>
                                    </select>
                                </div>
                                <p class="text-muted small mb-0">Locking and escalation controls are available in the actions menu.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Update status</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        <% } %>
        <% if (isStaff) { %>
            <div class="modal fade" id="changeCategoryModal" tabindex="-1" aria-labelledby="changeCategoryModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="changeCategoryModalLabel">Change ticket category</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form action="/support/ticket/<%= ticket.ticketId %>/category" method="POST">
                            <div class="modal-body">
                                <div class="form-group">
                                    <label for="categoryId">Select category</label>
                                    <select class="form-control" id="categoryId" name="categoryId" required>
                                        <% (categories || []).forEach((category) => { %>
                                            <option value="<%= category.categoryId %>" <%= category.categoryId === ticket.categoryId ? 'selected' : '' %>>
                                                <%= category.name %>
                                            </option>
                                        <% }) %>
                                    </select>
                                </div>
                                <p class="text-muted small mb-0">Changing the category updates staff permissions for this ticket's Discord channel.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Update category</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        <% } %>
    <% } %>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const userIdentifierInput = document.getElementById("userIdentifier");
        const userIdInput = document.getElementById("userIdInput");
        const userSuggestions = document.getElementById("userSuggestions");

        if (userIdentifierInput && userIdInput && userSuggestions) {
            let searchTimeout;

            const clearSuggestions = () => {
                userSuggestions.innerHTML = "";
            };

            const renderSuggestions = (results = []) => {
                clearSuggestions();
                if (!results.length) return;

                results.forEach((user) => {
                    const item = document.createElement("button");
                    item.type = "button";
                    item.className = "list-group-item list-group-item-action d-flex align-items-center gap-2";
                    item.dataset.userId = user.userId;
                    item.dataset.username = user.username;

                    if (user.avatarUrl) {
                        const img = document.createElement("img");
                        img.src = user.avatarUrl;
                        img.alt = `${user.username} avatar`;
                        img.width = 32;
                        img.height = 32;
                        img.className = "rounded";
                        item.appendChild(img);
                    } else {
                        const placeholder = document.createElement("div");
                        placeholder.className = "rounded bg-secondary";
                        placeholder.style.width = "32px";
                        placeholder.style.height = "32px";
                        item.appendChild(placeholder);
                    }

                    const label = document.createElement("span");
                    label.textContent = user.username;
                    label.className = "flex-fill text-start";
                    item.appendChild(label);

                    item.addEventListener("click", () => {
                        userIdentifierInput.value = user.username;
                        userIdInput.value = user.userId;
                        clearSuggestions();
                    });

                    userSuggestions.appendChild(item);
                });
            };

            const searchUsers = async (term) => {
                if (!term || term.length < 2) {
                    clearSuggestions();
                    return;
                }

                try {
                    const response = await fetch(`/support/users/search?q=${encodeURIComponent(term)}`);
                    if (!response.ok) {
                        clearSuggestions();
                        return;
                    }

                    const data = await response.json();
                    renderSuggestions(data.results || []);
                } catch (searchError) {
                    console.error("Failed to search users", searchError);
                    clearSuggestions();
                }
            };

            userIdentifierInput.addEventListener("input", (event) => {
                const value = event.target.value || "";
                userIdInput.value = "";
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => searchUsers(value.trim()), 250);
            });
        }
    });
</script>

<%- include('../../modules/footer.ejs') %>
