<%- include('../../modules/header.ejs', {
    pageTitle: pageTitle,
    pageDescription: "View Support Ticket"
}) %>

<%- include('../../modules/navigationBar.ejs') %>

<div class="page-header">
    <div class="container">
        <h1>Ticket #<%= ticket.ticketId %></h1>
    </div>
</div>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h2><%= ticket.title %></h2>
        </div>
        <div class="card-body">
            <p><strong>Status:</strong> <%= ticket.status %></p>
            <p><strong>Created At:</strong> <%= new Date(ticket.createdAt).toLocaleString() %></p>
            <div class="mt-3">
                <h4>Participants</h4>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-primary">Owner: <%= ticket.userId %></span>
                    <% participants.users.forEach((participant) => { %>
                        <span class="badge bg-info text-dark">User: <%= participant.username || participant.userId %></span>
                    <% }); %>
                    <% participants.groups.forEach((group) => { %>
                        <span class="badge" style="background-color: <%= group.badgeColor || '#6c757d' %>; color: <%= group.textColor || '#fff' %>">Group: <%= group.roleName || group.rankSlug || group.roleId %></span>
                    <% }); %>
                </div>
            </div>
            <% if (req.session.user.isStaff) { %>
                <form action="/dashboard/support/ticket/<%= ticket.ticketId %>/status" method="POST">
                    <% if (ticket.status === 'open') { %>
                        <button type="submit" name="status" value="closed" class="btn btn-danger">Close Ticket</button>
                    <% } else { %>
                        <button type="submit" name="status" value="open" class="btn btn-success">Reopen Ticket</button>
                    <% } %>
                </form>
            <% } %>
            <% if (ticket.status === 'open' && (req.session.user.isStaff || req.session.user.userId === ticket.userId)) { %>
                <div class="row mt-3">
                    <div class="col-md-6">
                        <form action="/support/ticket/<%= ticket.ticketId %>/add-user" method="POST">
                            <div class="form-group">
                                <label for="userIdentifier">Add User</label>
                                <input type="text" class="form-control" id="userIdentifier" name="userIdentifier" placeholder="Username or User ID" required>
                            </div>
                            <button type="submit" class="btn btn-outline-primary mt-2">Add User</button>
                        </form>
                    </div>
                    <div class="col-md-6">
                        <form action="/support/ticket/<%= ticket.ticketId %>/add-group" method="POST">
                            <div class="form-group">
                                <label for="groupRoleId">Add Group</label>
                                <select class="form-control" id="groupRoleId" name="groupRoleId" required>
                                    <option value="">Select a group</option>
                                    <% rankOptions.forEach((rank) => { %>
                                        <option value="<%= rank.id %>"><%= rank.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-outline-secondary mt-2">Add Group</button>
                        </form>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header">
            <h2>Messages</h2>
        </div>
        <div class="card-body">
            <% messages.forEach(message => { %>
                <% const topRank = (message.ranks && message.ranks.length) ? message.ranks[0] : null; %>
                <div class="card mb-3">
                    <div class="card-body d-flex">
                        <div class="me-3">
                            <% if (message.avatarUrl) { %>
                                <img src="<%= message.avatarUrl %>" alt="<%= message.username %> avatar" class="rounded-circle" width="56" height="56">
                            <% } else { %>
                                <div class="rounded-circle bg-secondary" style="width:56px;height:56px;"></div>
                            <% } %>
                        </div>
                        <div class="flex-fill">
                            <div class="d-flex align-items-center gap-2">
                                <strong style="color: <%= topRank?.badgeColor || '#0f172a' %>;"><%= message.username %></strong>
                                <span class="text-muted small"><%= new Date(message.createdAt).toLocaleString() %></span>
                            </div>
                            <% if (message.ranks && message.ranks.length) { %>
                                <div class="d-flex flex-wrap gap-1 mt-1">
                                    <% message.ranks.forEach((rank) => { %>
                                        <span class="badge" style="background-color: <%= rank.badgeColor || '#1f2937' %>; color: <%= rank.textColor || '#ffffff' %>;"><%= rank.displayName %></span>
                                    <% }); %>
                                </div>
                            <% } %>
                            <p class="mt-2 mb-1"><%= message.message %></p>
                            <% if (message.attachments) { %>
                                <% JSON.parse(message.attachments).filter(att => att).forEach(attachment => { %>
                                    <a href="<%= attachment %>" target="_blank" class="d-inline-block me-2">View Attachment</a>
                                <% }) %>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <% if (ticket.status === 'open') { %>
        <div class="card mt-4">
            <div class="card-header">
                <h2>Reply</h2>
            </div>
            <div class="card-body">
                <form action="/support/ticket/<%= ticket.ticketId %>" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea name="message" id="message" rows="5" class="form-control" required></textarea>
                    </div>
                    <div class="form-group">
                        <label for="attachment">Attachment</label>
                        <input type="file" name="attachment" id="attachment" class="form-control">
                    </div>
                    <button type="submit" class="btn btn-primary">Reply</button>
                </form>
            </div>
        </div>
    <% } %>
</div>

<%- include('../../modules/footer.ejs') %>
