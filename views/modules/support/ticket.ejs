<%- include('../../modules/header.ejs', {
    pageTitle: pageTitle,
    pageDescription: "View Support Ticket"
}) %>

<%- include('../../modules/navigationBar.ejs') %>

<%- include('../../partials/miniHeader.ejs', {
    headerTitle: `Ticket #${ticket.ticketId}`,
    globalImage,
}) %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <h2 class="mb-1"><%= ticket.title %></h2>
                    <% const statusClass = {
                        open: "bg-success",
                        closed: "bg-secondary",
                        pending: "bg-warning text-dark"
                    }[ticket.status] || "bg-secondary"; %>
                    <span class="badge rounded-pill <%= statusClass %>"><%= ticket.status %></span>
                </div>
                <% if (isStaff || isOwner) { %>
                    <form action="/support/ticket/<%= ticket.ticketId %>/status" method="POST" class="d-flex gap-2">
                        <% if (ticket.status === 'open') { %>
                            <button type="submit" name="status" value="closed" class="btn btn-outline-danger btn-sm">Close ticket</button>
                        <% } else { %>
                            <button type="submit" name="status" value="open" class="btn btn-outline-success btn-sm">Reopen ticket</button>
                        <% } %>
                    </form>
                <% } %>
            </div>
        </div>
        <div class="card-body">
            <p><strong>Created At:</strong> <span class="local-datetime" data-timestamp="<%= new Date(ticket.createdAt).toISOString() %>"></span></p>
            <div class="mt-3">
                <h4>Participants</h4>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-primary">Owner: <%= ticket.userId %></span>
                    <% participants.users.forEach((participant) => { %>
                        <span class="badge bg-info text-dark">User: <%= participant.username || participant.userId %></span>
                    <% }); %>
                    <% participants.groups.forEach((group) => { %>
                        <span class="badge" style="background-color: <%= group.badgeColor || '#6c757d' %>; color: <%= group.textColor || '#fff' %>">Group: <%= group.roleName || group.rankSlug || group.roleId %></span>
                    <% }); %>
                </div>
            </div>
            <% if (ticket.status === 'open' && (req.session.user.isStaff || req.session.user.userId === ticket.userId)) { %>
                <div class="row mt-3">
                    <div class="col-md-6">
                        <form action="/support/ticket/<%= ticket.ticketId %>/add-user" method="POST">
                            <div class="form-group">
                                <label for="userIdentifier">Add User</label>
                                <input type="text" class="form-control" id="userIdentifier" name="userIdentifier" placeholder="Username or User ID" required>
                            </div>
                            <button type="submit" class="btn btn-outline-primary mt-2">Add User</button>
                        </form>
                    </div>
                    <div class="col-md-6">
                        <form action="/support/ticket/<%= ticket.ticketId %>/add-group" method="POST">
                            <div class="form-group">
                                <label for="groupRoleId">Add Group</label>
                                <select class="form-control" id="groupRoleId" name="groupRoleId" required>
                                    <option value="">Select a group</option>
                                    <% rankOptions.forEach((rank) => { %>
                                        <option value="<%= rank.id %>"><%= rank.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-outline-secondary mt-2">Add Group</button>
                        </form>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header">
            <h2>Messages</h2>
        </div>
        <div class="card-body">
            <% messages.forEach(message => { %>
                <% const topRank = (message.ranks && message.ranks.length) ? message.ranks[0] : null; %>
                <% const cardClasses = ["card", "mb-3"];
                   if (message.isInternal) {
                       cardClasses.push("border-warning", "bg-light");
                   }
                %>
                <div class="<%= cardClasses.join(' ') %>">
                    <div class="card-body d-flex">
                        <div class="me-3">
                            <% if (message.avatarUrl) { %>
                                <img src="<%= message.avatarUrl %>" alt="<%= message.username %> avatar" class="rounded-circle" width="56" height="56">
                            <% } else { %>
                                <div class="rounded-circle bg-secondary" style="width:56px;height:56px;"></div>
                            <% } %>
                        </div>
                        <div class="flex-fill">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <strong style="color: <%= topRank?.badgeColor || '#0f172a' %>;"><%= message.username %></strong>
                                <% if (message.isInternal) { %>
                                    <span class="badge bg-warning text-dark">Internal note</span>
                                <% } %>
                                <span class="text-muted small local-datetime" data-timestamp="<%= new Date(message.createdAt).toISOString() %>"></span>
                            </div>
                            <% if (message.ranks && message.ranks.length) { %>
                                <div class="d-flex flex-wrap gap-1 mt-1">
                                    <% message.ranks.forEach((rank) => { %>
                                        <span class="badge" style="background-color: <%= rank.badgeColor || '#1f2937' %>; color: <%= rank.textColor || '#ffffff' %>;"><%= rank.displayName %></span>
                                    <% }); %>
                                </div>
                            <% } %>
                            <p class="mt-2 mb-1"><%= message.message %></p>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <% if (ticket.status === 'open') { %>
        <div class="card mt-4">
            <div class="card-header">
                <h2>Reply</h2>
            </div>
            <div class="card-body">
                <form action="/support/ticket/<%= ticket.ticketId %>" method="POST">
                    <% if (isStaff) { %>
                        <div class="form-group mb-3">
                            <label class="form-label">Reply visibility</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="visibility" id="visibilityPublic" value="public" checked>
                                <label class="form-check-label" for="visibilityPublic">Public reply (visible to everyone on the ticket)</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="visibility" id="visibilityInternal" value="internal">
                                <label class="form-check-label" for="visibilityInternal">Internal note (staff only, not sent to Discord)</label>
                            </div>
                        </div>
                    <% } else { %>
                        <input type="hidden" name="visibility" value="public">
                    <% } %>
                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea name="message" id="message" rows="5" class="form-control" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Reply</button>
                </form>
            </div>
        </div>
    <% } %>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".local-datetime").forEach((element) => {
            const timestamp = element.getAttribute("data-timestamp");
            if (!timestamp) return;
            const date = new Date(timestamp);
            element.textContent = date.toLocaleString();
        });
    });
</script>

<%- include('../../modules/footer.ejs') %>
