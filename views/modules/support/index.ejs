<%- include('../../modules/header.ejs', {
    pageTitle: pageTitle,
    pageDescription: "Support Tickets"
}) %>

<%- include('../../modules/navigationBar.ejs') %>

<%- include('../../partials/miniHeader.ejs', {
    headerTitle: "Support Tickets",
    globalImage,
}) %>

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h2 class="mb-0">My Tickets</h2>
        <a href="/support/create" class="btn btn-primary">Create New Ticket</a>
    </div>
    <div class="card">
        <div class="card-body">
            <% if (tickets.length === 0) { %>
                <p>You have no support tickets.</p>
            <% } else { %>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Ticket ID</th>
                            <th>Title</th>
                            <th>Status</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% tickets.forEach(ticket => { %>
                            <tr>
                                <td>#<%= ticket.ticketId %></td>
                                <td><%= ticket.title %></td>
                                <% const statusClass = {
                                    open: "bg-success",
                                    closed: "bg-secondary",
                                    pending: "bg-warning text-dark"
                                }[ticket.status] || "bg-secondary"; %>
                                <td>
                                    <span class="badge rounded-pill <%= statusClass %>"><%= ticket.status %></span>
                                </td>
                                <td><span class="local-datetime" data-timestamp="<%= new Date(ticket.createdAt).toISOString() %>"></span></td>
                                <td>
                                    <a href="/support/ticket/<%= ticket.ticketId %>" class="btn btn-primary">View</a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".local-datetime").forEach((element) => {
            const timestamp = element.getAttribute("data-timestamp");
            if (!timestamp) return;
            const date = new Date(timestamp);
            element.textContent = date.toLocaleString();
        });
    });
</script>

<%- include('../../modules/footer.ejs') %>
