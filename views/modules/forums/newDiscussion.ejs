<%- include("../../modules/header.ejs", {
    pageTitle: `Start a Discussion :: ${category ? category.name : pageTitle}`,
    pageDescription: category && category.description ? category.description : "Start a new community discussion"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: category ? `New Discussion in ${category.name}` : pageTitle,
  backgroundImage: globalImage
}) %>

<div class="container my-5 forums-container">
  <div class="row g-4">
    <div class="col-lg-3">
      <%- include("./partials/sidebar.ejs", {
        categories: categories,
        activeCategory: activeCategory
      }) %>
    </div>
    <div class="col-lg-9">
      <% if (req.cookies.alertType) { %>
        <%- include("../../partials/alert.ejs", {
          alertType: req.cookies.alertType,
          content: req.cookies.alertContent
        }) %>
      <% } %>

      <div class="forums-card card shadow-sm">
        <div class="card-body">
          <h4 class="mb-3">Create a new discussion</h4>
          <form action="/forums/category/<%= category.slug %>" method="post" class="forums-form">
            <div class="mb-3">
              <label class="form-label" for="discussionTitle">Title</label>
              <input type="text" class="form-control" id="discussionTitle" name="title" maxlength="200" required>
            </div>
            <div class="mb-3">
              <label class="form-label" for="discussionContent">Content</label>
              <%- include("../../partials/summerNoteEditor.ejs", {
                editorElementName: "discussionContent",
                editorPOSTElementName: "content",
                editorElementText: ""
              }) %>
            </div>
            <div class="text-end">
              <a class="btn btn-link" href="/forums/category/<%= category.slug %>">Cancel</a>
              <button type="submit" class="btn btn-main">Post Discussion</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    document.querySelectorAll('form[method="post"]').forEach(form => {
      form.addEventListener('submit', () => {
        const btn = form.querySelector('button[type="submit"]');
        if (!btn) return;
        setTimeout(() => {
          btn.disabled = true;
          btn.dataset.originalText = btn.textContent;
          btn.textContent = 'Submitting…';
        }, 0);
      });
    });
  })();
</script>

<%- include("../../modules/footer.ejs") %>
