<% const isOnline = profileSession && profileSession.isOnline; %>
<% const serverName = profileSession && profileSession.server ? profileSession.server.charAt(0).toUpperCase() + profileSession.server.slice(1) : "the network"; %>

<% const ranks = Array.isArray(profileRanks) ? profileRanks : []; %>

<section class="profile-hero hero-overlay" style="background: url(../<%= globalImage %>) no-repeat 50% 50%; background-size: cover;">
    <div class="profile-hero-overlay py-5">
        <div class="container">
            <div class="row align-items-center g-4">
                <div class="col-auto">
                    <div class="profile-avatar shadow-lg">
                        <img src="<%= profilePicture %>" alt="<%= profileApiData.username %>'s Avatar" class="img-fluid rounded-circle" width="160" height="160">
                    </div>
                </div>
                <div class="col">
                    <h1 class="text-white display-6 fw-bold mb-2"><%= profileApiData.username %></h1>
                    <% if (ranks.length) { %>
                        <div class="d-flex flex-wrap align-items-center profile-rank-pills mb-3">
                            <% ranks.forEach(function(rank) { %>
                                <span class="rank-pill"
                                      style="--rank-pill-bg: <%= rank.rankBadgeColour || '#ffffff' %>; --rank-pill-text: <%= rank.rankTextColour || '#0f172a' %>"
                                      title="<%= rank.displayName %>">
                                    <span class="rank-pill-name"><%= rank.displayName %></span>
                                </span>
                            <% }) %>
                        </div>
                    <% } %>
                    <div class="d-flex flex-wrap align-items-center gap-3 text-white-50">
                        <% if (isOnline) { %>
                            <span class="badge badge-soft-success d-inline-flex align-items-center gap-2">
                                <i class="fa-solid fa-circle"></i>
                                <span>Online</span>
                            </span>
                            <span>Playing on <span class="text-white fw-semibold"><%= serverName %></span></span>
                        <% } else if (profileSession && profileSession.lastOnlineDiff) { %>
                            <span class="badge badge-soft-danger d-inline-flex align-items-center gap-2">
                                <i class="fa-solid fa-circle"></i>
                                <span>Offline</span>
                            </span>
                            <span>Last seen <span class="text-white fw-semibold"><%= profileSession.lastOnlineDiff %> ago</span> on <span class="text-white fw-semibold"><%= serverName %></span></span>
                        <% } else { %>
                            <span class="badge badge-soft-secondary d-inline-flex align-items-center gap-2">
                                <i class="fa-solid fa-circle"></i>
                                <span>No recent session information available</span>
                            </span>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
