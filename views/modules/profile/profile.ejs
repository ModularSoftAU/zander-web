<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: config.siteConfiguration.tagline
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<%- include("../../modules/profile/profileHeader.ejs", {
    profileSession: profileSession,
    profileApiData: profileApiData,
    profilePicture: profilePicture,
    profileRanks: profileRanks
}) %>

<div class="container py-5 profile-container">
    <% if (req.cookies.alertType) { %>
        <div class="mb-4">
            <%- include("../../partials/alert.ejs", {
                alertType: req.cookies.alertType,
                content: req.cookies.alertContent
            }) %>
        </div>
    <% } %>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <ul class="nav nav-pills profile-tabs" id="profileTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <a class="nav-link active profile-tab-link" id="about-tab" data-bs-toggle="tab" href="#about" role="tab" aria-controls="about" aria-selected="true">
                                <i class="fa-solid fa-user me-2"></i>About Me
                            </a>
                        </li>
                        <% if (contextPermissions && contextPermissions.includes('zander.web.punishments')) { %>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link profile-tab-link" id="punishments-tab" data-bs-toggle="tab" href="#punishments" role="tab" aria-controls="punishments" aria-selected="false">
                                    <i class="fa-solid fa-shield me-2 text-danger"></i>Punishments
                                </a>
                            </li>
                        <% } %>
                        <% if (contextPermissions && contextPermissions.includes('zander.web.audit')) { %>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link profile-tab-link" id="audit-tab" data-bs-toggle="tab" href="#audit" role="tab" aria-controls="audit" aria-selected="false">
                                    <i class="fa-solid fa-magnifying-glass me-2 text-danger"></i>Audit
                                </a>
                            </li>
                        <% } %>
                        <% if (contextPermissions && contextPermissions.includes('zander.web.reports')) { %>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link profile-tab-link" id="reports-tab" data-bs-toggle="tab" href="#reports" role="tab" aria-controls="reports" aria-selected="false">
                                    <i class="fa-solid fa-flag me-2 text-danger"></i>Reports
                                </a>
                            </li>
                        <% } %>
                    </ul>

                    <div class="tab-content pt-4" id="profileTabsContent">
                        <div class="tab-pane fade show active" id="about" role="tabpanel" aria-labelledby="about-tab">
                            <div class="row gy-4 align-items-start mt-1 mb-4">
                                <div class="col-12 col-sm-6">
                                    <div class="profile-legacy-stat text-center text-sm-start">
                                        <h2 class="mb-1"><%= profileStats.totalLogins %></h2>
                                        <p class="text-muted text-uppercase small mb-0">Logins</p>
                                    </div>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <div class="profile-legacy-stat text-center text-sm-start">
                                        <h2 class="mb-1"><%= profileStats.totalPlaytime %></h2>
                                        <p class="text-muted text-uppercase small mb-0">Total Playtime</p>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-4">

                            <% if (profileApiData.social_aboutMe) { %>
                                <div class="profile-about-legacy">
                                    <%- profileApiData.social_aboutMe %>
                                </div>
                            <% } else { %>
                                <div class="alert alert-warning mb-0" role="alert">
                                    <%= profileApiData.username %> hasn't added an About section yet.
                                </div>
                            <% } %>
                        </div>

                        <% if (contextPermissions && contextPermissions.includes('zander.web.punishments')) { %>
                            <div class="tab-pane fade" id="punishments" role="tabpanel" aria-labelledby="punishments-tab">
                                <% const punishments = profilePunishmentsApiData && Array.isArray(profilePunishmentsApiData.data) ? profilePunishmentsApiData.data : []; %>
                                <% if (!punishments.length) { %>
                                    <div class="alert alert-warning mb-0" role="alert">
                                        No punishments found for this player.
                                    </div>
                                <% } else { %>
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th scope="col">Punishment ID</th>
                                                    <th scope="col">Punished By</th>
                                                    <th scope="col">Type</th>
                                                    <th scope="col">Reason</th>
                                                    <th scope="col">Expires</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% punishments.forEach(function (punishment) { %>
                                                    <% const appealReason = punishment.reasonRemoved || punishment.removedByReason || ""; %>
                                                    <% const isAppealed = String(appealReason).toLowerCase().includes("appeal"); %>
                                                    <% const punishmentId = punishment.id || punishment.punishmentId || punishment.punishment_id || "—"; %>
                                                    <% const punishedBy = punishment.bannedByUsername || punishment.bannedByUuid || "System"; %>
                                                    <% let expiryLabel = "—"; %>
                                                    <% if (punishment.type === "ban") { %>
                                                        <% if (moment(punishment.dateEnd).isValid()) { %>
                                                            <% if (moment(punishment.dateEnd).isAfter(moment())) { %>
                                                                <% expiryLabel = `${moment(punishment.dateEnd).fromNow(true)} remaining`; %>
                                                            <% } else { %>
                                                                <% expiryLabel = "Expired"; %>
                                                            <% } %>
                                                        <% } else { %>
                                                            <% expiryLabel = "Permanent"; %>
                                                        <% } %>
                                                    <% } %>
                                                    <tr class="<%= isAppealed ? 'table-warning' : '' %>">
                                                        <th scope="row"><%= punishmentId %></th>
                                                        <td><%= punishedBy %></td>
                                                        <td class="text-uppercase"><%= punishment.type || "Unknown" %></td>
                                                        <td><%= punishment.reason || "No reason provided." %></td>
                                                        <td><%= expiryLabel %></td>
                                                    </tr>
                                                <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                <% } %>
                            </div>
                        <% } %>

                        <% if (contextPermissions && contextPermissions.includes('zander.web.audit')) { %>
                            <div class="tab-pane fade" id="audit" role="tabpanel" aria-labelledby="audit-tab">
                                <h5 class="text-uppercase text-muted mb-3">Minecraft</h5>
                                <div class="table-responsive mb-4">
                                    <table class="table table-sm align-middle mb-0">
                                        <tbody>
                                            <tr>
                                                <th scope="row" class="w-50">Last Minecraft Session</th>
                                                <td data-bs-toggle="tooltip" data-placement="top" title="<%= moment(profileApiData.audit_lastMinecraftLogin).fromNow() %>">
                                                    <% if (moment(profileApiData.audit_lastMinecraftLogin).isValid()) { %>
                                                        <%= moment(profileApiData.audit_lastMinecraftLogin).format('LLLL') %>
                                                    <% } else { %>
                                                        <i>No data!</i>
                                                    <% } %>
                                                </td>
                                            </tr>
                                            <tr>
                                                <th scope="row">Last Minecraft Message</th>
                                                <td data-bs-toggle="tooltip" data-placement="top" title="<%= moment(profileApiData.audit_lastMinecraftMessage).fromNow() %>">
                                                    <% if (moment(profileApiData.audit_lastMinecraftMessage).isValid()) { %>
                                                        <%= moment(profileApiData.audit_lastMinecraftMessage).format('LLLL') %>
                                                    <% } else { %>
                                                        <i>No data!</i>
                                                    <% } %>
                                                </td>
                                            </tr>
                                            <tr>
                                                <th scope="row">Last Minecraft Punishment</th>
                                                <td>
                                                    <div class="alert alert-warning mb-0" role="alert">
                                                        Feature coming soon, currently in development.
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <h5 class="text-uppercase text-muted mb-3">Discord</h5>
                                <div class="table-responsive mb-4">
                                    <table class="table table-sm align-middle mb-0">
                                        <tbody>
                                            <tr>
                                                <th scope="row" class="w-50">Last Discord Message</th>
                                                <td data-bs-toggle="tooltip" data-placement="top" title="<%= moment(profileApiData.audit_lastDiscordMessage).fromNow() %>">
                                                    <% if (moment(profileApiData.audit_lastDiscordMessage).isValid()) { %>
                                                        <%= moment(profileApiData.audit_lastDiscordMessage).format('LLLL') %>
                                                    <% } else { %>
                                                        <i>No data!</i>
                                                    <% } %>
                                                </td>
                                            </tr>
                                            <tr>
                                                <th scope="row">Last Discord Voice Session</th>
                                                <td data-bs-toggle="tooltip" data-placement="top" title="<%= moment(profileApiData.audit_lastDiscordVoice).fromNow() %>">
                                                    <% if (moment(profileApiData.audit_lastDiscordVoice).isValid()) { %>
                                                        <%= moment(profileApiData.audit_lastDiscordVoice).format('LLLL') %>
                                                    <% } else { %>
                                                        <i>No data!</i>
                                                    <% } %>
                                                </td>
                                            </tr>
                                            <tr>
                                                <th scope="row">Last Discord Punishment</th>
                                                <td>
                                                    <div class="alert alert-warning mb-0" role="alert">
                                                        Feature coming soon, currently in development.
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <h5 class="text-uppercase text-muted mb-3">Website</h5>
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0">
                                        <tbody>
                                            <tr>
                                                <th scope="row" class="w-50">Last Website Login</th>
                                                <td data-bs-toggle="tooltip" data-placement="top" title="<%= moment(profileApiData.audit_lastWebsiteLogin).fromNow() %>">
                                                    <% if (moment(profileApiData.audit_lastWebsiteLogin).isValid()) { %>
                                                        <%= moment(profileApiData.audit_lastWebsiteLogin).format('LLLL') %>
                                                    <% } else { %>
                                                        <i>No data!</i>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        <% } %>

                        <% if (contextPermissions && contextPermissions.includes('zander.web.reports')) { %>
                            <div class="tab-pane fade" id="reports" role="tabpanel" aria-labelledby="reports-tab">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th scope="col">Report ID</th>
                                                <th scope="col">Reported User</th>
                                                <th scope="col">Reason</th>
                                                <th scope="col">Platform</th>
                                                <th scope="col">Date/Time</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% profileReportsApiData.data.forEach(report => { %>
                                                <tr>
                                                    <td class="fw-semibold"><%= report.reportId %></td>
                                                    <td><%= report.reportedUser %></td>
                                                    <td><%= report.reportReason %></td>
                                                    <td><span class="badge text-bg-primary"><%= report.reportPlatform %></span></td>
                                                    <td><%= moment(report.reportDateTime).format('Do MMMM YYYY, h:mm a') %></td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title text-uppercase text-muted mb-3">Member Since</h5>
                    <p class="mb-1 fw-semibold" data-bs-toggle="tooltip" data-placement="top" title="<%= moment(profileApiData.joined).fromNow() %>">
                        <%= moment(profileApiData.joined).format('LLLL') %>
                    </p>
                    <p class="text-muted small mb-0">Joined <%= moment(profileApiData.joined).fromNow() %></p>
                </div>
            </div>

            <% if (profileApiData.social_interests) { %>
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">
                        <h5 class="card-title text-uppercase text-muted mb-3">Interests</h5>
                        <p class="mb-0"><%= profileApiData.social_interests %></p>
                    </div>
                </div>
            <% } %>

            <% const hasSocialConnections = profileApiData.social_discord || profileApiData.social_steam || profileApiData.social_twitch || profileApiData.social_youtube || profileApiData.social_twitter_x || profileApiData.social_instagram || profileApiData.social_reddit || profileApiData.social_spotify; %>
            <% if (hasSocialConnections || profileApiData.discordId) { %>
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h5 class="card-title text-uppercase text-muted mb-3">Social Connections</h5>

                        <% if (profileApiData.discordId) { %>
                            <div class="profile-social-highlight mb-3">
                                <span class="badge badge-soft-discord me-2"><i class="fa-brands fa-discord me-1"></i>Discord Connected</span>
                                <% if (profileApiData.social_discord) { %>
                                    <span class="fw-semibold"><%= profileApiData.social_discord %></span>
                                <% } %>
                            </div>
                        <% } %>

                        <% if (hasSocialConnections) { %>
                            <ul class="list-unstyled profile-social-list mb-0">
                                <% if (profileApiData.social_discord && !profileApiData.discordId) { %>
                                    <li class="profile-social-item"><i class="fa-brands fa-discord"></i> <span><%= profileApiData.social_discord %></span></li>
                                <% } %>
                                <% if (profileApiData.social_steam) { %>
                                    <li class="profile-social-item"><i class="fa-brands fa-steam"></i> <a href="https://steamcommunity.com/id/<%= profileApiData.social_steam %>" target="_blank" rel="noopener">Steam</a></li>
                                <% } %>
                                <% if (profileApiData.social_twitch) { %>
                                    <li class="profile-social-item"><i class="fa-brands fa-twitch"></i> <a href="https://twitch.tv/<%= profileApiData.social_twitch %>" target="_blank" rel="noopener">Twitch</a></li>
                                <% } %>
                                <% if (profileApiData.social_youtube) { %>
                                    <li class="profile-social-item"><i class="fa-brands fa-youtube"></i> <a href="https://youtube.com/<%= profileApiData.social_youtube %>" target="_blank" rel="noopener">YouTube</a></li>
                                <% } %>
                                <% if (profileApiData.social_twitter_x) { %>
                                    <li class="profile-social-item"><i class="fa-brands fa-twitter"></i> <a href="https://twitter.com/<%= profileApiData.social_twitter_x %>" target="_blank" rel="noopener">Twitter / X</a></li>
                                <% } %>
                                <% if (profileApiData.social_instagram) { %>
                                    <li class="profile-social-item"><i class="fa-brands fa-square-instagram"></i> <a href="https://instagram.com/<%= profileApiData.social_instagram %>" target="_blank" rel="noopener">Instagram</a></li>
                                <% } %>
                                <% if (profileApiData.social_reddit) { %>
                                    <li class="profile-social-item"><i class="fa-brands fa-reddit"></i> <a href="<%= profileApiData.social_reddit %>" target="_blank" rel="noopener">Reddit</a></li>
                                <% } %>
                                <% if (profileApiData.social_spotify) { %>
                                    <li class="profile-social-item"><i class="fa-brands fa-spotify"></i> <a href="https://open.spotify.com/user/<%= profileApiData.social_spotify %>" target="_blank" rel="noopener">Spotify</a></li>
                                <% } %>
                            </ul>
                        <% } else { %>
                            <p class="text-muted small mb-0">No additional social links shared yet.</p>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>
