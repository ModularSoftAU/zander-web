<% if (features.votes && topVoters && topVoters.length > 0) { %>
<section class="section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8 text-center">
        <div class="section-title">
          <h2>Top Voters This Month</h2>
          <p class="mb-0">Thank you to everyone who votes for us! Your support helps the community grow.</p>
        </div>
      </div>
    </div>

    <div class="row justify-content-center mt-4">
      <div class="col-lg-6">
        <ol class="list-group list-group-numbered">
          <% topVoters.forEach(function(voter) { %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
              <img
                src="https://craftatar.com/avatars/<%= voter.uuid %>?size=24&overlay"
                alt="<%= voter.username %>'s avatar"
                width="24"
                height="24"
                style="border-radius: 3px;"
                onerror="this.style.display='none'"
              >
              <span><%= voter.username %></span>
            </div>
            <span class="badge bg-primary rounded-pill"><%= voter.voteCount %> vote<%= voter.voteCount !== 1 ? 's' : '' %></span>
          </li>
          <% }); %>
        </ol>
      </div>
    </div>
  </div>
</section>
<% } %>
