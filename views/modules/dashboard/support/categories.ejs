<%- include('../../../modules/header.ejs', {
    pageTitle: "Manage Support Categories",
    pageDescription: "Create, edit, and delete support ticket categories"
}) %>

<%- include('../dashboard-header.ejs') %>

<div class="container-fluid">
    <div class="row">
        <%- include('../dashboard-sidebar.ejs') %>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Manage Support Categories</h1>
            </div>

            <div class="card">
                <div class="card-header">
                    <h2>Create New Category</h2>
                </div>
                <div class="card-body">
                    <form action="/dashboard/support/categories" method="POST">
                        <div class="form-group mb-3">
                            <label for="name">Category Name</label>
                            <input type="text" name="name" id="name" class="form-control" required>
                        </div>
                        <div class="form-group mb-3">
                            <label for="description">Description</label>
                            <textarea name="description" id="description" rows="3" class="form-control" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Create Category</button>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h2>Existing Categories</h2>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th>Permissions</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% categories.forEach(category => { %>
                                    <tr>
                                        <td><%= category.name %></td>
                                        <td><%= category.description %></td>
                                        <td>
                                            <% if (category.permissions && category.permissions.length > 0) { %>
                                                <% category.permissions.forEach(permission => { %>
                                                    <span class="badge bg-secondary mb-1"><%= permission.roleName %></span><br>
                                                <% }) %>
                                            <% } else { %>
                                                <span class="text-muted">No permissions set.</span>
                                            <% } %>
                                            <form action="/dashboard/support/categories/<%= category.categoryId %>/permissions" method="POST" class="mt-2">
                                                <div class="input-group input-group-sm">
                                                    <select name="roleId" class="form-select">
                                                        <% roles.forEach(role => { %>
                                                            <option value="<%= role.id %>"><%= role.name %></option>
                                                        <% }) %>
                                                    </select>
                                                    <button type="submit" class="btn btn-success">Add Role</button>
                                                </div>
                                            </form>
                                        </td>
                                        <td>
                                            <div class="btn-group">
                                                <a href="/dashboard/support/categories/<%= category.categoryId %>/edit" class="btn btn-sm btn-primary">Edit</a>
                                                <form action="/dashboard/support/categories/<%= category.categoryId %>/delete" method="POST" style="display: inline-block;">
                                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<%- include('../../../modules/footer.ejs') %>
