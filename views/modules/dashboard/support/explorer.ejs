<%- include('../../../modules/header.ejs', {
    pageTitle: "Support Ticket Explorer",
    pageDescription: "Browse and manage support tickets by category"
}) %>

<div class="container-fluid">
    <div class="row">
        <%- include('../dashboard-sidebar.ejs') %>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="page-header">
                <div class="container">
                    <h1>Support Ticket Explorer</h1>
                </div>
            </div>

            <div class="container">
                <div class="card">
                    <div class="card-header">
                        <h2>All Tickets</h2>
                    </div>
                    <div class="card-body">
                        <form action="/dashboard/support/explorer" method="GET">
                            <div class="input-group mb-3">
                                <select name="category" class="form-control">
                                    <option value="">All Categories</option>
                                    <% categories.forEach(category => { %>
                                        <option value="<%= category.categoryId %>" <%= selectedCategory == category.categoryId ? 'selected' : '' %>><%= category.name %></option>
                                    <% }) %>
                                </select>
                                <button type="submit" class="btn btn-primary">Filter</button>
                            </div>
                        </form>

                        <% if (tickets.length === 0) { %>
                            <p>No support tickets found.</p>
                        <% } else { %>
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Ticket ID</th>
                                        <th>Title</th>
                                        <th>Status</th>
                                        <th>User</th>
                                        <th>Created At</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% tickets.forEach(ticket => { %>
                                        <tr>
                                            <td>#<%= ticket.ticketId %></td>
                                            <td><%= ticket.title %></td>
                                            <td><%= ticket.status %></td>
                                            <td><%= ticket.username %></td>
                                            <td><%= new Date(ticket.createdAt).toLocaleString() %></td>
                                            <td>
                                                <a href="/support/ticket/<%= ticket.ticketId %>" class="btn btn-primary">View</a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        <% } %>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<%- include('../../../modules/footer.ejs') %>
