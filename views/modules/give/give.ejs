<%- include("../header.ejs", {
    pageTitle: "Give",
    pageDescription: "Support the Crafting for Christ network"
}) %>

<%- include("../navigationBar.ejs") %>

<%- include("../../partials/miniHeader.ejs", {
  headerTitle: "Give",
  backgroundImage: globalImage
}) %>

<section class="section">
    <div class="container">
        <div class="row text-center">
            <div class="col-12">
                <h2 class="mb-4">Support the Future of Our Network</h2>
                <p class="lead mb-5">Our Minecraft network is migrating to a new, high-performance hosting provider to better serve our community. Your support helps us cover the increased operational costs and continue providing a place where you can play, grow, and be encouraged.</p>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-center mb-4">
                            <i class="fas fa-server fa-3x text-primary"></i>
                        </div>
                        <h4 class="card-title text-center">Why We're Moving</h4>
                        <p class="card-text">This migration will improve the quality, reliability, and performance of our entire network, ensuring a smoother and more enjoyable experience for everyone.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-center mb-4">
                            <i class="fas fa-dollar-sign fa-3x text-success"></i>
                        </div>
                        <h4 class="card-title text-center">How You Can Help</h4>
                        <p class="card-text">Better hosting comes with increased costs. You can support us by purchasing a rank or subscribing to a monthly tier. Every contribution helps keep the network running smoothly.</p>
                        <div class="text-center mt-4">
                            <a href="https://craftingforchrist.net/ranks" target="_blank" class="btn btn-primary">Support the Server</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-center mb-4">
                            <i class="fas fa-file-invoice-dollar fa-3x text-info"></i>
                        </div>
                        <h4 class="card-title text-center">Financial Transparency</h4>
                        <p class="card-text">We believe in transparency. In the next 1–2 weeks, we will publish a page outlining our financial status, which will be updated regularly to keep our community informed.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-12 text-center">
                <h3>Thank You!</h3>
                <p>A big thank-you to our current hosting provider and to our awesome community for continuing to play, pray, and grow with us. ❤️</p>
            </div>
        </div>
    </div>
</section>

<%- include("../footer.ejs") %>
