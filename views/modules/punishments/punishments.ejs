<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Review recent punishments across the network."
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-2">
        <div>
            <h2 class="mb-1">Punishments</h2>
            <p class="text-muted mb-0">Latest actions across the network.</p>
        </div>
        <span class="text-muted small">Page <%= apiData.page || 1 %></span>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <% const punishments = apiData && Array.isArray(apiData.data) ? apiData.data : []; %>
            <% if (!punishments.length) { %>
                <div class="alert alert-warning mb-0" role="alert">
                    No punishments were found.
                </div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Punishment ID</th>
                                <th scope="col">Player</th>
                                <th scope="col">Punished By</th>
                                <th scope="col">Type</th>
                                <th scope="col">Reason</th>
                                <th scope="col">Expires</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% punishments.forEach(function (punishment) { %>
                                <% const appealReason = punishment.reasonRemoved || punishment.removedByReason || ""; %>
                                <% const isAppealed = String(appealReason).toLowerCase().includes("appeal"); %>
                                <% const punishmentId = punishment.id || punishment.punishmentId || punishment.punishment_id || "—"; %>
                                <% const punishedBy = punishment.bannedByUsername || punishment.bannedByUuid || "System"; %>
                                <% const playerName = punishment.bannedUsername || punishment.bannedUuid || "Unknown"; %>
                                <% let expiryLabel = "—"; %>
                                <% if (punishment.type === "ban") { %>
                                    <% if (moment(punishment.dateEnd).isValid()) { %>
                                        <% if (moment(punishment.dateEnd).isAfter(moment())) { %>
                                            <% expiryLabel = `${moment(punishment.dateEnd).fromNow(true)} remaining`; %>
                                        <% } else { %>
                                            <% expiryLabel = "Expired"; %>
                                        <% } %>
                                    <% } else { %>
                                        <% expiryLabel = "Permanent"; %>
                                    <% } %>
                                <% } %>
                                <tr class="<%= isAppealed ? 'table-warning' : '' %>">
                                    <th scope="row"><%= punishmentId %></th>
                                    <td>
                                        <% if (punishment.bannedUsername) { %>
                                            <a href="/profile/<%= punishment.bannedUsername %>"><%= playerName %></a>
                                        <% } else { %>
                                            <%= playerName %>
                                        <% } %>
                                    </td>
                                    <td><%= punishedBy %></td>
                                    <td class="text-uppercase"><%= punishment.type || "Unknown" %></td>
                                    <td><%= punishment.reason || "No reason provided." %></td>
                                    <td><%= expiryLabel %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <% const page = apiData.page || 1; %>
                <% const limit = apiData.limit || punishments.length; %>
                <% const hasNext = punishments.length === limit; %>
                <nav class="mt-4" aria-label="Punishments pagination">
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="/punishments?page=<%= Math.max(page - 1, 1) %>&limit=<%= limit %>">&laquo; Previous</a>
                        </li>
                        <li class="page-item disabled">
                            <span class="page-link">Page <%= page %></span>
                        </li>
                        <li class="page-item <%= hasNext ? '' : 'disabled' %>">
                            <a class="page-link" href="/punishments?page=<%= page + 1 %>&limit=<%= limit %>">Next &raquo;</a>
                        </li>
                    </ul>
                </nav>
            <% } %>
        </div>
    </div>
</div>

<%- include("../../modules/footer.ejs") %>
