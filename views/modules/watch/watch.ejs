<%- include("../../modules/header.ejs", {
    pageTitle: pageTitle,
    pageDescription: "Watch CFC creator streams and videos"
}) %>

<%- include("../../modules/navigationBar.ejs") %>

<div class="container py-5">
    <% if (req.cookies.alertType) { %>
        <div class="mb-4">
            <%- include("../../partials/alert.ejs", {
                alertType: req.cookies.alertType,
                content: req.cookies.alertContent
            }) %>
        </div>
    <% } %>

    <div class="mb-4">
        <h2 class="mb-1">Watch</h2>
        <p class="text-muted mb-0">Creator streams and videos.</p>
    </div>

    <%
      function fmtCount(n) {
        if (n == null) return null;
        n = Number(n);
        if (n >= 1000000) return (n / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
        if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
        return String(n);
      }

      // Collect unique creators across both sections for the filter bar
      const allItems = [...(liveContent || []), ...(videoContent || [])];
      const creatorsMap = new Map();
      for (const item of allItems) {
        if (!creatorsMap.has(item.user_id)) creatorsMap.set(item.user_id, item);
      }
      const creators = [...creatorsMap.values()];
    %>

    <%# Creator filter bar — only shown when there are multiple creators %>
    <% if (creators.length > 1) { %>
    <div class="mb-4 d-flex flex-wrap gap-2 align-items-center" id="creator-filter">
        <button class="btn btn-sm btn-dark active" data-filter="all">All creators</button>
        <% for (const c of creators) { %>
            <button class="btn btn-sm btn-outline-secondary" data-filter="<%= c.user_id %>">
                <%= c.username %>
            </button>
        <% } %>
    </div>
    <% } %>

    <%# Live Now %>
    <section class="mb-5">
        <h2 class="h5 fw-semibold mb-3">
            <% if (liveContent && liveContent.length > 0) { %>
                <span class="badge bg-danger me-2" style="font-size:0.65em;vertical-align:middle;">LIVE</span>
            <% } %>
            Live Now
        </h2>

        <% if (!liveContent || liveContent.length === 0) { %>
            <div class="card border-0 bg-light text-center py-5">
                <div class="card-body">
                    <i class="fa-solid fa-satellite-dish fa-2x text-muted mb-3"></i>
                    <p class="text-muted mb-0">No creators are live right now. Check back soon!</p>
                </div>
            </div>
        <% } else { %>
            <div class="row g-3" id="live-grid">
                <% for (const item of liveContent) { %>
                <div class="col-sm-6 col-lg-4 watch-card-col" data-user-id="<%= item.user_id %>">
                    <div class="card border-0 shadow-sm h-100 watch-card">
                        <%# Thumbnail links to stream %>
                        <a href="<%= item.watch_url %>" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                            <div class="position-relative">
                                <% if (item.thumbnail_url) { %>
                                    <img src="<%= item.thumbnail_url %>" alt="<%= item.title %>" class="card-img-top" style="aspect-ratio:16/9;object-fit:cover;">
                                <% } else { %>
                                    <div class="card-img-top bg-dark d-flex align-items-center justify-content-center" style="aspect-ratio:16/9;">
                                        <i class="fa-solid fa-video fa-2x text-muted"></i>
                                    </div>
                                <% } %>
                                <span class="badge bg-danger position-absolute top-0 start-0 m-2">LIVE</span>
                                <% if (item.platform === 'twitch') { %>
                                    <span class="badge position-absolute top-0 end-0 m-2" style="background:#9146FF;"><i class="fab fa-twitch me-1"></i>Twitch</span>
                                <% } else { %>
                                    <span class="badge bg-danger position-absolute top-0 end-0 m-2"><i class="fab fa-youtube me-1"></i>YouTube</span>
                                <% } %>
                            </div>
                        </a>
                        <div class="card-body p-3 d-flex flex-column">
                            <h6 class="card-title mb-1 fw-semibold text-truncate" title="<%= item.title %>">
                                <a href="<%= item.watch_url %>" target="_blank" rel="noopener noreferrer" class="text-dark text-decoration-none stretched-link-title">
                                    <%= item.title || 'Untitled Stream' %>
                                </a>
                            </h6>
                            <p class="card-text text-muted small mb-3">
                                <a href="/profile/<%= item.username %>" class="text-muted fw-semibold text-decoration-none"><i class="fa-solid fa-user me-1"></i><%= item.username %></a>
                                <% if (item.started_at) { %>
                                    &nbsp;&bull;&nbsp;<i class="fa-solid fa-clock me-1"></i>Started <%= moment(item.started_at).fromNow() %>
                                <% } %>
                                <% const liveViewers = fmtCount(item.viewer_count); if (liveViewers) { %>
                                    &nbsp;&bull;&nbsp;<i class="fa-solid fa-eye me-1"></i><%= liveViewers %> viewers
                                <% } %>
                            </p>
                            <div class="mt-auto d-flex gap-2">
                                <a href="/profile/<%= item.username %>" class="btn btn-sm btn-outline-secondary flex-grow-1">
                                    <i class="fa-solid fa-user me-1"></i>Profile
                                </a>
                                <% if (item.platform === 'twitch') { %>
                                    <a href="<%= item.watch_url %>" target="_blank" rel="noopener noreferrer" class="btn btn-sm flex-grow-1" style="background:#9146FF;color:#fff;">
                                        <i class="fab fa-twitch me-1"></i>Follow
                                    </a>
                                <% } else { %>
                                    <a href="https://www.youtube.com/channel/<%= item.external_channel_id %>?sub_confirmation=1" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-danger flex-grow-1">
                                        <i class="fab fa-youtube me-1"></i>Subscribe
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
            </div>
        <% } %>
    </section>

    <%# Latest Videos %>
    <section>
        <h2 class="h5 fw-semibold mb-3">Latest Videos</h2>

        <% if (!videoContent || videoContent.length === 0) { %>
            <div class="card border-0 bg-light text-center py-5">
                <div class="card-body">
                    <i class="fa-solid fa-film fa-2x text-muted mb-3"></i>
                    <p class="text-muted mb-0">No recent creator videos yet.</p>
                </div>
            </div>
        <% } else { %>
            <div class="row g-3" id="video-grid">
                <% for (const item of videoContent) { %>
                <div class="col-sm-6 col-lg-4 watch-card-col" data-user-id="<%= item.user_id %>">
                    <div class="card border-0 shadow-sm h-100 watch-card">
                        <%# Thumbnail links to video %>
                        <a href="<%= item.watch_url %>" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                            <div class="position-relative">
                                <% if (item.thumbnail_url) { %>
                                    <img src="<%= item.thumbnail_url %>" alt="<%= item.title %>" class="card-img-top" style="aspect-ratio:16/9;object-fit:cover;">
                                <% } else { %>
                                    <div class="card-img-top bg-dark d-flex align-items-center justify-content-center" style="aspect-ratio:16/9;">
                                        <i class="fa-solid fa-video fa-2x text-muted"></i>
                                    </div>
                                <% } %>
                                <% if (item.platform === 'twitch') { %>
                                    <span class="badge position-absolute top-0 end-0 m-2" style="background:#9146FF;"><i class="fab fa-twitch me-1"></i>Twitch</span>
                                <% } else { %>
                                    <span class="badge bg-danger position-absolute top-0 end-0 m-2"><i class="fab fa-youtube me-1"></i>YouTube</span>
                                <% } %>
                            </div>
                        </a>
                        <div class="card-body p-3 d-flex flex-column">
                            <h6 class="card-title mb-1 fw-semibold" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;" title="<%= item.title %>">
                                <a href="<%= item.watch_url %>" target="_blank" rel="noopener noreferrer" class="text-dark text-decoration-none">
                                    <%= item.title || 'Untitled Video' %>
                                </a>
                            </h6>
                            <p class="card-text text-muted small mb-3">
                                <a href="/profile/<%= item.username %>" class="text-muted fw-semibold text-decoration-none"><i class="fa-solid fa-user me-1"></i><%= item.username %></a>
                                <% if (item.published_at) { %>
                                    &nbsp;&bull;&nbsp;<i class="fa-solid fa-clock me-1"></i><%= moment(item.published_at).fromNow() %>
                                <% } %>
                                <% const vidViews = fmtCount(item.viewer_count); if (vidViews) { %>
                                    &nbsp;&bull;&nbsp;<i class="fa-solid fa-eye me-1"></i><%= vidViews %> views
                                <% } %>
                            </p>
                            <div class="mt-auto d-flex gap-2">
                                <a href="/profile/<%= item.username %>" class="btn btn-sm btn-outline-secondary flex-grow-1">
                                    <i class="fa-solid fa-user me-1"></i>Profile
                                </a>
                                <% if (item.platform === 'twitch') { %>
                                    <a href="<%= item.watch_url %>" target="_blank" rel="noopener noreferrer" class="btn btn-sm flex-grow-1" style="background:#9146FF;color:#fff;">
                                        <i class="fab fa-twitch me-1"></i>Follow
                                    </a>
                                <% } else { %>
                                    <a href="https://www.youtube.com/channel/<%= item.external_channel_id %>?sub_confirmation=1" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-danger flex-grow-1">
                                        <i class="fab fa-youtube me-1"></i>Subscribe
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
            </div>
        <% } %>
    </section>
</div>

<style>
.watch-card { transition: transform 0.15s ease, box-shadow 0.15s ease; }
.watch-card:hover { transform: translateY(-3px); box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,.15) !important; }
</style>

<script>
(function () {
  const filterBar = document.getElementById('creator-filter');
  if (!filterBar) return;

  filterBar.addEventListener('click', function (e) {
    const btn = e.target.closest('button[data-filter]');
    if (!btn) return;

    const filter = btn.dataset.filter;

    // Update active pill
    filterBar.querySelectorAll('button').forEach(b => b.classList.remove('active', 'btn-dark', 'btn-outline-secondary'));
    filterBar.querySelectorAll('button').forEach(b => b.classList.add(b === btn ? 'btn-dark' : 'btn-outline-secondary'));
    btn.classList.add('active');

    // Show/hide cards
    document.querySelectorAll('.watch-card-col').forEach(function (col) {
      const match = filter === 'all' || col.dataset.userId === filter;
      col.style.display = match ? '' : 'none';
    });
  });
})();
</script>

<%- include("../../modules/footer.ejs") %>
