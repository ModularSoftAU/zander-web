PORT=8080
siteAddress=http://localhost:8080
TZ=Australia/Sydney

discordAPIKey=APIKEY
discordClientId=CLIENTID
discordClientSecret=CLIENTSECRET
apiKey=KEY

# Twitch OAuth — register at https://dev.twitch.tv/console/apps
twitchClientId=CLIENTID
twitchClientSecret=CLIENTSECRET

# Google/YouTube OAuth & API — register at https://console.cloud.google.com
# OAuth 2.0 client: Web application, redirect URI = siteAddress/profile/social/youtube/callback
# Enable: YouTube Data API v3
googleClientId=CLIENTID
googleClientSecret=CLIENTSECRET
youtubeApiKey=APIKEY

sessionCookieSecret=THISISNOTVERYSECRETANDITHINKYOUSHOULDCHANGEIT

databaseHost=database.example.com
databasePort=3306
databaseUser=root
databasePassword=root
databaseName=zander

# Web Push (VAPID) — generate keys with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=